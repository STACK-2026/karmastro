# Security + SEO headers served by Cloudflare Pages for every route.
#
# CSP is intentionally pragmatic: we allow 'unsafe-inline' for scripts and
# styles because the site ships inline JSON-LD blocks (rich results),
# inline Astro hydration markers, and Tailwind inline styles. Switching
# to nonce-based CSP means regenerating hashes on every build; not worth
# the breakage risk for the security delta.
#
# Connect allowlist covers the two live third parties:
#   - Supabase API (nkjbmbdrvejemzrggxvr.supabase.co) for newsletter +
#     horoscope fetches
#   - OpenStreetMap Nominatim for birth-place geocoding in calculators

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), microphone=(), camera=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https://nkjbmbdrvejemzrggxvr.supabase.co https://nominatim.openstreetmap.org; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://nkjbmbdrvejemzrggxvr.supabase.co; upgrade-insecure-requests; manifest-src 'self'; worker-src 'self' blob:; object-src 'none'

# Long-cache static assets (hashed by Astro/Vite)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
