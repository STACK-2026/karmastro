---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ShareButton from "../../../components/ShareButton.astro";
import ZodiacSymbol from "../../../components/ZodiacSymbol.astro";
import NewsletterCapture from "../../../components/NewsletterCapture.astro";
import { ZODIAC_SIGNS, SIGN_SLUGS, getSignBySlug, formatFrenchDate } from "../../../data/zodiac";
import fs from "fs";
import path from "path";

export function getStaticPaths() {
  return SIGN_SLUGS.map((slug) => ({ params: { signe: slug } }));
}

const { signe } = Astro.params;
const sign = getSignBySlug(signe as string);
if (!sign) throw new Error(`Unknown sign: ${signe}`);

const dataDir = path.join(process.cwd(), "src/data/horoscope");
let entry: any = null;
let tomorrowEntry: any = null;
// Use Paris timezone (Europe/Paris) so "today" matches the real FR calendar day
function parisDate(d: Date = new Date()): string {
  return new Intl.DateTimeFormat("fr-CA", {
    timeZone: "Europe/Paris",
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(d);
}
let todayDate = parisDate();
let tomorrowDate = "";
let archiveDates: string[] = [];

type ArchiveCard = {
  date: string;
  intro: string;
  mantra: string | null;
  luckyNumber: number | null;
  color: string | null;
  moonPhase: string | null;
};
let archiveCards: ArchiveCard[] = [];

function addDays(dateStr: string, days: number): string {
  const d = new Date(dateStr + "T12:00:00Z");
  d.setUTCDate(d.getUTCDate() + days);
  return d.toISOString().slice(0, 10);
}

try {
  if (fs.existsSync(dataDir)) {
    const files = fs
      .readdirSync(dataDir)
      .filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f))
      .sort();

    archiveDates = files.map((f) => f.replace(".json", "")).reverse();

    // "Today" in Paris timezone (CEST/CET)
    const realToday = parisDate();
    const pastFiles = files.filter((f) => f.replace(".json", "") <= realToday);
    if (pastFiles.length > 0) {
      const latestFile = pastFiles[pastFiles.length - 1];
      todayDate = latestFile.replace(".json", "");
      const data = JSON.parse(fs.readFileSync(path.join(dataDir, latestFile), "utf-8"));
      entry = data[sign.slug];
    } else if (files.length > 0) {
      const latestFile = files[files.length - 1];
      todayDate = latestFile.replace(".json", "");
      const data = JSON.parse(fs.readFileSync(path.join(dataDir, latestFile), "utf-8"));
      entry = data[sign.slug];
    }

    // "Tomorrow" horoscope : premium preview
    tomorrowDate = addDays(todayDate, 1);
    const tomorrowFile = path.join(dataDir, `${tomorrowDate}.json`);
    if (fs.existsSync(tomorrowFile)) {
      const tomorrowData = JSON.parse(fs.readFileSync(tomorrowFile, "utf-8"));
      tomorrowEntry = tomorrowData[sign.slug];
    }

    // Archive cards : load up to 14 past entries for this sign with rich metadata
    const pastArchive = files
      .filter((f) => f.replace(".json", "") < todayDate)
      .reverse()
      .slice(0, 14);

    for (const f of pastArchive) {
      try {
        const archiveData = JSON.parse(fs.readFileSync(path.join(dataDir, f), "utf-8"));
        const signEntry = archiveData[sign.slug];
        if (!signEntry) continue;
        archiveCards.push({
          date: f.replace(".json", ""),
          intro: (signEntry.intro || "").slice(0, 110),
          mantra: signEntry.mantra || null,
          luckyNumber: signEntry.luckyNumber ?? null,
          color: signEntry.color || null,
          moonPhase: signEntry.moonPhase || null,
        });
      } catch (e) {
        /* skip corrupted file */
      }
    }
  }
} catch (e) {
  console.warn("Horoscope data load error:", e);
}

const tomorrowFormatted = tomorrowDate ? formatFrenchDate(tomorrowDate) : "";

const dateFormatted = formatFrenchDate(todayDate);
const title = `Horoscope ${sign.name} du ${dateFormatted} - Karmastro`;
const description = entry?.intro
  ? `${entry.intro.slice(0, 150)}...`
  : `Horoscope ${sign.name} du ${dateFormatted} : amour, travail, énergie et intuition du jour. Lecture cosmique signée Sibylle.`;

const compatSigns = sign.compatibilities
  .map((slug) => ZODIAC_SIGNS.find((s) => s.slug === slug))
  .filter(Boolean) as typeof ZODIAC_SIGNS;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished: todayDate,
  dateModified: todayDate,
  author: {
    "@type": "Person",
    name: entry?.author || "Sibylle",
    description: "Oracle astrologue de Karmastro, héritière des Sibylles antiques",
  },
  publisher: {
    "@type": "Organization",
    name: "Karmastro",
    url: "https://karmastro.com",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `https://karmastro.com/horoscope/${sign.slug}`,
  },
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd} ogType="article" publishedTime={todayDate}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6">
      <a href="/" class="hover:text-amber-300">Accueil</a>
      <span class="mx-2">/</span>
      <a href="/horoscope" class="hover:text-amber-300">Horoscope</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">{sign.name}</span>
    </nav>

    <header class="text-center mb-10">
      <div class="flex justify-center mb-4">
        <ZodiacSymbol sign={sign.name} size={96} color="#D4A017" />
      </div>
      <h1 class="text-4xl md:text-5xl font-serif mb-2">Horoscope {sign.name}</h1>
      <p class="text-lg text-white/70 mb-1">{dateFormatted}</p>
      <p class="text-xs text-white/40">
        {sign.dates} · Élément {sign.element} · Maître {sign.rulingPlanet}
      </p>
    </header>

    {!entry && (
      <div class="text-center py-12 border border-amber-300/20 rounded-2xl bg-amber-300/5">
        <p class="text-amber-300/80">
          Les astres écrivent encore ta lecture du jour. Reviens dans quelques heures.
        </p>
      </div>
    )}

    {entry && (
      <>
        <div class="p-6 rounded-2xl border border-amber-300/20 bg-amber-300/5 mb-8">
          <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-2">Énergie cosmique du jour</p>
          <p class="text-lg leading-relaxed text-white/90">{entry.intro}</p>
        </div>

        <div class="grid md:grid-cols-2 gap-4 mb-8">
          {entry.love && (
            <section class="p-5 rounded-xl border border-white/10 bg-white/[0.02]">
              <h2 class="font-serif text-xl mb-3 text-pink-300">Amour</h2>
              <p class="text-white/80 leading-relaxed">{entry.love}</p>
            </section>
          )}
          {entry.work && (
            <section class="p-5 rounded-xl border border-white/10 bg-white/[0.02]">
              <h2 class="font-serif text-xl mb-3 text-amber-300">Travail</h2>
              <p class="text-white/80 leading-relaxed">{entry.work}</p>
            </section>
          )}
          {entry.energy && (
            <section class="p-5 rounded-xl border border-white/10 bg-white/[0.02]">
              <h2 class="font-serif text-xl mb-3 text-emerald-300">Énergie</h2>
              <p class="text-white/80 leading-relaxed">{entry.energy}</p>
            </section>
          )}
          {entry.intuition && (
            <section class="p-5 rounded-xl border border-white/10 bg-white/[0.02]">
              <h2 class="font-serif text-xl mb-3 text-purple-300">Intuition</h2>
              <p class="text-white/80 leading-relaxed">{entry.intuition}</p>
            </section>
          )}
        </div>

        <div class="grid grid-cols-3 gap-4 mb-10 text-center">
          {entry.luckyNumber != null && (
            <div class="p-4 rounded-xl border border-white/10 bg-white/[0.02]">
              <p class="text-xs text-white/50 uppercase tracking-wider mb-1">Chiffre chanceux</p>
              <p class="text-3xl font-serif text-amber-300">{entry.luckyNumber}</p>
            </div>
          )}
          {entry.color && (
            <div class="p-4 rounded-xl border border-white/10 bg-white/[0.02]">
              <p class="text-xs text-white/50 uppercase tracking-wider mb-1">Couleur</p>
              <p class="text-lg text-white/90">{entry.color}</p>
            </div>
          )}
          {entry.mantra && (
            <div class="p-4 rounded-xl border border-white/10 bg-white/[0.02]">
              <p class="text-xs text-white/50 uppercase tracking-wider mb-1">Mantra</p>
              <p class="text-sm italic text-white/90">"{entry.mantra}"</p>
            </div>
          )}
        </div>

        {entry.author && (
          <p class="text-center text-xs text-white/40 mb-4">
            Lecture signée par <a href="/notre-histoire" class="text-amber-300 hover:underline">{entry.author}</a>
          </p>
        )}

        <div class="flex justify-center mb-10">
          <ShareButton
            title={`Horoscope ${sign.name} du ${dateFormatted}`}
            text={`Mon horoscope ${sign.name} du jour sur Karmastro : ${entry.intro?.slice(0, 140) || "une lecture cosmique signée Sibylle"}`}
            url={`https://karmastro.com/horoscope/${sign.slug}`}
            variant="secondary"
            label="Partager cet horoscope"
          />
        </div>

        {/* Newsletter capture : "Recevoir mon horoscope" */}
        <NewsletterCapture sign={sign.slug} variant="card" source={`horoscope-${sign.slug}`} />

        {/* ═══ TOMORROW PREVIEW (Premium only) ═══ */}
        <section class="mb-10">
          <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
            <h2 class="font-serif text-2xl">Demain, {tomorrowFormatted}</h2>
            <span class="text-xs px-3 py-1 rounded-full bg-gradient-to-r from-amber-300/20 to-purple-400/20 border border-amber-300/40 text-amber-300">
              Avant-première Étoile
            </span>
          </div>

          <div id="tomorrow-container" class="relative">
            {/* Teaser visible pour tous */}
            <div class="p-6 rounded-2xl border border-white/10 bg-white/[0.02] relative overflow-hidden">
              {tomorrowEntry ? (
                <>
                  {/* Teaser : only the first sentence visible as hook */}
                  <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-2">Énergie cosmique de demain</p>
                  <p class="text-base leading-relaxed text-white/80 mb-4 italic">
                    {tomorrowEntry.intro?.split(/[.!?]/)[0]}...
                  </p>

                  {/* Heavily blurred content : only Étoile can read */}
                  <div
                    id="tomorrow-content"
                    class="relative transition-all duration-500"
                    data-locked="true"
                    style="filter: blur(18px); opacity: 0.35; user-select: none; pointer-events: none;"
                    aria-hidden="true"
                  >
                    <p class="text-lg leading-relaxed text-white/90 mb-4">{tomorrowEntry.intro}</p>
                    <div class="grid md:grid-cols-2 gap-3 text-sm">
                      {tomorrowEntry.love && (
                        <div>
                          <p class="font-serif text-base text-pink-300 mb-1">Amour</p>
                          <p class="text-white/80 text-sm">{tomorrowEntry.love}</p>
                        </div>
                      )}
                      {tomorrowEntry.work && (
                        <div>
                          <p class="font-serif text-base text-amber-300 mb-1">Travail</p>
                          <p class="text-white/80 text-sm">{tomorrowEntry.work}</p>
                        </div>
                      )}
                      {tomorrowEntry.energy && (
                        <div>
                          <p class="font-serif text-base text-emerald-300 mb-1">Énergie</p>
                          <p class="text-white/80 text-sm">{tomorrowEntry.energy}</p>
                        </div>
                      )}
                      {tomorrowEntry.intuition && (
                        <div>
                          <p class="font-serif text-base text-purple-300 mb-1">Intuition</p>
                          <p class="text-white/80 text-sm">{tomorrowEntry.intuition}</p>
                        </div>
                      )}
                    </div>
                  </div>

                  {/* Paywall CTA (below blurred content, not overlapping) */}
                  <div id="tomorrow-paywall" class="mt-6 p-5 rounded-xl bg-gradient-to-r from-purple-400/10 to-amber-300/10 border border-amber-300/30 text-center">
                    <div class="text-3xl mb-2">✦</div>
                    <p class="font-serif text-lg mb-1 text-white">Accès en avant-première</p>
                    <p class="text-xs text-white/60 mb-4 max-w-sm mx-auto">
                      L'horoscope de demain est offert aux voyageuses et voyageurs Étoile. Lis-le dès maintenant, sans attendre minuit.
                    </p>
                    <div class="flex gap-3 flex-wrap justify-center items-center">
                      <a
                        href="https://app.karmastro.com/pricing"
                        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity text-sm"
                      >
                        Passer en Étoile
                      </a>
                      <span class="text-xs text-white/50 flex items-center gap-1">
                        ou disponible dans <span id="countdown-timer" class="font-mono text-amber-300">--:--:--</span>
                      </span>
                    </div>
                  </div>
                </>
              ) : (
                <div class="text-center py-8">
                  <p class="text-amber-300/80 text-sm mb-2">Les astres écrivent encore ta lecture de demain</p>
                  <p class="text-white/50 text-xs">Reviens à partir de minuit pour la découvrir</p>
                </div>
              )}
            </div>
          </div>
        </section>

        {/* ═══ Premium unlock script ═══ */}
        <script is:inline>
          (function () {
            function updateCountdown() {
              const el = document.getElementById("countdown-timer");
              if (!el) return;
              const now = new Date();
              const tomorrow = new Date(now);
              tomorrow.setHours(24, 0, 0, 0);
              const diff = tomorrow - now;
              if (diff <= 0) { el.textContent = "00:00:00"; return; }
              const h = Math.floor(diff / 3600000);
              const m = Math.floor((diff % 3600000) / 60000);
              const s = Math.floor((diff % 60000) / 1000);
              el.textContent = String(h).padStart(2, "0") + ":" + String(m).padStart(2, "0") + ":" + String(s).padStart(2, "0");
            }
            updateCountdown();
            setInterval(updateCountdown, 1000);

            function checkPremium() {
              try {
                const tier = localStorage.getItem("km_user_tier");
                if (tier === "etoile" || tier === "cosmos") {
                  const content = document.getElementById("tomorrow-content");
                  const paywall = document.getElementById("tomorrow-paywall");
                  if (content) {
                    content.style.filter = "";
                    content.style.opacity = "";
                    content.style.pointerEvents = "";
                    content.style.userSelect = "";
                    content.removeAttribute("aria-hidden");
                    content.setAttribute("data-locked", "false");
                  }
                  if (paywall) paywall.style.display = "none";
                }
              } catch (e) {}
            }
            checkPremium();
            window.addEventListener("storage", checkPremium);
          })();
        </script>
      </>
    )}

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center mb-10">
      <h3 class="font-serif text-xl mb-2">Besoin d'une lecture plus personnelle ?</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed">
        L'horoscope est une lecture générale. Pour une guidance qui prend en compte ton thème natal complet, pose ta question à l'un de nos quatre guides.
      </p>
      <a
        href="https://app.karmastro.com/oracle"
        class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity"
      >
        Pose ta question à l'Oracle
      </a>
    </div>

    <section class="mb-10">
      <h2 class="font-serif text-2xl mb-4">Compatibilités du {sign.name}</h2>
      <div class="grid grid-cols-3 gap-3">
        {compatSigns.map((c) => (
          <a
            href={`/horoscope/${c.slug}`}
            class="p-4 rounded-xl border border-white/10 bg-white/[0.02] hover:border-amber-300/40 transition-colors text-center"
          >
            <div class="flex justify-center mb-2">
              <ZodiacSymbol sign={c.name} size={40} color="#D4A017" />
            </div>
            <p class="text-sm text-white/80">{c.name}</p>
          </a>
        ))}
      </div>
    </section>

    {archiveCards.length > 0 && (
      <section class="mb-10">
        <div class="flex items-baseline justify-between mb-4 flex-wrap gap-2">
          <h2 class="font-serif text-2xl">Archives récentes</h2>
          <span class="text-xs text-white/40">{archiveCards.length} lectures passées</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {archiveCards.map((a) => (
            <a
              href={`/horoscope/${sign.slug}/${a.date}`}
              class="group block p-4 rounded-xl border border-white/10 bg-white/[0.02] hover:border-amber-300/40 hover:bg-amber-300/[0.03] transition-all"
            >
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-medium text-amber-300/90 group-hover:text-amber-300">
                  {formatFrenchDate(a.date)}
                </span>
                {a.luckyNumber != null && (
                  <span class="text-[10px] px-2 py-0.5 rounded-full bg-amber-300/10 border border-amber-300/30 text-amber-300">
                    ✦ {a.luckyNumber}
                  </span>
                )}
              </div>
              {a.intro && (
                <p class="text-xs text-white/70 leading-relaxed line-clamp-2 mb-2">
                  {a.intro}...
                </p>
              )}
              <div class="flex items-center gap-2 flex-wrap text-[10px] text-white/40">
                {a.color && (
                  <span class="inline-flex items-center gap-1">
                    <span class="w-1.5 h-1.5 rounded-full bg-white/40" />
                    {a.color}
                  </span>
                )}
                {a.mantra && (
                  <span class="italic truncate max-w-[200px]">"{a.mantra}"</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10">
      {ZODIAC_SIGNS.map((s) => (
        <a
          href={`/horoscope/${s.slug}`}
          class={`text-sm px-3 py-1.5 rounded-full border transition-colors inline-flex items-center gap-1.5 ${
            s.slug === sign.slug
              ? "border-amber-300 bg-amber-300/10 text-amber-300"
              : "border-white/10 hover:border-amber-300/40 hover:text-amber-300"
          }`}
        >
          <ZodiacSymbol sign={s.name} size={16} color="currentColor" />
          {s.name}
        </a>
      ))}
    </nav>
  </article>
</BaseLayout>
