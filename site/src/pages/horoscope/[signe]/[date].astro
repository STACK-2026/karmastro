---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ZodiacSymbol from "../../../components/ZodiacSymbol.astro";
import { ZODIAC_SIGNS, SIGN_SLUGS, getSignBySlug, formatFrenchDate } from "../../../data/zodiac";
import fs from "fs";
import path from "path";

export function getStaticPaths() {
  const dataDir = path.join(process.cwd(), "src/data/horoscope");
  const paths: any[] = [];

  if (!fs.existsSync(dataDir)) return paths;

  const files = fs
    .readdirSync(dataDir)
    .filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f))
    .sort();

  if (files.length === 0) return paths;

  // Real today (server time). The "today" detail route is handled by /horoscope/[signe]/index.astro
  const realToday = new Date().toISOString().slice(0, 10);

  // Generate pages for every file except "today" : past (archives) + future (preview)
  const eligible = files.filter((f) => f.replace(".json", "") !== realToday);

  for (const file of eligible) {
    const date = file.replace(".json", "");
    const data = JSON.parse(fs.readFileSync(path.join(dataDir, file), "utf-8"));
    const isFuture = date > realToday;
    for (const slug of SIGN_SLUGS) {
      if (data[slug]) {
        paths.push({
          params: { signe: slug, date },
          props: { entry: data[slug], date, isFuture },
        });
      }
    }
  }

  return paths;
}

const { signe, date } = Astro.params;
const { entry, date: propDate, isFuture } = Astro.props as { entry: any; date: string; isFuture: boolean };
const sign = getSignBySlug(signe as string);
if (!sign) throw new Error(`Unknown sign: ${signe}`);

const dateFormatted = formatFrenchDate(propDate);
const title = `Horoscope ${sign.name} du ${dateFormatted} - Archives Karmastro`;
const description = entry?.intro
  ? `${entry.intro.slice(0, 150)}...`
  : `Archives horoscope ${sign.name} du ${dateFormatted}.`;

const compatSigns = sign.compatibilities
  .map((slug) => ZODIAC_SIGNS.find((s) => s.slug === slug))
  .filter(Boolean) as typeof ZODIAC_SIGNS;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description,
  datePublished: propDate,
  author: {
    "@type": "Person",
    name: entry?.author || "Sibylle",
  },
  publisher: {
    "@type": "Organization",
    name: "Karmastro",
    url: "https://karmastro.com",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `https://karmastro.com/horoscope/${sign.slug}/${propDate}`,
  },
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd} ogType="article" publishedTime={propDate}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6">
      <a href="/" class="hover:text-amber-300">Accueil</a>
      <span class="mx-2">/</span>
      <a href="/horoscope" class="hover:text-amber-300">Horoscope</a>
      <span class="mx-2">/</span>
      <a href={`/horoscope/${sign.slug}`} class="hover:text-amber-300">{sign.name}</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">{dateFormatted}</span>
    </nav>

    <div class={`mb-4 px-4 py-2 rounded-xl text-center ${isFuture ? "bg-gradient-to-r from-amber-300/10 to-purple-400/10 border border-amber-300/40" : "bg-amber-300/10 border border-amber-300/20"}`}>
      <p class="text-xs text-amber-300/90">
        {isFuture ? "✦ Avant-première Étoile" : "Archive"} du {dateFormatted} - <a href={`/horoscope/${sign.slug}`} class="underline hover:text-amber-300">voir l'horoscope du jour</a>
      </p>
    </div>

    <header class="text-center mb-10">
      <div class="flex justify-center mb-4">
        <ZodiacSymbol sign={sign.name} size={96} color="#D4A017" />
      </div>
      <h1 class="text-4xl md:text-5xl font-serif mb-2">Horoscope {sign.name}</h1>
      <p class="text-lg text-white/70 mb-1">{dateFormatted}</p>
      <p class="text-xs text-white/40">
        {sign.dates} · Élément {sign.element} · Maître {sign.rulingPlanet}
      </p>
    </header>

    <div id="future-wrap" class="relative" data-future={isFuture ? "1" : "0"}>
      <div class="p-6 rounded-2xl border border-amber-300/20 bg-amber-300/5 mb-8">
        <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-2">Énergie cosmique du jour</p>
        <p class="text-lg leading-relaxed text-white/90">{entry.intro}</p>
      </div>

    <div class="grid md:grid-cols-2 gap-4 mb-8">
      {entry.love && (
        <section class="p-5 rounded-xl border border-white/10 bg-white/[0.02]">
          <h2 class="font-serif text-xl mb-3 text-pink-300">Amour</h2>
          <p class="text-white/80 leading-relaxed">{entry.love}</p>
        </section>
      )}
      {entry.work && (
        <section class="p-5 rounded-xl border border-white/10 bg-white/[0.02]">
          <h2 class="font-serif text-xl mb-3 text-amber-300">Travail</h2>
          <p class="text-white/80 leading-relaxed">{entry.work}</p>
        </section>
      )}
      {entry.energy && (
        <section class="p-5 rounded-xl border border-white/10 bg-white/[0.02]">
          <h2 class="font-serif text-xl mb-3 text-emerald-300">Énergie</h2>
          <p class="text-white/80 leading-relaxed">{entry.energy}</p>
        </section>
      )}
      {entry.intuition && (
        <section class="p-5 rounded-xl border border-white/10 bg-white/[0.02]">
          <h2 class="font-serif text-xl mb-3 text-purple-300">Intuition</h2>
          <p class="text-white/80 leading-relaxed">{entry.intuition}</p>
        </section>
      )}
    </div>

    <div class="grid grid-cols-3 gap-4 mb-10 text-center">
      {entry.luckyNumber != null && (
        <div class="p-4 rounded-xl border border-white/10 bg-white/[0.02]">
          <p class="text-xs text-white/50 uppercase tracking-wider mb-1">Chiffre chanceux</p>
          <p class="text-3xl font-serif text-amber-300">{entry.luckyNumber}</p>
        </div>
      )}
      {entry.color && (
        <div class="p-4 rounded-xl border border-white/10 bg-white/[0.02]">
          <p class="text-xs text-white/50 uppercase tracking-wider mb-1">Couleur</p>
          <p class="text-lg text-white/90">{entry.color}</p>
        </div>
      )}
      {entry.mantra && (
        <div class="p-4 rounded-xl border border-white/10 bg-white/[0.02]">
          <p class="text-xs text-white/50 uppercase tracking-wider mb-1">Mantra</p>
          <p class="text-sm italic text-white/90">"{entry.mantra}"</p>
        </div>
      )}
    </div>
    </div>
    {/* /future-wrap */}

    {/* Paywall overlay for future dates */}
    {isFuture && (
      <>
        <div id="future-paywall" class="fixed inset-0 z-40 flex items-center justify-center p-6 pointer-events-none">
          <div class="max-w-md w-full p-6 rounded-2xl bg-gradient-to-b from-[#1a0f2e]/95 to-[#0f0a1e]/95 border border-amber-300/30 backdrop-blur-xl shadow-2xl text-center pointer-events-auto">
            <div class="text-4xl mb-3">✦</div>
            <p class="font-serif text-xl mb-2 text-white">Lecture du {dateFormatted}</p>
            <p class="text-sm text-white/60 mb-5">
              En avant-première pour les voyageuses et voyageurs Étoile. Accès immédiat sans attendre minuit.
            </p>
            <div class="flex gap-3 flex-wrap justify-center mb-4">
              <a
                href="https://app.karmastro.com/pricing"
                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity text-sm"
              >
                Passer en Étoile
              </a>
            </div>
            <p class="text-xs text-white/50">
              Disponible dans <span id="future-countdown" class="font-mono text-amber-300">--:--:--</span>
            </p>
            <a href={`/horoscope/${sign.slug}`} class="block mt-4 text-[10px] text-white/40 hover:text-white/60">← Retour à l'horoscope du jour</a>
          </div>
        </div>
        <script is:inline>
          (function () {
            function updateCountdown() {
              const el = document.getElementById("future-countdown");
              if (!el) return;
              const now = new Date();
              const target = new Date(now);
              target.setHours(24, 0, 0, 0);
              const diff = target - now;
              if (diff <= 0) { el.textContent = "00:00:00"; return; }
              const h = Math.floor(diff / 3600000);
              const m = Math.floor((diff % 3600000) / 60000);
              const s = Math.floor((diff % 60000) / 1000);
              el.textContent = String(h).padStart(2, "0") + ":" + String(m).padStart(2, "0") + ":" + String(s).padStart(2, "0");
            }
            updateCountdown();
            setInterval(updateCountdown, 1000);

            // Blur the future content + lock scroll
            const wrap = document.getElementById("future-wrap");
            if (wrap && wrap.getAttribute("data-future") === "1") {
              wrap.style.filter = "blur(6px)";
              wrap.style.opacity = "0.5";
              wrap.style.pointerEvents = "none";
            }

            // Unlock for Étoile users
            function checkPremium() {
              try {
                const tier = localStorage.getItem("km_user_tier");
                if (tier === "etoile" || tier === "cosmos") {
                  const w = document.getElementById("future-wrap");
                  const p = document.getElementById("future-paywall");
                  if (w) { w.style.filter = ""; w.style.opacity = ""; w.style.pointerEvents = ""; }
                  if (p) p.style.display = "none";
                }
              } catch (e) {}
            }
            checkPremium();
            window.addEventListener("storage", checkPremium);
          })();
        </script>
      </>
    )}

    {entry.author && !isFuture && (
      <p class="text-center text-xs text-white/40 mb-10">
        Lecture signée par <a href="/notre-histoire" class="text-amber-300 hover:underline">{entry.author}</a>
      </p>
    )}

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center mb-10">
      <h3 class="font-serif text-xl mb-2">Une guidance personnalisée ?</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed">
        Pour une lecture qui prend en compte ton thème natal complet, pose ta question à l'un de nos quatre guides cosmiques.
      </p>
      <a
        href="https://app.karmastro.com/oracle"
        class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity"
      >
        Consulter l'Oracle
      </a>
    </div>

    <section class="mb-10">
      <h2 class="font-serif text-2xl mb-4">Compatibilités du {sign.name}</h2>
      <div class="grid grid-cols-3 gap-3">
        {compatSigns.map((c) => (
          <a
            href={`/horoscope/${c.slug}`}
            class="p-4 rounded-xl border border-white/10 bg-white/[0.02] hover:border-amber-300/40 transition-colors text-center"
          >
            <div class="flex justify-center mb-2">
              <ZodiacSymbol sign={c.name} size={40} color="#D4A017" />
            </div>
            <p class="text-sm text-white/80">{c.name}</p>
          </a>
        ))}
      </div>
    </section>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10">
      {ZODIAC_SIGNS.map((s) => (
        <a
          href={`/horoscope/${s.slug}`}
          class={`text-sm px-3 py-1.5 rounded-full border transition-colors inline-flex items-center gap-1.5 ${
            s.slug === sign.slug
              ? "border-amber-300 bg-amber-300/10 text-amber-300"
              : "border-white/10 hover:border-amber-300/40 hover:text-amber-300"
          }`}
        >
          <ZodiacSymbol sign={s.name} size={16} color="currentColor" />
          {s.name}
        </a>
      ))}
    </nav>
  </article>
</BaseLayout>
