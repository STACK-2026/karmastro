---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareButton from "../../components/ShareButton.astro";
import ZodiacSymbol from "../../components/ZodiacSymbol.astro";
import { ZODIAC_SIGNS, formatFrenchDate } from "../../data/zodiac";
import fs from "fs";
import path from "path";

// Load today's horoscope file (Paris timezone, strictly <= today)
const dataDir = path.join(process.cwd(), "src/data/horoscope");
let todayData: Record<string, any> = {};
function parisDate(): string {
  return new Intl.DateTimeFormat("fr-CA", {
    timeZone: "Europe/Paris",
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
  }).format(new Date());
}
let todayDate = parisDate();
let hasData = false;

try {
  if (fs.existsSync(dataDir)) {
    const realToday = parisDate();
    const files = fs
      .readdirSync(dataDir)
      .filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f))
      .sort();
    // Only past-or-today files
    const pastFiles = files.filter((f) => f.replace(".json", "") <= realToday);
    const pickFile = pastFiles.length > 0 ? pastFiles[pastFiles.length - 1] : files[files.length - 1];
    if (pickFile) {
      todayDate = pickFile.replace(".json", "");
      todayData = JSON.parse(fs.readFileSync(path.join(dataDir, pickFile), "utf-8"));
      hasData = true;
    }
  }
} catch (e) {
  console.warn("Horoscope data not available yet:", e);
}

const dateFormatted = formatFrenchDate(todayDate);
const title = `Horoscope du jour ${dateFormatted} - 12 signes - Karmastro`;
const description = `Horoscope quotidien gratuit pour les 12 signes du zodiaque, calculé avec Swiss Ephemeris. Amour, travail, énergie et intuition pour le ${dateFormatted}.`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: `https://karmastro.com/horoscope`,
  datePublished: todayDate,
  isPartOf: {
    "@type": "WebSite",
    name: "Karmastro",
    url: "https://karmastro.com",
  },
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Horoscope du jour</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">
        {dateFormatted}
      </h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        Lecture cosmique pour les 12 signes, calculée avec Swiss Ephemeris et signée par Sibylle, notre oracle mystique.
      </p>

      {/* Discreet NASA-precision + geo widget */}
      <div class="mt-6 inline-flex items-center gap-3 px-4 py-2 rounded-full border border-amber-300/20 bg-amber-300/5 text-[11px] text-white/60">
        <span class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-amber-300 animate-pulse"></span>
          <span id="geo-precision">Précision NASA JPL</span>
        </span>
        <span class="text-white/20">·</span>
        <span id="geo-location" class="tabular-nums">—</span>
      </div>
    </div>

    {/* Geo detection script : silent, no user-facing detection message */}
    <script is:inline>
      (function () {
        const locEl = document.getElementById("geo-location");
        const precEl = document.getElementById("geo-precision");
        if (!locEl) return;

        // 1. Local time (instant, no permission needed)
        const updateTime = () => {
          const now = new Date();
          const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || "Europe/Paris";
          const timeStr = new Intl.DateTimeFormat("fr-FR", { timeZone: tz, hour: "2-digit", minute: "2-digit" }).format(now);
          const current = locEl.textContent || "";
          // Only update the time part, keep city if detected
          if (current.includes("·")) {
            const [city] = current.split(" · ");
            locEl.textContent = `${city} · ${timeStr}`;
          } else if (current === "—") {
            locEl.textContent = timeStr;
          }
        };
        updateTime();
        setInterval(updateTime, 30000);

        // 2. City from IP: ipapi gives raw commune (can be tiny village like "Craon"),
        // so we reverse-geocode via Nominatim to get the nearest significant admin unit.
        // Cache key v2 to invalidate the old commune-level cache.
        async function getCity() {
          try {
            const cached = localStorage.getItem("km_geo_city_v2");
            const cachedAt = parseInt(localStorage.getItem("km_geo_city_v2_at") || "0", 10);
            if (cached && Date.now() - cachedAt < 24 * 3600 * 1000) return cached;

            const ipResp = await fetch("https://ipapi.co/json/", { cache: "default" });
            if (!ipResp.ok) return null;
            const ipData = await ipResp.json();
            const lat = ipData.latitude;
            const lon = ipData.longitude;

            // Fallback chain: if no coords, use ipapi region or city
            let place: string | null = null;

            if (lat != null && lon != null) {
              try {
                const nomResp = await fetch(
                  `https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lon}&format=json&zoom=10&addressdetails=1&accept-language=fr`,
                  { headers: { Accept: "application/json" } }
                );
                if (nomResp.ok) {
                  const nomData = await nomResp.json();
                  const a = nomData.address || {};
                  // Prefer known major admin units in descending significance.
                  // address.city only populates for OSM places tagged place=city (prefectures, metropolises).
                  // For villages we fall back to county (French département) or state (région).
                  place = a.city || a.state_district || a.county || a.town || a.municipality || a.state || null;
                }
              } catch {}
            }

            // Last resort: ipapi region, then raw city
            if (!place) place = ipData.region || ipData.city || null;

            if (place) {
              localStorage.setItem("km_geo_city_v2", place);
              localStorage.setItem("km_geo_city_v2_at", String(Date.now()));
            }
            return place;
          } catch {
            return null;
          }
        }

        getCity().then((city) => {
          if (city) {
            const tz = Intl.DateTimeFormat().resolvedOptions().timeZone || "Europe/Paris";
            const timeStr = new Intl.DateTimeFormat("fr-FR", { timeZone: tz, hour: "2-digit", minute: "2-digit" }).format(new Date());
            locEl.textContent = `${city} · ${timeStr}`;
          }
        });
      })();
    </script>
    </div>

    {!hasData && (
      <div class="text-center py-12 border border-amber-300/20 rounded-2xl bg-amber-300/5">
        <p class="text-amber-300/80">
          Les astres écrivent encore les lignes du jour. Reviens dans quelques heures.
        </p>
      </div>
    )}

    {hasData && (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {ZODIAC_SIGNS.map((sign) => {
          const entry = todayData[sign.slug];
          return (
            <a
              href={`/horoscope/${sign.slug}`}
              class="group block p-5 rounded-2xl border border-white/10 bg-white/[0.02] hover:border-amber-300/40 hover:bg-amber-300/5 transition-all"
            >
              <div class="flex items-center justify-between mb-2">
                <ZodiacSymbol sign={sign.name} size={40} color="#D4A017" />
                <span class="text-xs text-white/40 uppercase tracking-wider">{sign.element}</span>
              </div>
              <h2 class="font-serif text-xl mb-1 group-hover:text-amber-300 transition-colors">
                {sign.name}
              </h2>
              <p class="text-xs text-white/50 mb-3">{sign.dates}</p>
              {entry?.intro && (
                <p class="text-sm text-white/70 line-clamp-2 leading-relaxed">
                  {entry.intro.slice(0, 90)}...
                </p>
              )}
              <p class="mt-3 text-xs text-amber-300/80 group-hover:text-amber-300">
                Lire l'horoscope →
              </p>
            </a>
          );
        })}
      </div>
    )}

    <div class="mt-10 flex justify-center">
      <ShareButton
        title={`Horoscope du jour ${dateFormatted} - Karmastro`}
        text="Découvre l'horoscope quotidien des 12 signes sur Karmastro, calculé avec Swiss Ephemeris"
        url="https://karmastro.com/horoscope"
        variant="secondary"
        label="Partager l'horoscope du jour"
      />
    </div>

    <div class="mt-16 text-center">
      <div class="inline-block p-8 rounded-3xl border border-purple-400/20 bg-purple-400/5 max-w-xl">
        <h3 class="font-serif text-2xl mb-3">Envie d'aller plus loin ?</h3>
        <p class="text-white/70 mb-5 leading-relaxed">
          L'horoscope du jour est une lecture générale. Pour une guidance personnalisée qui croise ton thème natal, ta numérologie et les transits, parle directement à l'un de nos quatre guides cosmiques.
        </p>
        <a
          href="https://app.karmastro.com/oracle"
          class="inline-block px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity"
        >
          Consulter l'Oracle
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
