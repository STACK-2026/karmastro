---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { GLOSSARY, GLOSSARY_CATEGORIES } from "../../data/glossary";

const title = "Glossaire de l'astrologie et de la numérologie - Karmastro";
const description =
  "Le dictionnaire cosmique de Karmastro : définitions claires, anecdotes et exemples pour comprendre l'astrologie, la numérologie et la guidance karmique. Apprends, puis calcule le tien.";

const byCat = GLOSSARY_CATEGORIES.map((cat) => ({
  cat,
  terms: GLOSSARY.filter((t) => t.category === cat),
})).filter((g) => g.terms.length > 0);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "DefinedTermSet",
    name: "Glossaire Karmastro",
    description,
    url: "https://karmastro.com/glossaire/",
    hasDefinedTerm: GLOSSARY.map((t) => ({
      "@type": "DefinedTerm", name: t.term, url: `https://karmastro.com/glossaire/${t.slug}/`,
    })),
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="text-center mb-12">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Apprendre</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Le glossaire cosmique</h1>
      <p class="text-lg text-white/70 max-w-xl mx-auto leading-relaxed">
        Astrologie, numérologie, karma : chaque terme expliqué simplement, avec une anecdote pour le retenir, et le moyen de le calculer pour toi. Comprends, puis vis-le.
      </p>
    </header>

    {byCat.map((g) => (
      <section class="mb-10">
        <h2 class="font-serif text-2xl text-amber-300 mb-4">{g.cat}</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {g.terms.map((t) => (
            <a href={`/glossaire/${t.slug}/`} class="block p-4 rounded-xl border border-white/10 bg-white/[0.02] hover:border-amber-300/40 transition-colors">
              <p class="font-serif text-white mb-1">{t.term}</p>
              <p class="text-sm text-white/60 leading-relaxed">{t.short}</p>
            </a>
          ))}
        </div>
      </section>
    ))}

    <div class="mt-12 p-6 rounded-2xl border border-amber-300/30 bg-gradient-to-r from-purple-400/10 to-amber-300/10 text-center">
      <p class="font-serif text-lg text-white mb-2">Une question qui n'attend pas une définition ?</p>
      <p class="text-sm text-white/60 mb-4">L'Oracle te répond en direct, gratuitement.</p>
      <a href="/oracle/" class="inline-block px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold text-sm hover:opacity-90 transition-opacity">Parler à l'Oracle ✦</a>
    </div>
  </article>
</BaseLayout>
