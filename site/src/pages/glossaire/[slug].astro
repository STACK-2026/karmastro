---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { GLOSSARY, getTerm } from "../../data/glossary";

export function getStaticPaths() {
  return GLOSSARY.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const term = getTerm(slug as string)!;
const related = (term.related || []).map((s) => getTerm(s)).filter(Boolean);

const title = `${term.term} : définition - Glossaire Karmastro`;
const description = term.definition.slice(0, 155);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "DefinedTerm",
    name: term.term,
    description: term.definition,
    inDefinedTermSet: { "@type": "DefinedTermSet", name: "Glossaire Karmastro", url: "https://karmastro.com/glossaire/" },
    url: `https://karmastro.com/glossaire/${term.slug}/`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Accueil", item: "https://karmastro.com/" },
      { "@type": "ListItem", position: 2, name: "Glossaire", item: "https://karmastro.com/glossaire/" },
      { "@type": "ListItem", position: 3, name: term.term, item: `https://karmastro.com/glossaire/${term.slug}/` },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-2xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6">
      <a href="/" class="hover:text-amber-300">Accueil</a>
      <span class="mx-2">/</span>
      <a href="/glossaire/" class="hover:text-amber-300">Glossaire</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">{term.term}</span>
    </nav>

    <header class="mb-8">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">{term.category}</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">{term.term}</h1>
    </header>

    <div data-speakable class="text-lg text-white/85 leading-relaxed mb-8">
      {term.definition}
    </div>

    <aside class="mb-8 p-5 rounded-2xl border border-amber-300/25 bg-gradient-to-br from-amber-300/[0.06] to-purple-400/[0.04]">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">✦ Le savais-tu ?</p>
      <p class="text-[15px] text-white/90 leading-relaxed">{term.funFact}</p>
    </aside>

    <div class="mb-10 p-5 rounded-2xl border border-amber-300/30 bg-[#0f0a1e]/40 text-center">
      <p class="font-serif text-base text-white mb-3">Passe de la théorie à toi</p>
      <div class="flex flex-wrap gap-2 justify-center">
        {term.toolUrl && (
          <a href={term.toolUrl} class="px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold text-sm hover:opacity-90 transition-opacity">{term.toolLabel || "Calcule le tien"}</a>
        )}
        {term.oracleQ && (
          <a href={`/oracle/?q=${encodeURIComponent(term.oracleQ)}`} class="km-oracle px-5 py-2.5 rounded-xl border border-amber-300/40 text-amber-300 font-medium text-sm hover:bg-amber-300/10 transition-colors">Demande à l'Oracle</a>
        )}
      </div>
    </div>

    {related.length > 0 && (
      <div class="mb-10">
        <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-3">À explorer aussi</p>
        <div class="flex flex-wrap gap-2">
          {related.map((r) => (
            <a href={`/glossaire/${r!.slug}/`} class="px-4 py-2 rounded-full border border-white/15 text-white/70 text-sm hover:border-amber-300/40 hover:text-amber-300 transition-colors">{r!.term}</a>
          ))}
        </div>
      </div>
    )}

    <p class="text-sm text-white/50">
      <a href="/glossaire/" class="text-amber-300 hover:underline">← Tout le glossaire cosmique</a>
    </p>
  </article>
</BaseLayout>
