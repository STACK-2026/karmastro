---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const title = "Ücretsiz Astroloji ve Numeroloji Hesaplayıcıları | Karmastro";
const description =
  "Ücretsiz astroloji ve numeroloji hesaplayıcıları: yaşam yolu sayısı, yükselen burç, zodyak uyumu, doğum haritası, kişisel yıl, karmik borç. Hassas, derinlemesine, Swiss Ephemeris üzerine inşa edilmiş.";

type Tool = { slug: string; title: string; desc: string; category: "Astroloji" | "Numeroloji"; icon: string };

const TOOLS: Tool[] = [
  { slug: "dogum-haritasi", title: "Doğum Haritası", desc: "10 gezegen, 12 ev ve büyük açılarla tam doğum haritası.", category: "Astroloji", icon: "☉" },
  { slug: "yukselen-burc", title: "Yükselen Burç Hesaplayıcı", desc: "Yükselen burcunu keşfet: taktığın maske, bıraktığın ilk izlenim.", category: "Astroloji", icon: "↗" },
  { slug: "uyumluluk", title: "Burç Uyumluluğu", desc: "İki burç arasında aşk, arkadaşlık, iş ve karmik uyum.", category: "Astroloji", icon: "♥" },
  { slug: "yasam-yolu-sayisi", title: "Yaşam Yolu Sayısı", desc: "Pisagor numerolojisindeki merkezi rakam. Misyonu ortaya koyar.", category: "Numeroloji", icon: "1" },
  { slug: "ifade-sayisi", title: "İfade Sayısı", desc: "Kader sayısı olarak da bilinir. Doğuştan gelen yetenekleri gösterir.", category: "Numeroloji", icon: "A" },
  { slug: "kisisel-yil", title: "Kişisel Yıl", desc: "Her yıl belirli bir numerolojik tema taşır. Sizinkini keşfedin.", category: "Numeroloji", icon: "★" },
];

const FALLBACK_TOOLS: { slug: string; title: string; desc: string; category: "Astroloji" | "Numeroloji"; icon: string }[] = [
  { slug: "sinastri", title: "Sinastri", desc: "İki kişi arasındaki gerçek kimyayı görmek için iki tam doğum haritasını karşılaştır.", category: "Astroloji", icon: "∞" },
  { slug: "transitler", title: "Günlük Transitler", desc: "Şu anda hareket halindeki gezegenler ve doğum haritanı nasıl etkiledikleri.", category: "Astroloji", icon: "◉" },
  { slug: "kisisel-yil", title: "Kişisel Yıl", desc: "Her yıl belirli bir numerolojik tema taşır. Kendi yılını keşfet ve enerjisiyle uyum sağla.", category: "Numeroloji", icon: "★" },
  { slug: "karmik-borc", title: "Karmik Borç", desc: "Önceki yaşamlardan miras kalan 13/4, 14/5, 16/7 veya 19/1 borçlarını taşıyıp taşımadığını keşfet.", category: "Numeroloji", icon: "∴" },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Ücretsiz Astroloji ve Numeroloji Hesaplayıcıları",
    description,
    url: "https://karmastro.com/tr/araclar",
    inLanguage: "tr",
    hasPart: TOOLS.map((t) => ({
      "@type": "WebApplication",
      name: t.title,
      url: `https://karmastro.com/tr/araclar/${t.slug}`,
      applicationCategory: "UtilitiesApplication",
      offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Ana Sayfa", item: "https://karmastro.com/tr" },
      { "@type": "ListItem", position: 2, name: "Araçlar", item: "https://karmastro.com/tr/araclar" },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-4xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/tr" class="hover:text-amber-300">Ana Sayfa</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">Araçlar</span>
    </nav>

    <header class="text-center mb-12">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Ücretsiz Araçlar</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Astroloji ve Numeroloji Hesaplayıcıları</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        Profesyonel bir astroloğun kullanacağı hassasiyetle inşa edilmiş araçlar. Dolgu yok, rastgele sayılar yok, duvar yok: sadece matematik ve net bir yorum.
      </p>
    </header>

    <section class="mb-12">
      <h2 class="font-serif text-2xl text-amber-300 mb-4 flex items-center gap-3">
        <span class="text-3xl">✦</span> Türkçe olarak mevcut
      </h2>
      <div class="grid md:grid-cols-2 gap-4">
        {TOOLS.map((t) => (
          <a href={`/tr/araclar/${t.slug}`} class="group p-5 rounded-2xl border border-amber-300/30 bg-amber-300/5 hover:border-amber-300/60 hover:bg-amber-300/10 transition-all">
            <div class="flex items-start gap-3 mb-2">
              <span class="text-3xl text-amber-300">{t.icon}</span>
              <h3 class="font-serif text-lg text-white group-hover:text-amber-300 transition-colors">{t.title}</h3>
            </div>
            <p class="text-sm text-white/60 leading-relaxed">{t.desc}</p>
            <p class="text-xs text-amber-300 mt-3 opacity-0 group-hover:opacity-100 transition-opacity">Aç →</p>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-12">
      <h2 class="font-serif text-2xl text-white/80 mb-4 flex items-center gap-3">
        <span class="text-3xl">◑</span> Kahin'de daha fazla araç
      </h2>
      <p class="text-sm text-white/60 mb-5 leading-relaxed">
        Bu araçlar Kahin uygulamasında Türkçe olarak mevcuttur. Bağımsız Türkçe versiyonlar yakında geliyor.
      </p>
      <div class="grid md:grid-cols-2 gap-4">
        {FALLBACK_TOOLS.map((t) => (
          <a href="https://app.karmastro.com/oracle?lang=tr" class="group p-5 rounded-2xl border border-white/10 bg-white/[0.02] hover:border-purple-300/40 hover:bg-purple-300/5 transition-all">
            <div class="flex items-start gap-3 mb-2">
              <span class="text-3xl text-purple-300">{t.icon}</span>
              <h3 class="font-serif text-lg text-white group-hover:text-purple-300 transition-colors">{t.title}</h3>
            </div>
            <p class="text-sm text-white/60 leading-relaxed">{t.desc}</p>
            <p class="text-xs text-purple-300 mt-3 opacity-0 group-hover:opacity-100 transition-opacity">Kahin'de aç →</p>
          </a>
        ))}
      </div>
    </section>

    <section class="prose prose-invert max-w-none mb-12">
      <h2 class="font-serif text-3xl mb-4">Neden bu hesaplayıcılar?</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        İnternet, belirsiz, genel veya düpedüz yanlış sonuçlar veren astroloji ve numeroloji hesaplayıcılarıyla dolu. Biz bizimkini tam tersini yapmak için inşa ettik. Her araç, profesyonel astrolog ve numerologların yüzyıllardır kullandığı <strong>kesin matematiği</strong> kullanır.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Tüm araçlar ücretsiz</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        Evet, gerçekten. Deneme sürümü yok, kredi kartı yok, «kilit açmak için kayıt ol» yok. Karmastro'yu insanlara binlerce yıldır yardım eden kozmik araçların özgürce erişilebilir olması gerektiği inancı üzerine kurduk.
      </p>
    </section>

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center">
      <h3 class="font-serif text-xl mb-2">Kişiselleştirilmiş bir okuma ister misin?</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed max-w-xl mx-auto">
        Bu hesaplayıcılar sana verileri verir. Astroloji ve numerolojini kişiselleştirilmiş rehberlikle kesiştiren eksiksiz bir okuma için Karmastro Kahini'ne danış.
      </p>
      <a href="https://app.karmastro.com/oracle?lang=tr" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity">
        Kahin'e ücretsiz danış
      </a>
    </div>
  </article>
</BaseLayout>
