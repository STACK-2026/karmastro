      </p>
      <a href="https://app.karmastro.com/oracle?lang=ru" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity">
        Обратиться к Оракулу бесплатно
      </a>
    </div>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/ru/instrumenty" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">← Все инструменты</a>
      <a href="/ru/instrumenty/voskhodyaschiy-znak" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Восходящий знак</a>
    </nav>
  </article>
</BaseLayout>

<script>
  import { calculateLifePath } from "../../../data/numerology-meanings";

  const MEANINGS_RU: Record<number, { title: string; summary: string; qualities: string[]; challenges: string[]; mission: string }> = {
    1: { title: "Первопроходец", summary: "Ты рождён, чтобы вести, а не следовать. Жизненный путь 1 несёт чистую энергию инициативы.", qualities: ["Природное лидерство", "Независимость", "Амбиции", "Смелость", "Оригинальность"], challenges: ["Эгоцентризм", "Нетерпеливость", "Одиночество", "Авторитаризм", "Жёсткость"], mission: "Научись вести без подавления, быть сильным без ожесточения." },
    2: { title: "Дипломат", summary: "Ты чувствуешь энергии, как другие слышат звуки. Жизненный путь 2 · это путь мира, гармонии и единения.", qualities: ["Дипломатия", "Чувствительность", "Эмпатия", "Терпение", "Сотрудничество"], challenges: ["Эмоциональная зависимость", "Нерешительность", "Гиперчувствительность", "Избегание конфликтов", "Покорность"], mission: "Пойми, что мягкость · это сила, а не слабость." },
    3: { title: "Артист", summary: "Ты превращаешь всё в цвет, слова или музыку. Жизненный путь 3 · это путь творческого самовыражения.", qualities: ["Креативность", "Общение", "Оптимизм", "Харизма", "Радость"], challenges: ["Рассеянность", "Поверхностность", "Сплетни", "Эмоциональная незрелость", "Эскапизм"], mission: "Научись, что глубина не убивает радость." },
    4: { title: "Строитель", summary: "Ты строишь то, о чём другие только мечтают. Жизненный путь 4 · это путь стабильности, структуры и долговечных результатов.", qualities: ["Дисциплина", "Надёжность", "Терпение", "Верность", "Практические навыки"], challenges: ["Жёсткость", "Трудоголизм", "Упрямство", "Страх перемен", "Чрезмерная серьёзность"], mission: "Научись, что структура служит свободе, а не наоборот." },
    5: { title: "Искательница Приключений", summary: "Ты нуждаешься в свободе, как другие в воздухе. Жизненный путь 5 · это путь перемен, опыта и личной свободы.", qualities: ["Любопытство", "Адаптивность", "Обаяние", "Универсальность", "Смелость к переменам"], challenges: ["Беспокойство", "Проблемы с обязательствами", "Импульсивность", "Зависимости", "Рассеянная энергия"], mission: "Научись, что свобода без направления · это просто дрейф." },
    6: { title: "Заботливый", summary: "Ты несёшь других, как Атлас нёс мир. Жизненный путь 6 · это путь ответственности, любви и служения.", qualities: ["Инстинкт заботы", "Ответственность", "Верность", "Способность учить", "Творческие дары"], challenges: ["Мученичество", "Чрезмерная вовлечённость", "Перфекционизм", "Самопожертвование", "Вмешательство"], mission: "Научись, что нельзя наливать из пустой чаши." },
    7: { title: "Искатель", summary: "Ты родился, задавая вопрос «почему». Жизненный путь 7 · это путь мудрости, интроспекции и духовного понимания.", qualities: ["Глубокое мышление", "Интуиция", "Независимость", "Аналитический ум", "Духовное осознание"], challenges: ["Изоляция", "Цинизм", "Чрезмерный анализ", "Недоверие", "Эмоциональная дистанция"], mission: "Научись, что истина без любви бесплодна." },
    8: { title: "Стратег", summary: "Ты понимаешь власть, не поддаваясь её соблазну. Жизненный путь 8 · это путь материального мастерства, изобилия и влияния.", qualities: ["Лидерство", "Финансовая интуиция", "Организаторские способности", "Выносливость", "Авторитет"], challenges: ["Жадность", "Трудоголизм", "Потребность контролировать", "Материализм", "Запугивание"], mission: "Научись, что истинная сила измеряется тем, что она создаёт." },
    9: { title: "Гуманист", summary: "Ты приходишь в жизнь, зная вещи, которые другие должны изучать. Жизненный путь 9 · это путь универсальной любви, сострадания и отпускания.", qualities: ["Сострадание", "Мудрость", "Художественная чувствительность", "Глобальная перспектива", "Щедрость"], challenges: ["Эмоциональная отстранённость", "Комплекс спасителя", "Меланхолия", "Трудности с отпусканием", "Самоправедность"], mission: "Научись, что сдаться · это сила, а не поражение." },
    11: { title: "Провидица (Мастер-число)", summary: "Ты родилась, подключённая к более высокой частоте. Мастер-число 11 несёт интенсивную интуицию.", qualities: ["Исключительная интуиция", "Провидческое мышление", "Харизма", "Духовный магнетизм", "Вдохновляющее присутствие"], challenges: ["Нервное напряжение", "Гиперчувствительность", "Самосомнение", "Тревога", "Мученичество"], mission: "Научись, что твоя чувствительность · это твой дар, а не твоя рана." },
    22: { title: "Мастер-Строитель (Мастер-число)", summary: "Ты можешь превратить невозможное в план. Мастер-число 22 сочетает духовную интуицию 11 с практической силой 4.", qualities: ["Провидческий прагматизм", "Лидерство", "Инновация", "Выносливость", "Мышление крупным масштабом"], challenges: ["Подавляющее давление", "Перфекционизм", "Выгорание", "Диктаторские тенденции", "Паралич сомнения"], mission: "Научись, что терпение · это не слабость." },
    33: { title: "Универсальный Целитель (Мастер-число)", summary: "Ты родился с редкой частотой бескорыстной любви. Мастер-число 33 · самый редкий жизненный путь.", qualities: ["Безусловная любовь", "Дар учения", "Творческое исцеление", "Духовная преданность", "Священное служение"], challenges: ["Мученичество", "Эмоциональное истощение", "Перфекционизм", "Забвение себя", "Подавляющая ответственность"], mission: "Научись, что давать из пустоты · это не давать." },
  };

  const form = document.getElementById("life-path-form") as HTMLFormElement;
  const resultDiv = document.getElementById("result") as HTMLDivElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = document.getElementById("birth-date") as HTMLInputElement;
    const value = input.value;
    if (!value) return;

    const [y, m, d] = value.split("-").map(Number);
    const result = calculateLifePath(d, m, y);
    const meaning = MEANINGS_RU[result.number] || MEANINGS_RU[9];

    (document.getElementById("result-number") as HTMLElement).textContent = String(result.number);
    (document.getElementById("result-title") as HTMLElement).textContent = meaning.title;
    (document.getElementById("result-calc") as HTMLElement).textContent = result.calculation;
    (document.getElementById("result-summary") as HTMLElement).textContent = meaning.summary;

    const qualitiesList = document.getElementById("result-qualities") as HTMLElement;
    qualitiesList.innerHTML = meaning.qualities.map((q) => `<li>✦ ${q}</li>`).join("");

    const challengesList = document.getElementById("result-challenges") as HTMLElement;
    challengesList.innerHTML = meaning.challenges.map((c) => `<li>◆ ${c}</li>`).join("");

    (document.getElementById("result-mission") as HTMLElement).textContent = meaning.mission;

    resultDiv.classList.remove("hidden");
    resultDiv.scrollIntoView({ behavior: "smooth", block: "start" });
  });
</script>
