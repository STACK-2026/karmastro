              <p class="text-xs uppercase tracking-widest text-emerald-300/80 mb-2">Сильные стороны</p>
              <ul id="result-qualities" class="text-sm text-white/70 space-y-1"></ul>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-pink-300/80 mb-2">Вызовы</p>
              <ul id="result-challenges" class="text-sm text-white/70 space-y-1"></ul>
            </div>
          </div>
          <div class="pt-4 border-t border-white/10">
            <p class="text-xs uppercase tracking-widest text-purple-300/80 mb-2">Миссия</p>
