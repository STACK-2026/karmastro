---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ToolEditorial from "../../../components/ToolEditorial.astro";
import { getToolEditorial } from "../../../data/tool-editorials";
const editorial_personal_year = getToolEditorial("personal-year", "ru");

const title = "Калькулятор личного года - Нумерология года | Karmastro";
const description =
  "Рассчитай твой личный год бесплатно. Каждый год несёт специфическую нумерологическую тему в цикле 1-9. Открой энергию текущего года.";

const jsonLd = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Главная",
      "item": "https://karmastro.com/ru/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Инструменты",
      "item": "https://karmastro.com/ru/instrumenty"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Личный год",
      "item": "https://karmastro.com/ru/instrumenty/lichnyi-god"
    }
  ]
},
  { "@context": "https://schema.org", "@type": "WebApplication", name: "Калькулятор личного года", description, url: "https://karmastro.com/ru/instrumenty/lichnyi-god", applicationCategory: "UtilitiesApplication", inLanguage: "ru", offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" }, aggregateRating: { "@type": "AggregateRating", ratingValue: "4.8", ratingCount: "152" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: [
    { "@type": "Question", name: "Что такое личный год?", acceptedAnswer: { "@type": "Answer", text: "Число 1-9, описывающее нумерологическую энергию текущего года. Часть девятилетнего цикла." } },
    { "@type": "Question", name: "Как рассчитать?", acceptedAnswer: { "@type": "Answer", text: "День + месяц рождения + текущий год. Редуцируй, кроме 11, 22, 33." } },
    { "@type": "Question", name: "Когда начинается?", acceptedAnswer: { "@type": "Answer", text: "Большинство нумерологов с 1 января. Другие с дня рождения." } },
    { "@type": "Question", name: "Что делать в каждом году?", acceptedAnswer: { "@type": "Answer", text: "1 сеять. 2 отношения. 3 выражать. 4 строить. 5 меняться. 6 отвечать. 7 углубляться. 8 собирать. 9 закрывать." } },
  ] },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/ru" class="hover:text-amber-300">Главная</a><span class="mx-2">/</span>
      <a href="/ru/instrumenty" class="hover:text-amber-300">Инструменты</a><span class="mx-2">/</span>
      <span class="text-white/80">Личный год</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Пифагорейская нумерология</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Калькулятор личного года</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">Каждый год несёт тему. Открой свою и настройся на её энергию.</p>
    </header>

    <aside data-speakable class="max-w-2xl mx-auto mb-10 p-5 md:p-6 rounded-2xl border border-amber-300/25 bg-gradient-to-br from-amber-300/[0.06] to-purple-400/[0.04]">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">Кратко</p>
      <p class="text-[15px] md:text-base text-white/90 leading-relaxed">
        <strong>Твоё число личного года</strong> это нумерологическая тема, окрашивающая 12 месяцев определённого календарного года для тебя. Оно вычисляется путём сложения твоего дня рождения, месяца рождения и текущего универсального года с последующим сведением к цифре от 1 до 9. Цикл в 9 лет повторяется всю жизнь: год 1 сажает, год 5 меняет курс, год 9 закрывает. Этот бесплатный калькулятор выдаёт твою текущую годовую тему за секунды из даты рождения.
      </p>
    </aside>

    <div class="p-8 md:p-10 rounded-3xl border border-amber-300/30 bg-gradient-to-br from-amber-300/10 to-purple-400/10 mb-10 text-center">
      <div class="text-5xl mb-4">★</div>
      <a href="https://app.karmastro.com/oracle?lang=ru" class="inline-block px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold hover:opacity-90 transition-opacity">Рассчитать мой личный год</a>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">Девятилетний цикл</h2>
      <p class="text-white/80 leading-relaxed mb-4">Пифагорейская нумерология видит жизнь в девятилетних циклах.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Как рассчитать</h2>
      <p class="text-white/80 leading-relaxed mb-4">День + месяц + <strong>текущий год</strong>. Пример для рождённого 12 марта в 2026: 1+2+3+2+0+2+6 = 16 → 7. Личный год 7.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Девять тем</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>Год 1 · Посев</strong>: новые начинания.</li>
        <li><strong>Год 2 · Отношения</strong>: терпение.</li>
        <li><strong>Год 3 · Выражение</strong>: творчество.</li>
        <li><strong>Год 4 · Построение</strong>: дисциплина.</li>
        <li><strong>Год 5 · Изменения</strong>: свобода.</li>
        <li><strong>Год 6 · Ответственность</strong>: семья.</li>
        <li><strong>Год 7 · Самоанализ</strong>: пауза.</li>
        <li><strong>Год 8 · Урожай</strong>: успех.</li>
        <li><strong>Год 9 · Закрытие</strong>: отпустить.</li>
      </ul>

      <h2 class="font-serif text-3xl mb-4 mt-10">Личный год в жизненном пути</h2>
      <p class="text-white/80 leading-relaxed mb-4">Объедини с <a href="/ru/instrumenty/chislo-zhiznennogo-puti" class="text-amber-300 hover:underline">жизненным путём</a>.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Переход между годами</h2>
      <p class="text-white/80 leading-relaxed mb-4">Вибрация нового года начинает ощущаться с октября.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Источники</h2>
      <ul class="text-white/80 space-y-1 mb-4 list-disc pl-5">
        <li><a href="https://ru.wikipedia.org/wiki/Нумерология" class="text-amber-300 hover:underline" rel="external">Нумерология - Википедия</a></li>
        <li><a href="https://www.britannica.com/topic/numerology" class="text-amber-300 hover:underline" rel="external">Numerology - Britannica</a></li>
        <li><a href="https://ru.wikipedia.org/wiki/Пифагор" class="text-amber-300 hover:underline" rel="external">Пифагор - Википедия</a></li>
      </ul>
    </section>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/ru/instrumenty" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Все инструменты</a>
      <a href="/ru/instrumenty/chislo-zhiznennogo-puti" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Жизненный путь</a>
      <a href="/ru/instrumenty/chislo-vyrazheniya" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Число выражения</a>
      <a href="/ru/instrumenty/natalnaya-karta" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Натальная карта</a>
      <a href="/ru/instrumenty/voskhodyaschiy-znak" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Асцендент</a>
      <a href="/ru/instrumenty/sovmestimost" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Совместимость</a>
      <a href="/ru/goroskop" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Гороскоп</a>
      <a href="/ru/blog" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Блог</a>
    </nav>
  
    {editorial_personal_year && (
      <ToolEditorial
        intro={editorial_personal_year.intro}
        sections={editorial_personal_year.sections}
        faq={editorial_personal_year.faq}
        sources={editorial_personal_year.sources}
        labels={editorial_personal_year.labels}
        dir="ltr"
      />
    )}
  </article>
</BaseLayout>
