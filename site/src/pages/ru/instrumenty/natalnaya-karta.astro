---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ToolEditorial from "../../../components/ToolEditorial.astro";
import { getToolEditorial } from "../../../data/tool-editorials";
const editorial_birth_chart = getToolEditorial("birth-chart", "ru");

const title = "Калькулятор натальной карты бесплатно | Karmastro";
const description =
  "Бесплатный калькулятор натальной карты на Swiss Ephemeris. Все 10 планет, 12 домов, асцендент и полная интерпретация на русском. Профессиональная точность.";

const jsonLd = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Главная",
      "item": "https://karmastro.com/ru/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Инструменты",
      "item": "https://karmastro.com/ru/instrumenty"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Натальная карта",
      "item": "https://karmastro.com/ru/instrumenty/natalnaya-karta"
    }
  ]
},
  { "@context": "https://schema.org", "@type": "WebApplication", name: "Калькулятор натальной карты", description, url: "https://karmastro.com/ru/instrumenty/natalnaya-karta", applicationCategory: "UtilitiesApplication", inLanguage: "ru", offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" }, aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", ratingCount: "287" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: [
    { "@type": "Question", name: "Что такое натальная карта?", acceptedAnswer: { "@type": "Answer", text: "Натальная карта, или карта рождения, это астрономический снимок неба в точный момент и место твоего рождения. Показывает положения Солнца, Луны и восьми планет, знаки зодиака, 12 домов и аспекты." } },
    { "@type": "Question", name: "Калькулятор действительно бесплатный?", acceptedAnswer: { "@type": "Answer", text: "Да. Полная натальная карта с 10 небесными телами, 12 домами, основными аспектами и письменной интерпретацией. Регистрация не обязательна." } },
    { "@type": "Question", name: "Какая точность?", acceptedAnswer: { "@type": "Answer", text: "Karmastro использует Swiss Ephemeris, астрономический стандарт. Точность до угловой секунды. Система домов Плацида по умолчанию." } },
    { "@type": "Question", name: "Нужно ли точное время рождения?", acceptedAnswer: { "@type": "Answer", text: "Для полной карты да. Асцендент и 12 домов зависят от точного времени." } },
    { "@type": "Question", name: "Что раскрывает натальная карта?", acceptedAnswer: { "@type": "Answer", text: "Ядро личности (Солнце), эмоциональный мир (Луна), социальную маску (Асцендент), стиль общения (Меркурий), стиль любви (Венера), драйв (Марс), паттерн роста (Юпитер), дисциплину (Сатурн) и поколенческие темы." } },
  ] },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/ru/" class="hover:text-amber-300">Главная</a><span class="mx-2">/</span>
      <a href="/ru/instrumenty/" class="hover:text-amber-300">Инструменты</a><span class="mx-2">/</span>
      <span class="text-white/80">Натальная карта</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Западная астрология</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Калькулятор натальной карты бесплатно</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">Твоя полная натальная карта, рассчитанная на Swiss Ephemeris. Каждая планета, каждый дом, каждый аспект, с ясной интерпретацией на русском.</p>
    </header>

    <aside data-speakable class="max-w-2xl mx-auto mb-10 p-5 md:p-6 rounded-2xl border border-amber-300/25 bg-gradient-to-br from-amber-300/[0.06] to-purple-400/[0.04]">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">Кратко</p>
      <p class="text-[15px] md:text-base text-white/90 leading-relaxed">
        <strong>Твоя натальная карта</strong>, также называемая картой рождения, это астрономическая карта неба в точный момент и месте твоего рождения. Она размещает 10 небесных тел (Солнце, Луна, Меркурий, Венера, Марс, Юпитер, Сатурн, Уран, Нептун, Плутон) по 12 знакам зодиака и 12 домам, плюс показывает главные аспекты между ними. Результат описывает твою глубинную психологию, а не судьбу. Этот бесплатный калькулятор выдаёт её за секунды из твоей точной даты, времени и города рождения.
      </p>
    </aside>

    <div class="p-8 md:p-10 rounded-3xl border border-amber-300/30 bg-gradient-to-br from-amber-300/10 to-purple-400/10 mb-10 text-center">
      <div class="text-5xl mb-4">✦</div>
      <h2 class="text-2xl md:text-3xl font-serif text-white mb-3">Получи полную карту</h2>
      <p class="text-white/70 mb-6 max-w-xl mx-auto leading-relaxed">Нужны точные дата, время и место рождения. Орион, наш проводник, даст персональную интерпретацию.</p>
      <a href="https://app.karmastro.com/oracle?lang=ru" class="inline-block px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold hover:opacity-90 transition-opacity">Моя натальная карта бесплатно</a>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">Что такое натальная карта?</h2>
      <p class="text-white/80 leading-relaxed mb-4">Натальная карта, или <strong>карта рождения</strong>, это точная астрономическая карта неба в момент и место твоего рождения. Этот снимок никогда не повторяется, твоя карта уникальна как отпечаток пальца.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Содержание карты</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>10 небесных тел</strong>: Солнце, Луна, Меркурий, Венера, Марс, Юпитер, Сатурн, Уран, Нептун, Плутон.</li>
        <li><strong>12 знаков зодиака</strong>: окрашивают выражение планет.</li>
        <li><strong>12 домов</strong>: описывают сферы жизни.</li>
        <li><strong>Аспекты</strong>: геометрические углы между планетами.</li>
      </ul>

      <h2 class="font-serif text-3xl mb-4 mt-10">Большая тройка</h2>
      <p class="text-white/80 leading-relaxed mb-4">Солнце (личность), Луна (эмоции) и <a href="/ru/instrumenty/voskhodyaschiy-znak/" class="text-amber-300 hover:underline">Асцендент</a> (маска) дают 80 процентов истории.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Как Karmastro рассчитывает</h2>
      <p class="text-white/80 leading-relaxed mb-4">Swiss Ephemeris, золотой стандарт точности. Система Плацида по умолчанию. Затем Орион даёт нарративную интерпретацию.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Почему точное время важно</h2>
      <p class="text-white/80 leading-relaxed mb-4">Асцендент меняется каждые два часа в среднем. 12 домов полностью зависят от точного времени.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Авторитетные источники</h2>
      <ul class="text-white/80 space-y-1 mb-4 list-disc pl-5">
        <li><a href="https://ru.wikipedia.org/wiki/Натальная_карта" class="text-amber-300 hover:underline" rel="external">Натальная карта - Википедия</a></li>
        <li><a href="https://www.britannica.com/topic/astrology" class="text-amber-300 hover:underline" rel="external">Astrology - Britannica</a></li>
        <li><a href="https://www.astro.com/swisseph/" class="text-amber-300 hover:underline" rel="external">Swiss Ephemeris</a></li>
      </ul>
    </section>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/ru/instrumenty/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Все инструменты</a>
      <a href="/ru/instrumenty/voskhodyaschiy-znak/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Асцендент</a>
      <a href="/ru/instrumenty/chislo-zhiznennogo-puti/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Жизненный путь</a>
      <a href="/ru/instrumenty/sovmestimost/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Совместимость</a>
      <a href="/ru/instrumenty/chislo-vyrazheniya/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Число выражения</a>
      <a href="/ru/instrumenty/lichnyi-god/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Личный год</a>
      <a href="/ru/goroskop/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Гороскоп</a>
      <a href="/ru/blog/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Блог</a>
    </nav>
  
    {editorial_birth_chart && (
      <ToolEditorial
        intro={editorial_birth_chart.intro}
        sections={editorial_birth_chart.sections}
        faq={editorial_birth_chart.faq}
        sources={editorial_birth_chart.sources}
        labels={editorial_birth_chart.labels}
        dir="ltr"
      />
    )}
  </article>
</BaseLayout>
