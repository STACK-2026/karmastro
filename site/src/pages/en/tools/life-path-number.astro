<script>
  import { calculateLifePath } from "../../../data/numerology-meanings";

  const MEANINGS_EN: Record<number, { title: string; summary: string; qualities: string[]; challenges: string[]; mission: string }> = {
    1: { title: "The Pioneer", summary: "You were born to lead, not to follow. Life Path 1 carries the raw energy of initiative. When you walk into a room, something shifts. Your mission is to turn that force into creation, not domination.", qualities: ["Natural leadership", "Independence", "Ambition", "Courage", "Originality"], challenges: ["Self-centeredness", "Impatience", "Loneliness", "Authoritarianism", "Rigidity"], mission: "Learn to lead without crushing, to be strong without becoming hard. The 1 is here to create new ground, to dare where others wait." },
    2: { title: "The Diplomat", summary: "You sense energies the way others hear sound. Life Path 2 is the path of peace, harmony, and union. Your mission is to use this sensitivity as a radar, not as a wound.", qualities: ["Diplomacy", "Sensitivity", "Empathy", "Patience", "Cooperation"], challenges: ["Emotional dependency", "Indecision", "Oversensitivity", "Conflict avoidance", "Submission"], mission: "Understand that softness is strength, not weakness. The 2 is here to reconcile, to see what others cannot see." },
    3: { title: "The Artist", summary: "You turn everything into color, words, or music. Life Path 3 is the path of creative expression. Your mission is to shape the intangible and share it generously.", qualities: ["Creativity", "Communication", "Optimism", "Charisma", "Joy"], challenges: ["Scatteredness", "Superficiality", "Gossiping", "Emotional immaturity", "Escapism"], mission: "Learn that depth does not kill joy. The 3 is here to express, to inspire, to remind others of the beauty of the world." },
    4: { title: "The Builder", summary: "You build what others only dream of. Life Path 4 is the path of stability, structure, and durable results. Your mission is to create something that outlives you.", qualities: ["Discipline", "Reliability", "Patience", "Loyalty", "Practical skill"], challenges: ["Rigidity", "Workaholism", "Stubbornness", "Fear of change", "Over-seriousness"], mission: "Learn that structure serves freedom, not the opposite. The 4 is here to build what lasts, with discipline and care." },
    5: { title: "The Adventurer", summary: "You need freedom like others need air. Life Path 5 is the path of change, experience, and personal freedom. Your mission is to turn movement into wisdom.", qualities: ["Curiosity", "Adaptability", "Charm", "Versatility", "Courage to change"], challenges: ["Restlessness", "Commitment issues", "Impulsiveness", "Addiction tendencies", "Scattered energy"], mission: "Learn that freedom without direction is just drift. The 5 is here to explore with purpose, to transform experiences into insight." },
    6: { title: "The Nurturer", summary: "You carry others the way Atlas carried the world. Life Path 6 is the path of responsibility, love, and service. Your mission is to give without losing yourself.", qualities: ["Nurturing instinct", "Responsibility", "Loyalty", "Teaching ability", "Creative gifts"], challenges: ["Martyrdom", "Over-involvement", "Perfectionism", "Self-sacrifice", "Meddling"], mission: "Learn that you cannot pour from an empty cup. The 6 is here to heal, to teach, to create beauty around the people it loves." },
    7: { title: "The Seeker", summary: "You were born asking why. Life Path 7 is the path of wisdom, introspection, and spiritual understanding. Your mission is to find truth and share what you learn.", qualities: ["Deep thinking", "Intuition", "Independence", "Analytical mind", "Spiritual awareness"], challenges: ["Isolation", "Cynicism", "Overthinking", "Distrust of others", "Emotional distance"], mission: "Learn that truth without love is sterile. The 7 is here to dig beneath the surface and bring back what it finds for others." },
    8: { title: "The Powerhouse", summary: "You understand power without being seduced by it. Life Path 8 is the path of material mastery, abundance, and influence. Your mission is to build something that serves more than yourself.", qualities: ["Leadership", "Financial intuition", "Organizational skills", "Endurance", "Authority"], challenges: ["Greed", "Workaholism", "Control issues", "Materialism", "Intimidation"], mission: "Learn that true power is measured by what it creates, not what it dominates. The 8 is here to master the material world with integrity." },
    9: { title: "The Humanitarian", summary: "You arrive at life knowing things others must learn. Life Path 9 is the path of universal love, compassion, and letting go. Your mission is to serve something bigger than yourself.", qualities: ["Compassion", "Wisdom", "Artistic sensitivity", "Global perspective", "Generosity"], challenges: ["Emotional detachment", "Savior complex", "Melancholy", "Difficulty letting go", "Self-righteousness"], mission: "Learn that surrender is strength, not defeat. The 9 is here to love without owning, to give without expecting return." },
    11: { title: "The Visionary (Master Number)", summary: "You were born with a wire plugged into a higher frequency. Master Number 11 carries intense intuition and a calling to awaken others. Your mission is to channel inspiration into form.", qualities: ["Exceptional intuition", "Visionary thinking", "Charisma", "Spiritual magnetism", "Inspirational presence"], challenges: ["Nervous tension", "Oversensitivity", "Self-doubt", "Anxiety", "Martyrdom"], mission: "Learn that your sensitivity is your gift, not your wound. The 11 is here to bring light to those who walk in darkness." },
    22: { title: "The Master Builder (Master Number)", summary: "You can turn the impossible into a blueprint. Master Number 22 combines the spiritual intuition of the 11 with the practical force of the 4. Your mission is to build something that changes the world.", qualities: ["Visionary pragmatism", "Leadership", "Innovation", "Endurance", "Large-scale thinking"], challenges: ["Overwhelming pressure", "Perfectionism", "Burnout", "Dictatorial tendencies", "Self-doubt paralysis"], mission: "Learn that patience is not weakness. The 22 is here to build monuments of the spirit, whether they are buildings, movements, or ideas." },
    33: { title: "The Universal Healer (Master Number)", summary: "You were born carrying a rare frequency of selfless love. Master Number 33 is the rarest life path. Your mission is to heal the world through wisdom and compassion.", qualities: ["Unconditional love", "Teaching gift", "Creative healing", "Spiritual devotion", "Sacred service"], challenges: ["Martyrdom", "Emotional exhaustion", "Perfectionism", "Self-forgetting", "Overwhelming responsibility"], mission: "Learn that giving from emptiness is not giving. The 33 is here to heal through presence, not sacrifice." },
  };

  const form = document.getElementById("life-path-form") as HTMLFormElement;
  const resultDiv = document.getElementById("result") as HTMLDivElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = document.getElementById("birth-date") as HTMLInputElement;
    const value = input.value;
    if (!value) return;

    const [y, m, d] = value.split("-").map(Number);
    const result = calculateLifePath(d, m, y);
    const meaning = MEANINGS_EN[result.number] || MEANINGS_EN[9];

    (document.getElementById("result-number") as HTMLElement).textContent = String(result.number);
    (document.getElementById("result-title") as HTMLElement).textContent = meaning.title;
    (document.getElementById("result-calc") as HTMLElement).textContent = result.calculation;
    (document.getElementById("result-summary") as HTMLElement).textContent = meaning.summary;

    const qualitiesList = document.getElementById("result-qualities") as HTMLElement;
    qualitiesList.innerHTML = meaning.qualities.map((q) => `<li>✦ ${q}</li>`).join("");

    const challengesList = document.getElementById("result-challenges") as HTMLElement;
    challengesList.innerHTML = meaning.challenges.map((c) => `<li>◆ ${c}</li>`).join("");

    (document.getElementById("result-mission") as HTMLElement).textContent = meaning.mission;

    resultDiv.classList.remove("hidden");
    resultDiv.scrollIntoView({ behavior: "smooth", block: "start" });
  });
</script>
