    famousExamples: "Barack Obama, Madonna, Mahatma Gandhi",
  },
  3: {
    title: "Die Künstlerin",
    archetype: "Der kreative Ausdruck, das Kind der Welt, diejenige, die erleuchtet.",
    summary: "Du verwandelst alles in Farbe, Worte oder Musik. Die Lebenszahl 3 ist der Weg des kreativen Ausdrucks. Deine Mission ist es, dem Ungreifbaren Form zu geben und es großzügig zu teilen.",
    qualities: ["Kreativität", "Kommunikation", "Optimismus", "Charisma", "Freude"],
    challenges: ["Zerstreuung", "Oberflächlichkeit", "Klatsch", "Emotionale Unreife", "Flucht"],
    mission: "Lerne, dass Tiefe die Freude nicht tötet. Die 3 ist hier, um auszudrücken, zu inspirieren, andere an die Schönheit der Welt zu erinnern.",
    famousExamples: "David Bowie, Hugh Jackman, Alec Baldwin",
  },
  4: {
    title: "Der Erbauer",
    archetype: "Der methodische Arbeiter, der Architekt, derjenige, der Fundamente legt.",
    summary: "Du baust, wovon andere nur träumen. Die Lebenszahl 4 ist der Weg der Stabilität, der Struktur und dauerhafter Ergebnisse. Deine Mission ist es, etwas zu erschaffen, das dich überdauert.",
    qualities: ["Disziplin", "Zuverlässigkeit", "Geduld", "Loyalität", "Praktische Fertigkeit"],
    challenges: ["Starrheit", "Workaholismus", "Sturheit", "Angst vor Veränderung", "Übertriebene Ernsthaftigkeit"],
    mission: "Lerne, dass Struktur der Freiheit dient, nicht umgekehrt. Die 4 ist hier, um Bleibendes zu bauen, mit Disziplin und Sorgfalt.",
    famousExamples: "Bill Gates, Oprah Winfrey, Arnold Schwarzenegger",
  },
  5: {
    title: "Die Abenteurerin",
    archetype: "Der freie Geist, die Reisende, die niemals anhält.",
    summary: "Du brauchst Freiheit, wie andere Luft brauchen. Die Lebenszahl 5 ist der Weg der Veränderung, der Erfahrung und der persönlichen Freiheit. Deine Mission ist es, Bewegung in Weisheit zu verwandeln.",
    qualities: ["Neugier", "Anpassungsfähigkeit", "Charme", "Vielseitigkeit", "Mut zur Veränderung"],
    challenges: ["Ruhelosigkeit", "Bindungsprobleme", "Impulsivität", "Suchttendenzen", "Zerstreute Energie"],
    mission: "Lerne, dass Freiheit ohne Richtung nur Treibenlassen ist. Die 5 ist hier, um mit Absicht zu erkunden, Erfahrung in Einsicht zu verwandeln.",
    famousExamples: "Abraham Lincoln, Angelina Jolie, Mick Jagger",
  },
  6: {
    title: "Der Fürsorger",
    archetype: "Der Beschützer, der Lehrer, derjenige, der andere zusammenhält.",
