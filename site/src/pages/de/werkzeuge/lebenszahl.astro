---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ToolEditorial from "../../../components/ToolEditorial.astro";
import { getToolEditorial } from "../../../data/tool-editorials";
const editorial_life_path = getToolEditorial("life-path", "de");

const title = "Lebenszahl berechnen - Pythagoreische Numerologie | Karmastro";
const description =
  "Berechne deine Lebenszahl kostenlos mit unserem pythagoreischen Numerologie-Rechner. Entdecke deine Mission, deine Gaben, deine Herausforderungen und die 12 Zahlen (inklusive der Meisterzahlen 11, 22, 33).";

const MEANINGS: Record<number, { title: string; archetype: string; summary: string; qualities: string[]; challenges: string[]; mission: string; famousExamples: string }> = {
  1: {
    title: "Der Pionier",
    archetype: "Der einsame Anführer, der Initiator, derjenige, der neue Wege eröffnet.",
    summary: "Du bist geboren, um zu führen, nicht um zu folgen. Die Lebenszahl 1 trägt die reine Energie der Initiative. Wenn du einen Raum betrittst, verändert sich etwas. Deine Mission ist es, diese Kraft in Schöpfung zu verwandeln, nicht in Dominanz.",
    qualities: ["Natürliche Führung", "Unabhängigkeit", "Ehrgeiz", "Mut", "Originalität"],
    challenges: ["Egozentrik", "Ungeduld", "Einsamkeit", "Autoritarismus", "Starrheit"],
    mission: "Lerne zu führen, ohne zu zerquetschen, stark zu sein, ohne hart zu werden. Die 1 ist hier, um neues Terrain zu erschaffen, um zu wagen, wo andere warten.",
    famousExamples: "Napoleon Bonaparte, Steve Jobs, Martin Luther King Jr.",
  },
  2: {
    title: "Die Diplomatin",
    archetype: "Die Mediatorin, die Intuitive, die Bindungen webt.",
    summary: "Du nimmst Energien wahr, wie andere Klänge hören. Die Lebenszahl 2 ist der Weg des Friedens, der Harmonie und der Vereinigung. Deine Mission ist es, diese Sensibilität als Radar zu nutzen, nicht als Wunde.",
