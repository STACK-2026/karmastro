---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const title = "Kostenloser Geburtshoroskop-Rechner - Natal Chart | Karmastro";
const description =
  "Kostenloser Geburtshoroskop-Rechner mit Swiss Ephemeris. Alle 10 Planeten, 12 Häuser, Aszendent und vollständige Interpretation auf Deutsch. Professionelle Präzision.";

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebApplication", name: "Geburtshoroskop-Rechner", description, url: "https://karmastro.com/de/werkzeuge/geburtshoroskop", applicationCategory: "UtilitiesApplication", inLanguage: "de", offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" }, aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", ratingCount: "378" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: [
    { "@type": "Question", name: "Was ist ein Geburtshoroskop?", acceptedAnswer: { "@type": "Answer", text: "Das Geburtshoroskop, auch Natal Chart oder Radix genannt, ist eine astronomische Momentaufnahme des Himmels zum Zeitpunkt und Ort deiner Geburt. Es zeigt die Position von Sonne, Mond und acht Planeten, ihre Sternzeichen, die 12 Häuser und die Aspekte zwischen ihnen." } },
    { "@type": "Question", name: "Ist der Rechner wirklich kostenlos?", acceptedAnswer: { "@type": "Answer", text: "Ja. Karmastro bietet ein vollständiges kostenloses Geburtshoroskop mit allen 10 Himmelskörpern, 12 Häusern, Hauptaspekten und einer geschriebenen Deutung. Keine Anmeldung nötig." } },
    { "@type": "Question", name: "Welche Präzision nutzt Karmastro?", acceptedAnswer: { "@type": "Answer", text: "Karmastro verwendet die Swiss Ephemeris, den astronomischen Standard professioneller Astrologen. Bogensekunden-genau. Häusersystem Placidus als Standard; Whole Sign und Equal House ebenfalls verfügbar." } },
    { "@type": "Question", name: "Brauche ich meine genaue Geburtszeit?", acceptedAnswer: { "@type": "Answer", text: "Für ein vollständiges Horoskop ja. Der Aszendent und die 12 Häuser hängen von der exakten Geburtszeit ab. Ohne sie lassen sich Sonnenzeichen, Mondzeichen (näherungsweise) und innere Planeten zuverlässig berechnen." } },
    { "@type": "Question", name: "Was verrät mein Geburtshoroskop?", acceptedAnswer: { "@type": "Answer", text: "Es offenbart deine Kernidentität (Sonne), dein Gefühlsleben (Mond), deine soziale Maske (Aszendent), deinen Kommunikationsstil (Merkur), deinen Liebesstil (Venus), deinen Antrieb (Mars), dein Wachstumsmuster (Jupiter), deine Disziplin (Saturn) und Generationsthemen (Uranus, Neptun, Pluto)." } },
  ] },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/de" class="hover:text-amber-300">Startseite</a><span class="mx-2">/</span>
      <a href="/de/werkzeuge" class="hover:text-amber-300">Werkzeuge</a><span class="mx-2">/</span>
      <span class="text-white/80">Geburtshoroskop</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Westliche Astrologie</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Kostenloser Geburtshoroskop-Rechner</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">Dein vollständiges Natal Chart, berechnet mit der Swiss Ephemeris. Jeder Planet, jedes Haus, jeder Aspekt, mit klarer Deutung auf Deutsch.</p>
    </header>

    <aside data-speakable class="max-w-2xl mx-auto mb-10 p-5 md:p-6 rounded-2xl border border-amber-300/25 bg-gradient-to-br from-amber-300/[0.06] to-purple-400/[0.04]">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">Kurz gesagt</p>
      <p class="text-[15px] md:text-base text-white/90 leading-relaxed">
        <strong>Dein Geburtshoroskop</strong>, auch Radix genannt, ist eine astronomische Karte des Himmels im genauen Moment und Ort deiner Geburt. Es verortet 10 Himmelskörper (Sonne, Mond, Merkur, Venus, Mars, Jupiter, Saturn, Uranus, Neptun, Pluto) in den 12 Tierkreiszeichen und 12 Häusern, dazu die wichtigsten Aspekte zwischen ihnen. Das Ergebnis beschreibt deine Kernpsychologie, nicht dein Schicksal. Dieser kostenlose Rechner liefert es in Sekunden aus deinem exakten Geburtsdatum, der Uhrzeit und dem Geburtsort.
      </p>
    </aside>

    <div class="p-8 md:p-10 rounded-3xl border border-amber-300/30 bg-gradient-to-br from-amber-300/10 to-purple-400/10 mb-10 text-center">
      <div class="text-5xl mb-4">✦</div>
      <h2 class="text-2xl md:text-3xl font-serif text-white mb-3">Hol dir dein vollständiges Geburtshoroskop</h2>
      <p class="text-white/70 mb-6 max-w-xl mx-auto leading-relaxed">Die vollständige Berechnung benötigt dein genaues Geburtsdatum, deine Uhrzeit und deinen Geburtsort. Orion, unsere Astrologie-Guide, liefert die personalisierte Deutung.</p>
      <a href="https://app.karmastro.com/oracle?lang=de" class="inline-block px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold hover:opacity-90 transition-opacity">Mein kostenloses Geburtshoroskop</a>
      <p class="text-xs text-white/50 mt-3">Keine Karte, keine Anmeldung nötig</p>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">Was ist ein Geburtshoroskop?</h2>
      <p class="text-white/80 leading-relaxed mb-4">Ein <strong>Geburtshoroskop</strong>, auch <strong>Natal Chart</strong> oder <strong>Radix</strong> genannt, ist eine präzise astronomische Karte des Himmels zum exakten Zeitpunkt und Ort deiner Geburt. Es erfasst die Positionen von Sonne, Mond und den acht Planeten relativ zum Tierkreis und zum Horizont deines Geburtsortes. Diese Momentaufnahme wiederholt sich nie in exakt derselben Form, weshalb dein Horoskop so einzigartig ist wie ein Fingerabdruck.</p>
      <p class="text-white/80 leading-relaxed mb-4">Die Astrologie behauptet, dass diese Aufnahme die grundlegenden psychologischen Dynamiken kodiert, mit denen du durchs Leben gehst. Es ist kein Schicksal, sondern eine Beschreibung der Karten, mit denen du ausgeteilt wurdest. Wie du sie spielst, liegt an dir.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Was dein Horoskop enthält</h2>
      <div class="not-prose grid md:grid-cols-2 gap-3 mb-6">
        <div class="p-4 rounded-xl border border-amber-300/20 bg-amber-300/5"><p class="font-serif text-lg text-amber-300 mb-1">Die 10 Himmelskörper</p><p class="text-sm text-white/70 leading-relaxed">Sonne, Mond, Merkur, Venus, Mars, Jupiter, Saturn, Uranus, Neptun, Pluto.</p></div>
        <div class="p-4 rounded-xl border border-purple-300/20 bg-purple-300/5"><p class="font-serif text-lg text-purple-300 mb-1">Die 12 Tierkreiszeichen</p><p class="text-sm text-white/70 leading-relaxed">Die Zeichen färben, wie sich jeder Planet ausdrückt. Mars im Widder wirkt anders als Mars in den Fischen.</p></div>
        <div class="p-4 rounded-xl border border-sky-300/20 bg-sky-300/5"><p class="font-serif text-lg text-sky-300 mb-1">Die 12 Häuser</p><p class="text-sm text-white/70 leading-relaxed">Häuser beschreiben Lebensbereiche: Identität, Geld, Beziehungen, Karriere.</p></div>
        <div class="p-4 rounded-xl border border-pink-300/20 bg-pink-300/5"><p class="font-serif text-lg text-pink-300 mb-1">Die Aspekte</p><p class="text-sm text-white/70 leading-relaxed">Geometrische Winkel zwischen Planeten, die beschreiben, wie ihre Energien kooperieren oder transformieren.</p></div>
      </div>

      <h2 class="font-serif text-3xl mb-4 mt-10">Die 10 Planeten und ihre Bedeutung</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>Sonne</strong>: Kernidentität, Ego, bewusster Wille.</li>
        <li><strong>Mond</strong>: Gefühlswelt, Instinkte, Bedürfnisse.</li>
        <li><strong>Merkur</strong>: Denken, Lernen, Kommunikation.</li>
        <li><strong>Venus</strong>: was du liebst, Ästhetik, Werte.</li>
        <li><strong>Mars</strong>: Antrieb, Begehren, Durchsetzung.</li>
        <li><strong>Jupiter</strong>: Wachstum, Sinn, Expansion.</li>
        <li><strong>Saturn</strong>: Disziplin, Karma, Struktur.</li>
        <li><strong>Uranus</strong>: Rebellion, Innovation, Bruch.</li>
        <li><strong>Neptun</strong>: Träume, Spiritualität, Vorstellungskraft.</li>
        <li><strong>Pluto</strong>: tiefe Transformation, Macht, Tod und Wiedergeburt.</li>
      </ul>

      <h2 class="font-serif text-3xl mb-4 mt-10">Die großen drei: Sonne, Mond, Aszendent</h2>
      <p class="text-white/80 leading-relaxed mb-4">Moderne Astrologen sagen, dass bereits drei Positionen 80 Prozent der Geschichte erzählen: dein <strong>Sonnenzeichen</strong> (Identität), dein <strong>Mondzeichen</strong> (Gefühlsselbst) und dein <strong>Aszendent</strong> (die Maske, die du trägst). Kennst du deinen Aszendenten noch nicht, starte mit unserem <a href="/de/werkzeuge/aszendent" class="text-amber-300 hover:underline">Aszendent-Rechner</a>.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Wie Karmastro dein Horoskop berechnet</h2>
      <p class="text-white/80 leading-relaxed mb-4">Wir nutzen die <strong>Swiss Ephemeris</strong>, den Goldstandard astronomischer Präzision, eingesetzt von professionellen Astrologen und wissenschaftlichen Observatorien. Häusersystem <strong>Placidus</strong> als Standard. Danach übergibt der Rechner die Deutung an <strong>Orion</strong>, unsere Astrologie-Guide, die eine erzählerische Lesung liefert, die auf dein Horoskop zugeschnitten ist.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Warum die genaue Geburtszeit zählt</h2>
      <p class="text-white/80 leading-relaxed mb-4">Der Mond bewegt sich etwa ein Grad pro zwei Stunden. Der <strong>Aszendent</strong> wechselt im Schnitt alle zwei Stunden. Die <strong>12 Häuser</strong> hängen vollständig von deiner genauen Geburtszeit ab. Prüfe zuerst deine Geburtsurkunde.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Autoritative Quellen</h2>
      <ul class="text-white/80 space-y-1 mb-4 list-disc pl-5">
        <li><a href="https://de.wikipedia.org/wiki/Horoskop" class="text-amber-300 hover:underline" rel="external">Horoskop - Wikipedia</a></li>
        <li><a href="https://www.britannica.com/topic/astrology" class="text-amber-300 hover:underline" rel="external">Astrology - Britannica</a></li>
        <li><a href="https://www.astro.com/swisseph/" class="text-amber-300 hover:underline" rel="external">Swiss Ephemeris - AstroDienst</a></li>
      </ul>
    </section>

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center mb-10">
      <h3 class="font-serif text-xl mb-2">Bereit für dein vollständiges Horoskop?</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed max-w-xl mx-auto">10 Planeten, 12 Häuser, Hauptaspekte, geschriebene Deutung. Kostenlos.</p>
      <a href="https://app.karmastro.com/oracle?lang=de" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity">Mein Geburtshoroskop berechnen</a>
    </div>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/de/werkzeuge" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Alle Werkzeuge</a>
      <a href="/de/werkzeuge/aszendent" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Aszendent</a>
      <a href="/de/werkzeuge/lebenszahl" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Lebenszahl</a>
      <a href="/de/werkzeuge/partnerhoroskop" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Partnerhoroskop</a>
      <a href="/de/werkzeuge/ausdruckszahl" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Ausdruckszahl</a>
      <a href="/de/werkzeuge/personliches-jahr" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Persönliches Jahr</a>
      <a href="/de/horoskop" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Horoskop</a>
      <a href="/de/blog" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Blog</a>
    </nav>
  </article>
</BaseLayout>
