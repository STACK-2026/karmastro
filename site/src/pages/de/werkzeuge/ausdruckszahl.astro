---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ToolEditorial from "../../../components/ToolEditorial.astro";
import ReadingPaywallCTA from "../../../components/ReadingPaywallCTA.astro";
import { getToolEditorial } from "../../../data/tool-editorials";
const editorial_expression_number = getToolEditorial("expression-number", "de");

const title = "Ausdruckszahl Rechner (Schicksalszahl) kostenlos | Karmastro";
const description =
  "Berechne deine Ausdruckszahl kostenlos, auch Schicksalszahl genannt. Sie offenbart deine angeborenen Talente, deine Mission und die natürliche Richtung deines Lebens.";

const jsonLd = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Startseite",
      "item": "https://karmastro.com/de/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Werkzeuge",
      "item": "https://karmastro.com/de/werkzeuge"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Ausdruckszahl",
      "item": "https://karmastro.com/de/werkzeuge/ausdruckszahl"
    }
  ]
},
  { "@context": "https://schema.org", "@type": "WebApplication", name: "Ausdruckszahl-Rechner", description, url: "https://karmastro.com/de/werkzeuge/ausdruckszahl", applicationCategory: "UtilitiesApplication", inLanguage: "de", offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" }, aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", ratingCount: "219" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: [
    { "@type": "Question", name: "Was ist die Ausdruckszahl?", acceptedAnswer: { "@type": "Answer", text: "Die Ausdruckszahl, auch Schicksalszahl genannt, wird aus dem vollständigen Geburtsnamen berechnet. Sie offenbart angeborene Talente, natürliche Fähigkeiten und die Lebensmission, die du von Haus aus mitbringst." } },
    { "@type": "Question", name: "Wie unterscheidet sie sich von der Lebenszahl?", acceptedAnswer: { "@type": "Answer", text: "Die Lebenszahl kommt aus dem Geburtsdatum und zeigt die Reise. Die Ausdruckszahl kommt aus dem vollständigen Namen und zeigt die Werkzeuge, mit denen du sie zurücklegst." } },
    { "@type": "Question", name: "Welchen Namen verwenden?", acceptedAnswer: { "@type": "Answer", text: "Immer den vollständigen Geburtsnamen aus der Geburtsurkunde, inklusive Zweitnamen. Keine Eheform, kein Spitzname. Die Ausdruckszahl kommt aus der ursprünglichen Schwingung der Geburt." } },
    { "@type": "Question", name: "Was sind die Meisterzahlen 11, 22, 33?", acceptedAnswer: { "@type": "Answer", text: "Meisterzahlen werden nicht reduziert. 11 visionäre Intuition, 22 Meisterbauer, 33 Meisterheiler. Anspruchsvolle Gaben, die Reife verlangen." } },
  ] },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/de/" class="hover:text-amber-300">Startseite</a><span class="mx-2">/</span>
      <a href="/de/werkzeuge/" class="hover:text-amber-300">Werkzeuge</a><span class="mx-2">/</span>
      <span class="text-white/80">Ausdruckszahl</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Pythagoreische Numerologie</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Ausdruckszahl-Rechner</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">Auch Schicksalszahl genannt. Offenbart die angeborenen Talente, die du seit der Geburt mitbringst, und die natürliche Richtung deines Lebens.</p>
    </header>

    <aside data-speakable class="max-w-2xl mx-auto mb-10 p-5 md:p-6 rounded-2xl border border-amber-300/25 bg-gradient-to-br from-amber-300/[0.06] to-purple-400/[0.04]">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">Kurz gesagt</p>
      <p class="text-[15px] md:text-base text-white/90 leading-relaxed">
        <strong>Deine Ausdruckszahl</strong>, auch Schicksalszahl genannt, ist die einstellige Schwingung, die dein voller Geburtsname trägt. Die pythagoräische Numerologie ordnet jedem Buchstaben einen Wert von 1 bis 9 zu, summiert sie und reduziert die Summe auf 1 bis 9 (oder die Meisterzahlen 11, 22, 33). Das Ergebnis zeigt deine natürlichen Talente und den Werkzeugkasten, mit dem du in dieses Leben gekommen bist. Dieser kostenlose Rechner liefert sie in Sekunden aus deinem vollen Geburtsnamen.
      </p>
    </aside>

    <div id="calculator" class="p-6 md:p-8 rounded-3xl border border-amber-300/20 bg-amber-300/5 mb-10">
      <form id="expr-form" class="space-y-4">
        <div>
          <label for="full-name" class="block text-sm font-medium text-white/80 mb-2">Dein vollständiger Geburtsname</label>
          <input type="text" id="full-name" required placeholder="z. B. Anna Maria Schmidt" class="w-full px-4 py-3 rounded-xl bg-[#0f0a1e]/50 border border-white/10 text-white placeholder-white/30 focus:border-amber-300 focus:outline-none transition-colors" />
          <p class="text-xs text-white/50 mt-1">Verwende den vollständigen Namen aus deiner Geburtsurkunde, inklusive Zweitnamen.</p>
        </div>
        <button type="submit" class="w-full px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold hover:opacity-90 transition-opacity">
          Meine Ausdruckszahl berechnen
        </button>
      </form>

      <div id="result" class="mt-6 hidden">
        <div class="p-6 rounded-2xl bg-[#0f0a1e]/60 border border-amber-300/30">
          <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">Deine Ausdruckszahl</p>
          <div class="flex items-baseline gap-4 mb-4">
            <span id="result-number" class="text-7xl font-serif text-amber-300"></span>
            <span id="result-title" class="text-xl font-serif text-white/90"></span>
          </div>
          <p class="text-xs text-white/50 mb-4">Buchstaben: <span id="result-letters" class="text-white/70"></span></p>
          <p class="text-xs text-white/50 mb-4">Berechnung: <span id="result-calc" class="text-white/70"></span></p>
          <p id="result-summary" class="text-white/80 leading-relaxed mb-6"></p>
          <div>
            <p class="text-xs uppercase tracking-widest text-emerald-300/80 mb-2">Deine natürlichen Talente</p>
            <ul id="result-talents" class="text-sm text-white/70 space-y-1 mb-4"></ul>
          </div>
          <div class="pt-4 border-t border-white/10">
            <p class="text-xs uppercase tracking-widest text-purple-300/80 mb-2">Dein Weg</p>
            <p id="result-path" class="text-sm text-white/80 italic leading-relaxed"></p>
          </div>
          <ReadingPaywallCTA tool="nombre-expression" locale="de" />
        </div>
      </div>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">Was ist die Ausdruckszahl?</h2>
      <p class="text-white/80 leading-relaxed mb-4">Eine der zentralen Zahlen der pythagoreischen Numerologie. Während die <a href="/de/werkzeuge/lebenszahl/" class="text-amber-300 hover:underline">Lebenszahl</a> die Reise beschreibt, beschreibt die Ausdruckszahl die <strong>Werkzeuge, mit denen du geboren wurdest</strong>: angeborene Talente, natürliche Berufung, Mission.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Berechnung</h2>
      <p class="text-white/80 leading-relaxed mb-4">Die pythagoreische Méthode ordnet jedem Buchstaben eine Zahl von 1 bis 9 zu: A=1, B=2, ..., I=9, J=1, etc. Alle Werte deines vollständigen Geburtsnamens werden addiert und auf eine Ziffer reduziert, außer bei Meisterzahlen 11, 22, 33.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Bedeutung der Zahlen</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>1 Pionier</strong>: Führung, Originalität.</li>
        <li><strong>2 Diplomat</strong>: Sensibilität, Kooperation.</li>
        <li><strong>3 Künstler</strong>: Ausdruck, Charisma.</li>
        <li><strong>4 Erbauer</strong>: Disziplin, Struktur.</li>
        <li><strong>5 Abenteurer</strong>: Freiheit, Wandel.</li>
        <li><strong>6 Hüter</strong>: Verantwortung, Dienst.</li>
        <li><strong>7 Sucher</strong>: Weisheit, Spiritualität.</li>
        <li><strong>8 Stratege</strong>: Macht, Fülle.</li>
        <li><strong>9 Humanist</strong>: Mitgefühl, Zyklenschluss.</li>
        <li><strong>11 Visionär</strong>: erhöhte Intuition.</li>
        <li><strong>22 Meisterbauer</strong>: große materielle Verwirklichung.</li>
        <li><strong>33 Meisterheiler</strong>: bedingungslose Liebe im Dienst.</li>
      </ul>

      <h2 class="font-serif text-3xl mb-4 mt-10">Ausdruck, Seele und Persönlichkeit</h2>
      <p class="text-white/80 leading-relaxed mb-4">Aus der Ausdruckszahl leiten sich zwei weitere ab: die <strong>Seelenzahl</strong> (nur Vokale: tiefstes Verlangen) und die <strong>Persönlichkeitszahl</strong> (nur Konsonanten: äußere Wahrnehmung). Die drei bilden deine numerologische Signatur.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Warum der Geburtsname</h2>
      <p class="text-white/80 leading-relaxed mb-4">Die pythagoreische Tradition hält den ersten Namen, den du erhalten hast, für die ursprüngliche Schwingung. Spätere Namensänderungen fügen Schichten hinzu, ersetzen aber nicht die native Zahl.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Autoritative Quellen</h2>
      <ul class="text-white/80 space-y-1 mb-4 list-disc pl-5">
        <li><a href="https://de.wikipedia.org/wiki/Numerologie" class="text-amber-300 hover:underline" rel="external">Numerologie - Wikipedia</a></li>
        <li><a href="https://www.britannica.com/topic/numerology" class="text-amber-300 hover:underline" rel="external">Numerology - Britannica</a></li>
        <li><a href="https://de.wikipedia.org/wiki/Pythagoras" class="text-amber-300 hover:underline" rel="external">Pythagoras - Wikipedia</a></li>
      </ul>
    </section>

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center mb-10">
      <h3 class="font-serif text-xl mb-2">Vollständige numerologische Lesung?</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed max-w-xl mx-auto">Lebenszahl, Ausdruck, Seele, Persönlichkeit, persönliches Jahr. Pythia kreuzt alles in einer einzigartigen Lesung.</p>
      <a href="https://karmastro.com/oracle/" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity">Pythia konsultieren</a>
    </div>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/de/werkzeuge/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Alle Werkzeuge</a>
      <a href="/de/werkzeuge/lebenszahl/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Lebenszahl</a>
      <a href="/de/werkzeuge/personliches-jahr/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Persönliches Jahr</a>
      <a href="/de/werkzeuge/geburtshoroskop/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Geburtshoroskop</a>
      <a href="/de/werkzeuge/aszendent/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Aszendent</a>
      <a href="/de/werkzeuge/partnerhoroskop/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Partnerhoroskop</a>
      <a href="/de/blog/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Horoskop</a>
      <a href="/de/blog/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Blog</a>
    </nav>
  
    {editorial_expression_number && (
      <ToolEditorial
        intro={editorial_expression_number.intro}
        sections={editorial_expression_number.sections}
        faq={editorial_expression_number.faq}
        sources={editorial_expression_number.sources}
        labels={editorial_expression_number.labels}
        dir="ltr"
      />
    )}
  </article>
</BaseLayout>

<script>
  import { calculateExpression } from "../../../data/numerology-meanings";

  const MEANINGS_DE: Record<number, { title: string; talents: string[]; path: string; summary: string }> = {
    1: { title: "Der Pionier", talents: ["Führung", "Innovation", "Unabhängigkeit", "Mut"], path: "Neue Wege bahnen, Vorhaben starten, herausstechen.", summary: "Dein Name schwingt mit Pioniergeist. Du bist hier, um zu führen, Neues zu begründen, der Erste zu sein. Dein Talent ist es, Vision in Handlung zu übersetzen, bevor andere die Gelegenheit überhaupt sehen." },
    2: { title: "Der Friedensstifter", talents: ["Diplomatie", "Intuition", "Zusammenarbeit", "Kunstfertigkeit"], path: "Brücken bauen, vermitteln, Harmonie schaffen.", summary: "Dein Name schwingt mit zwischenmenschlicher Intelligenz. Du liest Räume, wie andere Bücher lesen. Dein Talent ist es, Menschen und Ideen zu verweben, ohne dass jemand den Faden bemerkt." },
    3: { title: "Der Kommunikator", talents: ["Kreativer Ausdruck", "Schreiben", "Bühne", "Charisma"], path: "Ideen sichtbar machen, unterhalten, inspirieren.", summary: "Dein Name schwingt mit ausdrucksstarkem Genie. Worte, Bilder, Musik, Geschichten sind deine Werkzeuge. Dein Talent ist es, Menschen etwas fühlen zu lassen, von dem sie nicht wussten, dass sie es fühlen mussten." },
    4: { title: "Der Architekt", talents: ["Disziplin", "Handwerk", "Organisation", "Beständigkeit"], path: "Systeme und Strukturen bauen, die Bestand haben.", summary: "Dein Name schwingt mit solider, geduldiger, grundlegender Énergie. Du baust, wovon andere nur träumen. Dein Talent ist es, Chaos in einen Plan zu verwandeln und den Plan dann in etwas Reales." },
    5: { title: "Der Freiheitssucher", talents: ["Anpassungsfähigkeit", "Kommunikation", "Reisen", "Verkauf"], path: "Bewegung, Vielfalt, Welten verbinden.", summary: "Dein Name schwingt mit rastloser Neugier. In Bewegung blühst du auf. Dein Talent ist es, zwischen Kulturen, Systemen oder Ideen zu übersetzen, die sich normalerweise nie begegnen." },
    6: { title: "Der Fürsorgende", talents: ["Lehren", "Heilen", "Begleiten", "Schönheit schaffen"], path: "Nähren, beschützen, verschönern.", summary: "Dein Name schwingt mit Verantwortung und Liebe. Menschen bringen dir ihre Sorgen, weil etwas in dir Halt gibt. Dein Talent ist es, anderen ein Gefühl von Geborgenheit zu schenken." },
    7: { title: "Der Mystiker", talents: ["Tiefe Analyse", "Forschung", "Spiritualität", "Meisterschaft"], path: "Verborgene Wahrheiten aufdecken, Weisheit lehren.", summary: "Dein Name schwingt mit der Énergie des Suchenden. Du gehst immer tiefer als die Oberfläche. Dein Talent ist es, Muster zu erkennen, die sonst niemand bemerkt, und sie klar in Worte zu fassen." },
    8: { title: "Der Macher", talents: ["Geschäftssinn", "Führung", "Strategie", "Finanzielle Meisterschaft"], path: "Wohlstand und Einfluss aufbauen, im Großen organisieren.", summary: "Dein Name schwingt mit materieller Meisterschaft. Du verstehst Macht, ohne dich von ihr verderben zu lassen. Dein Talent ist es, Vision in Struktur und Struktur in Vermächtnis zu verwandeln." },
    9: { title: "Der Humanist", talents: ["Mitgefühl", "Lehren", "Kunst", "Globales Denken"], path: "Dem Ganzen dienen, durch das eigene Vorbild inspirieren.", summary: "Dein Name schwingt mit der Weisheit einer alten Seele. Du siehst über jede Grenze hinaus auf das Ganze. Dein Talent ist es, Anliegen zu dienen, die größer sind als du selbst, ohne deine Mitte zu verlieren." },
    11: { title: "Der Erleuchter (Meisterzahl)", talents: ["Spirituelle Einsicht", "Inspiration", "Vision", "Ausstrahlung"], path: "Andere durch Präsenz und Vorbild erwecken.", summary: "Dein Name schwingt mit der Meisterzahl 11, einer verdoppelten 2. Du bist ein Kanal für Inspiration. Dein Talent ist es, einen Raum zu betreten und die Énergie zu verändern, ohne ein Wort zu sagen." },
    22: { title: "Der Meisterbauer", talents: ["Visionäre Bodenständigkeit", "Großprojekte", "Führung", "Ausdauer"], path: "Große Visionen in bleibende Wirklichkeit verwandeln.", summary: "Dein Name schwingt mit der Meisterzahl 22, einer verdoppelten 4. Du bist hier, um im Großen zu bauen. Dein Talent ist es, unmögliche Träume zu nehmen und sie in funktionierende Systeme zu verwandeln." },
    33: { title: "Der Meisterheiler", talents: ["Bedingungslose Liebe", "Heilung", "Lehren", "Selbstloser Dienst"], path: "Die Welt durch mitfühlendes Lehren heilen.", summary: "Dein Name schwingt mit der Meisterzahl 33, der seltensten von allen. Du bist hier, um bedingungslos zu lieben und ohne Ego zu lehren. Dein Talent ist die Präsenz selbst." },
  };

  const form = document.getElementById("expr-form") as HTMLFormElement;
  const resultDiv = document.getElementById("result") as HTMLDivElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const name = (document.getElementById("full-name") as HTMLInputElement).value;
    if (!name.trim()) return;
    const result = calculateExpression(name);
    const meaning = MEANINGS_DE[result.number] || MEANINGS_DE[1];
    (document.getElementById("result-number") as HTMLElement).textContent = String(result.number);
    (document.getElementById("result-title") as HTMLElement).textContent = meaning.title;
    (document.getElementById("result-letters") as HTMLElement).textContent = result.letters;
    (document.getElementById("result-calc") as HTMLElement).textContent = result.calculation;
    (document.getElementById("result-summary") as HTMLElement).textContent = meaning.summary;
    (document.getElementById("result-talents") as HTMLElement).innerHTML = meaning.talents.map((t) => `<li>✦ ${t}</li>`).join("");
    (document.getElementById("result-path") as HTMLElement).textContent = meaning.path;
    resultDiv.classList.remove("hidden");
    resultDiv.scrollIntoView({ behavior: "smooth", block: "start" });
  });
</script>
