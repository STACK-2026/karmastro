---
import BlogLayout from "../../layouts/BlogLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  // Only generate pages for articles whose scheduled date has been reached
  const now = new Date();
  const posts = await getCollection("blog", ({ data }) => !data.draft && data.lang === "fr" && data.date.valueOf() <= now.valueOf());
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  author={post.data.author}
  category={post.data.category}
  tags={post.data.tags}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  slug={post.id}
  keywords={post.data.keywords}
  lastReviewed={post.data.lastReviewed}
  reviewedBy={post.data.reviewedBy}
>
  <Content />
</BlogLayout>
