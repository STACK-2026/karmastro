---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../../../site.config";
import { jsonLdBreadcrumbs } from "../../utils/seo";
import { fullUrl } from "../../utils/config";

// Only show published articles (scheduled date has passed)
const now = new Date();
const posts = (await getCollection("blog", ({ data }) => !data.draft && data.date.valueOf() <= now.valueOf()))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url },
  { name: "Le Cosmos", url: fullUrl("/blog") },
];
---

<BaseLayout
  title={`Le Cosmos - Blog ${siteConfig.name}`}
  description={`Le Cosmos, le blog de ${siteConfig.name}. Astrologie, numérologie, guidance karmique : explore l'univers des astres et des nombres.`}
  jsonLd={[
    { "@context": "https://schema.org", "@type": "CollectionPage", name: `Le Cosmos - Blog ${siteConfig.name}`, url: fullUrl("/blog") },
    jsonLdBreadcrumbs(breadcrumbs),
  ]}
>
  <div class="max-w-6xl mx-auto px-4 py-12">
    <h1 class="mb-2">Le Cosmos</h1>
    <p class="text-gray-400 mb-10 text-lg">Explore l'univers de l'astrologie, de la numérologie et du karma</p>

    {posts.length === 0 ? (
      <p class="text-gray-500 text-lg">Les premiers articles arrivent bientôt. Reviens vite !</p>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            slug={post.id}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
            category={post.data.category}
          />
        ))}
      </div>
    )}
  </div>
</BaseLayout>
