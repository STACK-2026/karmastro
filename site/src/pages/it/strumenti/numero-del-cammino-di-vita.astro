---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ToolEditorial from "../../../components/ToolEditorial.astro";
import { getToolEditorial } from "../../../data/tool-editorials";
const editorial_life_path = getToolEditorial("life-path", "it");

const title = "Calcolatore del Numero del Cammino di Vita - Numerologia Pitagorica | Karmastro";
const description =
  "Calcola il tuo numero del cammino di vita gratis con il nostro calcolatore di numerologia pitagorica. Scopri la tua missione, i tuoi doni, le tue sfide e i 12 numeri (inclusi i maestri 11, 22, 33).";

const MEANINGS: Record<number, { title: string; archetype: string; summary: string; qualities: string[]; challenges: string[]; mission: string; famousExamples: string }> = {
  1: {
    title: "Il Pioniere",
    archetype: "Il leader solitario, l'iniziatore, colui che apre nuovi sentieri.",
    summary: "Sei nato per guidare, non per seguire. Il Cammino di Vita 1 porta l'energia pura dell'iniziativa. Quando entri in una stanza, qualcosa cambia. La tua missione è trasformare quella forza in creazione, non in dominio.",
    qualities: ["Leadership naturale", "Indipendenza", "Ambizione", "Coraggio", "Originalità"],
    challenges: ["Egocentrismo", "Impazienza", "Solitudine", "Autoritarismo", "Rigidità"],
    mission: "Impara a guidare senza schiacciare, a essere forte senza indurirti. L'1 è qui per creare terreno nuovo, per osare dove gli altri aspettano.",
    famousExamples: "Napoleone Bonaparte, Steve Jobs, Martin Luther King Jr.",
  },
  2: {
    title: "La Diplomatica",
    archetype: "La mediatrice, l'intuitiva, colei che tesse i legami.",
    summary: "Percepisci le energie come altri odono i suoni. Il Cammino di Vita 2 è il cammino della pace, dell'armonia e dell'unione. La tua missione è usare questa sensibilità come un radar, non come una ferita.",
    qualities: ["Diplomazia", "Sensibilità", "Empatia", "Pazienza", "Cooperazione"],
    challenges: ["Dipendenza emotiva", "Indecisione", "Ipersensibilità", "Evitare i conflitti", "Sottomissione"],
    mission: "Comprendi che la dolcezza è forza, non debolezza. Il 2 è qui per riconciliare, per vedere ciò che altri non vedono.",
    famousExamples: "Barack Obama, Madonna, Mahatma Gandhi",
  },
  3: {
    title: "L'Artista",
    archetype: "L'espressione creativa, il bambino del mondo, colui che illumina.",
    summary: "Trasformi tutto in colore, parole o musica. Il Cammino di Vita 3 è il cammino dell'espressione creativa. La tua missione è dare forma all'intangibile e condividerlo generosamente.",
    qualities: ["Creatività", "Comunicazione", "Ottimismo", "Carisma", "Gioia"],
    challenges: ["Dispersione", "Superficialità", "Pettegolezzo", "Immaturità emotiva", "Fuga"],
    mission: "Impara che la profondità non uccide la gioia. Il 3 è qui per esprimere, per ispirare, per ricordare agli altri la bellezza del mondo.",
    famousExamples: "David Bowie, Hugh Jackman, Alec Baldwin",
  },
  4: {
    title: "Il Costruttore",
    archetype: "Il lavoratore metodico, l'architetto, colui che pone le fondamenta.",
    summary: "Costruisci ciò che gli altri solo sognano. Il Cammino di Vita 4 è il cammino della stabilità, della struttura e dei risultati duraturi. La tua missione è creare qualcosa che ti sopravviva.",
    qualities: ["Disciplina", "Affidabilità", "Pazienza", "Lealtà", "Abilità pratica"],
    challenges: ["Rigidità", "Dipendenza dal lavoro", "Testardaggine", "Paura del cambiamento", "Eccessiva serietà"],
    mission: "Impara che la struttura serve la libertà, non il contrario. Il 4 è qui per costruire ciò che dura, con disciplina e cura.",
    famousExamples: "Bill Gates, Oprah Winfrey, Arnold Schwarzenegger",
  },
  5: {
    title: "L'Avventuriera",
    archetype: "Lo spirito libero, la viaggiatrice, colei che non si ferma mai.",
    summary: "Hai bisogno di libertà come altri hanno bisogno d'aria. Il Cammino di Vita 5 è il cammino del cambiamento, dell'esperienza e della libertà personale. La tua missione è trasformare il movimento in saggezza.",
    qualities: ["Curiosità", "Adattabilità", "Fascino", "Versatilità", "Coraggio di cambiare"],
    challenges: ["Inquietudine", "Problemi di impegno", "Impulsività", "Tendenze additive", "Energia dispersa"],
    mission: "Impara che la libertà senza direzione è solo deriva. Il 5 è qui per esplorare con uno scopo, per trasformare l'esperienza in visione.",
    famousExamples: "Abraham Lincoln, Angelina Jolie, Mick Jagger",
  },
  6: {
    title: "Il Nutrice",
    archetype: "Il protettore, il maestro, colui che sostiene gli altri.",
    summary: "Porti gli altri come Atlante portava il mondo. Il Cammino di Vita 6 è il cammino della responsabilità, dell'amore e del servizio. La tua missione è dare senza perderti.",
    qualities: ["Istinto di cura", "Responsabilità", "Lealtà", "Capacità di insegnare", "Doni creativi"],
    challenges: ["Martirio", "Coinvolgimento eccessivo", "Perfezionismo", "Autosacrificio", "Intromissione"],
    mission: "Impara che non puoi servire da una coppa vuota. Il 6 è qui per guarire, per insegnare, per creare bellezza intorno a chi ama.",
    famousExamples: "Albert Einstein, Meryl Streep, John Lennon",
  },
  7: {
    title: "Il Cercatore",
    archetype: "Il filosofo mistico, il ricercatore, colui che mette tutto in discussione.",
    summary: "Sei nato chiedendo perché. Il Cammino di Vita 7 è il cammino della saggezza, dell'introspezione e della comprensione spirituale. La tua missione è trovare la verità e condividere ciò che impari.",
    qualities: ["Pensiero profondo", "Intuizione", "Indipendenza", "Mente analitica", "Consapevolezza spirituale"],
    challenges: ["Isolamento", "Cinismo", "Eccessiva analisi", "Sfiducia", "Distanza emotiva"],
    mission: "Impara che la verità senza amore è sterile. Il 7 è qui per scavare sotto la superficie e portare ciò che trova agli altri.",
    famousExamples: "Nikola Tesla, Principessa Diana, Johnny Depp",
  },
  8: {
    title: "La Stratega",
    archetype: "La costruttrice di imperi, la stratega, colei che trasforma la visione in ricchezza.",
    summary: "Comprendi il potere senza lasciarti sedurre da esso. Il Cammino di Vita 8 è il cammino del dominio materiale, dell'abbondanza e dell'influenza. La tua missione è costruire qualcosa che serva più di te stesso.",
    qualities: ["Leadership", "Intuizione finanziaria", "Capacità organizzativa", "Resistenza", "Autorità"],
    challenges: ["Avidità", "Dipendenza dal lavoro", "Bisogno di controllare", "Materialismo", "Intimidazione"],
    mission: "Impara che il vero potere si misura da ciò che crea, non da ciò che domina. L'8 è qui per dominare il mondo materiale con integrità.",
