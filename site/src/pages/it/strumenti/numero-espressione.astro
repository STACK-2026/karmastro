---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ToolEditorial from "../../../components/ToolEditorial.astro";
import ReadingPaywallCTA from "../../../components/ReadingPaywallCTA.astro";
import { getToolEditorial } from "../../../data/tool-editorials";
const editorial_expression_number = getToolEditorial("expression-number", "it");

const title = "Calcolatore del Numero di Espressione (Numero del Destino) | Karmastro";
const description =
  "Calcola gratis il tuo numero di espressione, detto anche numero del destino. Rivela i talenti innati, la missione e la direzione naturale della tua vita.";

const jsonLd = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://karmastro.com/it/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Strumenti",
      "item": "https://karmastro.com/it/strumenti"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Numero di espressione",
      "item": "https://karmastro.com/it/strumenti/numero-espressione"
    }
  ]
},
  { "@context": "https://schema.org", "@type": "WebApplication", name: "Calcolatore Numero di Espressione", description, url: "https://karmastro.com/it/strumenti/numero-espressione", applicationCategory: "UtilitiesApplication", inLanguage: "it", offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" }, aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", ratingCount: "187" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: [
    { "@type": "Question", name: "Cos'è il numero di espressione?", acceptedAnswer: { "@type": "Answer", text: "Detto anche numero del destino, si calcola dal nome completo di nascita. Rivela talenti innati, abilità naturali e la missione che porti con te dalla nascita." } },
    { "@type": "Question", name: "Che differenza c'è col cammino di vita?", acceptedAnswer: { "@type": "Answer", text: "Il cammino di vita viene dalla data di nascita e mostra il viaggio. Il numero di espressione viene dal nome e mostra gli strumenti per percorrerlo." } },
    { "@type": "Question", name: "Quale nome usare?", acceptedAnswer: { "@type": "Answer", text: "Il nome completo del certificato di nascita, inclusi secondi nomi. Non il cognome da sposata né soprannomi." } },
    { "@type": "Question", name: "Numeri maestri 11, 22, 33?", acceptedAnswer: { "@type": "Answer", text: "Non si riducono. 11 intuizione visionaria, 22 maestro costruttore, 33 maestro guaritore." } },
  ] },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/it/" class="hover:text-amber-300">Home</a><span class="mx-2">/</span>
      <a href="/it/strumenti/" class="hover:text-amber-300">Strumenti</a><span class="mx-2">/</span>
      <span class="text-white/80">Numero di espressione</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Numerologia Pitagorica</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Calcolatore del Numero di Espressione</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">Detto anche numero del destino. Rivela i talenti innati con cui nasci e la direzione naturale della tua vita.</p>
    </header>

    <aside data-speakable class="max-w-2xl mx-auto mb-10 p-5 md:p-6 rounded-2xl border border-amber-300/25 bg-gradient-to-br from-amber-300/[0.06] to-purple-400/[0.04]">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">In sintesi</p>
      <p class="text-[15px] md:text-base text-white/90 leading-relaxed">
        Il <strong>tuo numero di espressione</strong>, chiamato anche numero del destino, è la vibrazione a cifra singola portata dal tuo nome completo di nascita. La numerologia pitagorica assegna a ogni lettera un valore da 1 a 9, li somma e riduce il totale a una cifra da 1 a 9 (oppure ai numeri maestri 11, 22, 33). Il risultato rivela i tuoi talenti naturali e la cassetta degli attrezzi con cui sei arrivato in questa vita. Questo calcolatore gratuito te lo restituisce in pochi secondi dal tuo nome completo di nascita.
      </p>
    </aside>

    <div id="calculator" class="p-6 md:p-8 rounded-3xl border border-amber-300/20 bg-amber-300/5 mb-10">
      <form id="expr-form" class="space-y-4">
        <div>
          <label for="full-name" class="block text-sm font-medium text-white/80 mb-2">Il tuo nome completo di nascita</label>
          <input type="text" id="full-name" required placeholder="es. Maria Elena Rossi" class="w-full px-4 py-3 rounded-xl bg-[#0f0a1e]/50 border border-white/10 text-white placeholder-white/30 focus:border-amber-300 focus:outline-none transition-colors" />
          <p class="text-xs text-white/50 mt-1">Usa il nome completo del tuo certificato di nascita, inclusi i secondi nomi.</p>
        </div>
        <button type="submit" class="w-full px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold hover:opacity-90 transition-opacity">
          Calcola il mio numero di espressione
        </button>
      </form>

      <div id="result" class="mt-6 hidden">
        <div class="p-6 rounded-2xl bg-[#0f0a1e]/60 border border-amber-300/30">
          <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">Il tuo numero di espressione</p>
          <div class="flex items-baseline gap-4 mb-4">
            <span id="result-number" class="text-7xl font-serif text-amber-300"></span>
            <span id="result-title" class="text-xl font-serif text-white/90"></span>
          </div>
          <p class="text-xs text-white/50 mb-4">Lettere: <span id="result-letters" class="text-white/70"></span></p>
          <p class="text-xs text-white/50 mb-4">Calcolo: <span id="result-calc" class="text-white/70"></span></p>
          <p id="result-summary" class="text-white/80 leading-relaxed mb-6"></p>
          <div>
            <p class="text-xs uppercase tracking-widest text-emerald-300/80 mb-2">I tuoi talenti naturali</p>
            <ul id="result-talents" class="text-sm text-white/70 space-y-1 mb-4"></ul>
          </div>
          <div class="pt-4 border-t border-white/10">
            <p class="text-xs uppercase tracking-widest text-purple-300/80 mb-2">Il tuo cammino</p>
            <p id="result-path" class="text-sm text-white/80 italic leading-relaxed"></p>
          </div>
          <ReadingPaywallCTA tool="nombre-expression" locale="it" />
        </div>
      </div>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">Cos'è il numero di espressione?</h2>
      <p class="text-white/80 leading-relaxed mb-4">Una delle cifre fondamentali della numerologia pitagorica. Mentre il <a href="/it/strumenti/numero-del-cammino-di-vita/" class="text-amber-300 hover:underline">cammino di vita</a> descrive il viaggio, il numero di espressione descrive <strong>gli strumenti con cui nasci</strong>: talenti innati, vocazione naturale, missione.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Come si calcola</h2>
      <p class="text-white/80 leading-relaxed mb-4">Il metodo pitagorico assegna un numero da 1 a 9 a ogni lettera: A=1, B=2, ..., I=9, J=1, etc. Somma tutti i valori del nome completo di nascita e riduci a una cifra, salvo i maestri 11, 22, 33.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Significato dei numeri</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>1 Pioniere</strong>: leadership, originalità.</li>
        <li><strong>2 Diplomatico</strong>: sensibilità, cooperazione.</li>
        <li><strong>3 Artista</strong>: espressione, carisma.</li>
        <li><strong>4 Costruttore</strong>: disciplina, struttura.</li>
        <li><strong>5 Avventuriero</strong>: libertà, cambiamento.</li>
        <li><strong>6 Custode</strong>: responsabilità, servizio.</li>
        <li><strong>7 Ricercatore</strong>: saggezza, spiritualità.</li>
        <li><strong>8 Stratega</strong>: potere, abbondanza.</li>
        <li><strong>9 Umanitario</strong>: compassione, chiusura di cicli.</li>
        <li><strong>11 Visionario</strong>: intuizione elevata.</li>
        <li><strong>22 Maestro Costruttore</strong>: grandi realizzazioni.</li>
        <li><strong>33 Maestro Guaritore</strong>: amore incondizionato.</li>
      </ul>

      <h2 class="font-serif text-3xl mb-4 mt-10">Espressione, anima e personalità</h2>
      <p class="text-white/80 leading-relaxed mb-4">Dall'espressione derivano il <strong>numero dell'anima</strong> (solo vocali) e il <strong>numero della personalità</strong> (solo consonanti). I tre formano la tua firma numerologica.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Perché il nome di nascita</h2>
      <p class="text-white/80 leading-relaxed mb-4">La tradizione pitagorica ritiene che il primo nome ricevuto porti la vibrazione originale. Cambi successivi aggiungono strati ma non sostituiscono il numero nativo.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Fonti autorevoli</h2>
      <ul class="text-white/80 space-y-1 mb-4 list-disc pl-5">
        <li><a href="https://it.wikipedia.org/wiki/Numerologia" class="text-amber-300 hover:underline" rel="external">Numerologia - Wikipedia</a></li>
        <li><a href="https://www.britannica.com/topic/numerology" class="text-amber-300 hover:underline" rel="external">Numerology - Britannica</a></li>
        <li><a href="https://it.wikipedia.org/wiki/Pitagora" class="text-amber-300 hover:underline" rel="external">Pitagora - Wikipedia</a></li>
      </ul>
    </section>

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center mb-10">
      <h3 class="font-serif text-xl mb-2">Lettura numerologica completa?</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed max-w-xl mx-auto">Pythia incrocia tutto per te.</p>
      <a href="https://karmastro.com/oracle/" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity">Consultare Pythia</a>
    </div>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/it/strumenti/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Tutti gli strumenti</a>
      <a href="/it/strumenti/numero-del-cammino-di-vita/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Cammino di vita</a>
      <a href="/it/strumenti/anno-personale/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Anno personale</a>
      <a href="/it/strumenti/tema-natale/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Tema natale</a>
      <a href="/it/strumenti/ascendente/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Ascendente</a>
      <a href="/it/strumenti/compatibilita/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Compatibilità</a>
      <a href="/it/blog/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Oroscopo</a>
      <a href="/it/blog/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Blog</a>
    </nav>
  
    {editorial_expression_number && (
      <ToolEditorial
        intro={editorial_expression_number.intro}
        sections={editorial_expression_number.sections}
        faq={editorial_expression_number.faq}
        sources={editorial_expression_number.sources}
        labels={editorial_expression_number.labels}
        dir="ltr"
      />
    )}
  </article>
</BaseLayout>

<script>
  import { calculateExpression } from "../../../data/numerology-meanings";

  const MEANINGS_IT: Record<number, { title: string; talents: string[]; path: string; summary: string }> = {
    1: { title: "Il Pioniere", talents: ["Leadership", "Innovazione", "Indipendenza", "Coraggio"], path: "Aprire nuove strade, avviare progetti, distinguersi.", summary: "Il tuo nome vibra di energia pioniera. Sei qui per guidare, per dare origine, per essere il primo. Il tuo talento è trasformare la visione in azione prima ancora che gli altri intravedano l'opportunità." },
    2: { title: "Il Mediatore", talents: ["Diplomazia", "Intuizione", "Cooperazione", "Sensibilità artistica"], path: "Costruire ponti, mediare, creare armonia.", summary: "Il tuo nome vibra di intelligenza relazionale. Leggi gli ambienti come gli altri leggono i libri. Il tuo talento è intrecciare persone e idee senza che nessuno noti il filo." },
    3: { title: "Il Comunicatore", talents: ["Espressione creativa", "Scrittura", "Performance", "Carisma"], path: "Rendere visibili le idee, intrattenere, ispirare.", summary: "Il tuo nome vibra di genio espressivo. Parole, immagini, musica, storie: questi sono i tuoi strumenti. Il tuo talento è far provare alle persone qualcosa che non sapevano di aver bisogno di sentire." },
    4: { title: "L'Architetto", talents: ["Disciplina", "Artigianalità", "Organizzazione", "Solidità"], path: "Costruire sistemi e strutture che durano.", summary: "Il tuo nome vibra di energia solida, paziente, fondante. Costruisci ciò che gli altri si limitano a sognare. Il tuo talento è trasformare il caos in un progetto, e poi il progetto in qualcosa di reale." },
    5: { title: "L'Avventuriero", talents: ["Adattabilità", "Comunicazione", "Viaggio", "Vendita"], path: "Movimento, varietà, mettere in contatto mondi diversi.", summary: "Il tuo nome vibra di curiosità inquieta. Prosperi nel movimento. Il tuo talento è fare da ponte tra culture, sistemi o idee che normalmente non si incontrano mai." },
    6: { title: "Il Custode", talents: ["Insegnamento", "Cura", "Ascolto", "Creare bellezza"], path: "Nutrire, proteggere, abbellire.", summary: "Il tuo nome vibra di responsabilità e amore. Le persone ti portano i loro problemi perché qualcosa in te resta saldo. Il tuo talento è far sentire gli altri a casa." },
    7: { title: "Il Ricercatore", talents: ["Analisi profonda", "Ricerca", "Spiritualità", "Padronanza"], path: "Svelare verità nascoste, trasmettere saggezza.", summary: "Il tuo nome vibra dell'energia di chi cerca. Vai sempre oltre la superficie. Il tuo talento è trovare schemi che nessun altro nota e saperli esprimere con chiarezza." },
    8: { title: "Lo Stratega", talents: ["Acume negli affari", "Leadership", "Strategia", "Padronanza finanziaria"], path: "Costruire ricchezza e influenza, organizzare su larga scala.", summary: "Il tuo nome vibra di padronanza materiale. Comprendi il potere senza esserne corrotto. Il tuo talento è trasformare la visione in struttura e la struttura in eredità." },
    9: { title: "L'Umanitario", talents: ["Compassione", "Insegnamento", "Arte", "Pensiero globale"], path: "Servire la collettività, ispirare con l'esempio.", summary: "Il tuo nome vibra della saggezza di un'anima antica. Vedi oltre i confini di gruppo, fino all'insieme. Il tuo talento è servire cause più grandi di te senza perdere il tuo centro." },
    11: { title: "L'Illuminatore (Numero Maestro)", talents: ["Intuizione spirituale", "Ispirazione", "Visione", "Magnetismo"], path: "Risvegliare gli altri con la presenza e l'esempio.", summary: "Il tuo nome vibra del numero maestro 11, un 2 raddoppiato. Sei un canale di ispirazione. Il tuo talento è entrare in una stanza e cambiarne l'energia senza dire una parola." },
    22: { title: "Il Maestro Costruttore", talents: ["Pragmatismo visionario", "Progetti su larga scala", "Leadership", "Resistenza"], path: "Trasformare grandi visioni in realtà durature.", summary: "Il tuo nome vibra del numero maestro 22, un 4 raddoppiato. Sei qui per costruire su grande scala. Il tuo talento è prendere sogni impossibili e trasformarli in sistemi che funzionano." },
    33: { title: "Il Maestro Guaritore", talents: ["Amore incondizionato", "Guarigione", "Insegnamento", "Servizio disinteressato"], path: "Guarire il mondo attraverso un insegnamento compassionevole.", summary: "Il tuo nome vibra del numero maestro 33, il più raro di tutti. Sei qui per amare senza condizioni e insegnare senza ego. Il tuo talento è la presenza stessa." },
  };

  const form = document.getElementById("expr-form") as HTMLFormElement;
  const resultDiv = document.getElementById("result") as HTMLDivElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const name = (document.getElementById("full-name") as HTMLInputElement).value;
    if (!name.trim()) return;
    const result = calculateExpression(name);
    const meaning = MEANINGS_IT[result.number] || MEANINGS_IT[1];
    (document.getElementById("result-number") as HTMLElement).textContent = String(result.number);
    (document.getElementById("result-title") as HTMLElement).textContent = meaning.title;
    (document.getElementById("result-letters") as HTMLElement).textContent = result.letters;
    (document.getElementById("result-calc") as HTMLElement).textContent = result.calculation;
    (document.getElementById("result-summary") as HTMLElement).textContent = meaning.summary;
    (document.getElementById("result-talents") as HTMLElement).innerHTML = meaning.talents.map((t) => `<li>✦ ${t}</li>`).join("");
    (document.getElementById("result-path") as HTMLElement).textContent = meaning.path;
    resultDiv.classList.remove("hidden");
    resultDiv.scrollIntoView({ behavior: "smooth", block: "start" });
  });
</script>
