  function getCompat(a: number, b: number) {
    // Reduce master numbers for matrix lookup (but keep showing the real number)
    const reduceA = a === 11 || a === 22 || a === 33 ? (a === 11 ? 2 : a === 22 ? 4 : 6) : a;
    const reduceB = b === 11 || b === 22 || b === 33 ? (b === 11 ? 2 : b === 22 ? 4 : 6) : b;
    const [x, y] = [reduceA, reduceB].sort((a, b) => a - b);
    return COMPAT_MATRIX[`${x}-${y}`] || { score: 70, dynamic: "Dynamique à explorer avec l'Oracle pour une interprétation personnalisée.", lesson: "Chaque relation est unique au-delà des nombres." };
  }

  function scoreLabel(score: number): string {
    if (score >= 85) return "Harmonie naturelle exceptionnelle";
    if (score >= 75) return "Compatibilité forte et fluide";
    if (score >= 65) return "Bonne entente avec ajustements";
    if (score >= 55) return "Relation transformatrice mais exigeante";
    return "Alchimie rare, croissance garantie";
  }

  const form = document.getElementById("compat-form") as HTMLFormElement;
  const resultDiv = document.getElementById("result") as HTMLDivElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const dateA = (document.getElementById("date-a") as HTMLInputElement).value;
    const dateB = (document.getElementById("date-b") as HTMLInputElement).value;
    if (!dateA || !dateB) return;

    const [ya, ma, da] = dateA.split("-").map(Number);
    const [yb, mb, db] = dateB.split("-").map(Number);

    const lifeA = calculateLifePath(da, ma, ya);
    const lifeB = calculateLifePath(db, mb, yb);
    const compat = getCompat(lifeA.number, lifeB.number);

    animateNumberTo(document.getElementById("life-a"), lifeA.number, { duration: 900 });
    animateNumberTo(document.getElementById("life-b"), lifeB.number, { duration: 900 });
    animateNumberTo(document.getElementById("score-value"), compat.score, { duration: 1600 });
    (document.getElementById("score-label") as HTMLElement).textContent = scoreLabel(compat.score);
    (document.getElementById("dynamic-text") as HTMLElement).textContent = compat.dynamic;
    (document.getElementById("lesson-text") as HTMLElement).textContent = compat.lesson;

    // Wire PDF export
    const pdfBtn = document.getElementById("download-pdf-btn") as HTMLButtonElement | null;
    if (pdfBtn) {
      pdfBtn.onclick = async () => {
        try {
          const { exportCompatibilitePDF } = await import("../../utils/pdf");
          await exportCompatibilitePDF(lifeA, lifeB, compat);
        } catch (e) {
          console.error("PDF export failed:", e);
        }
      };
    }

    // Wire share
    const shareBtn = document.getElementById("share-result-btn") as HTMLButtonElement | null;
    if (shareBtn) {
      const shareText = `Chemin de vie ${lifeA.number} et ${lifeB.number} : score de compatibilité ${compat.score}/100. Calcule la tienne sur Karmastro.`;
      const shareUrl = "https://karmastro.com/outils/compatibilite";
      shareBtn.onclick = async () => {
        if (typeof navigator.share === "function") {
          try { await navigator.share({ title: "Compatibilité numérologique", text: shareText, url: shareUrl }); return; } catch {}
        }
        try {
          await navigator.clipboard.writeText(`${shareText} ${shareUrl}`);
          const original = shareBtn.innerHTML;
          shareBtn.textContent = "Copié ✦";
          setTimeout(() => { shareBtn.innerHTML = original; }, 2000);
        } catch {}
      };
    }

    revealResult(resultDiv);
  });
</script>
