---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Calculateur de compatibilité amoureuse gratuit - Numérologie - Karmastro";
const description =
  "Calcule la compatibilité amoureuse entre deux chemins de vie en numérologie pythagoricienne. Score de compatibilité, dynamique karmique, forces et défis du couple. Gratuit et instantané.";

const jsonLd = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Accueil",
      "item": "https://karmastro.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Outils",
      "item": "https://karmastro.com/outils"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Compatibilité",
      "item": "https://karmastro.com/outils/compatibilite"
    }
  ]
},
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Calculateur de compatibilité Karmastro",
    description,
    url: "https://karmastro.com/outils/compatibilite",
    applicationCategory: "UtilitiesApplication",
    operatingSystem: "Any",
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "EUR",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "Comment calcule-t-on la compatibilité numérologique ?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "La compatibilité numérologique se calcule en croisant les chemins de vie des deux personnes. Certaines combinaisons sont naturellement harmoniques (comme 1 et 5), d'autres créent de la tension productive (1 et 4), d'autres demandent beaucoup d'adaptation (1 et 8). Le score de compatibilité exprime la fluidité relationnelle, pas l'amour lui-même.",
        },
      },
      {
        "@type": "Question",
        name: "Un score bas signifie-t-il qu'on doit rompre ?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Absolument pas. Les scores bas indiquent simplement que la relation demandera plus d'efforts conscients pour fonctionner. Certains des couples les plus transformateurs au monde ont des scores numérologiques tendus : c'est la friction qui les a fait grandir. Le score est une carte, pas un verdict.",
        },
      },
      {
        "@type": "Question",
        name: "La compatibilité numérologique est-elle valable pour l'amitié ?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Oui, le calcul fonctionne pour toutes les relations : amoureuses, amicales, professionnelles, familiales. Seule l'interprétation varie. Une relation de travail avec une forte tension numérologique peut être très productive, là où cette même tension en couple demanderait plus de travail émotionnel.",
        },
      },
      {
        "@type": "Question",
        name: "Faut-il privilégier l'astrologie ou la numérologie pour la compatibilité ?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Idéalement, les deux. La numérologie donne la dynamique globale du couple en 30 secondes. L'astrologie, via la synastrie, permet d'entrer dans le détail aspect par aspect. Karmastro propose une synastrie complète dans son application, avec croisement des deux disciplines et guidance karmique.",
        },
      },
      {
        "@type": "Question",
        name: "Les maîtres nombres changent-ils le calcul de compatibilité ?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Oui, significativement. Un 11 ou un 22 apporte une vibration plus exigeante et plus spirituelle. Une compatibilité 11-2 fonctionne sur le papier mais peut écraser le 2. Une compatibilité 22-4 est extrêmement harmonique. Les maîtres nombres demandent des partenaires qui peuvent tenir le rythme de leur mission.",
        },
      },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6">
      <a href="/" class="hover:text-amber-300">Accueil</a>
      <span class="mx-2">/</span>
      <a href="/outils/" class="hover:text-amber-300">Outils</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">Compatibilité</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Numérologie pythagoricienne</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Calculateur de compatibilité</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        Croise deux chemins de vie et découvre la dynamique karmique de votre relation. Forces, défis, leçons partagées. Calcul instantané, résultat transparent.
      </p>
    </header>

    <aside data-speakable class="max-w-2xl mx-auto mb-10 p-5 md:p-6 rounded-2xl border border-amber-300/25 bg-gradient-to-br from-amber-300/[0.06] to-purple-400/[0.04]">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">En bref</p>
      <p class="text-[15px] md:text-base text-white/90 leading-relaxed">
        <strong>La compatibilité numérologique</strong> analyse la dynamique relationnelle entre deux personnes en croisant leurs chemins de vie (les 9 nombres de base plus les 3 maîtres nombres 11, 22, 33). Le résultat est un score sur 100 qui mesure la fluidité de l'interaction, pas la qualité de l'amour : un score bas n'interdit rien, un score haut ne garantit rien. Le calcul fonctionne pour toutes les relations (amour, amitié, travail, famille) et se fait uniquement à partir des dates de naissance. Ce calculateur gratuit te le donne en quelques secondes à partir de vos deux dates de naissance.
      </p>
    </aside>

    <div id="calculator" class="p-6 md:p-8 rounded-3xl border border-amber-300/20 bg-amber-300/5 mb-10">
      <form id="compat-form" class="space-y-6">
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <p class="text-xs uppercase tracking-widest text-pink-300/80 mb-3">Personne 1</p>
            <label for="date-a" class="block text-sm font-medium text-white/80 mb-2">Date de naissance</label>
            <input
              type="date"
              id="date-a"
              required
              class="w-full px-4 py-3 rounded-xl bg-[#0f0a1e]/50 border border-white/10 text-white focus:border-amber-300 focus:outline-none transition-colors"
            />
          </div>
          <div>
            <p class="text-xs uppercase tracking-widest text-purple-300/80 mb-3">Personne 2</p>
            <label for="date-b" class="block text-sm font-medium text-white/80 mb-2">Date de naissance</label>
            <input
              type="date"
              id="date-b"
              required
              class="w-full px-4 py-3 rounded-xl bg-[#0f0a1e]/50 border border-white/10 text-white focus:border-amber-300 focus:outline-none transition-colors"
            />
          </div>
        </div>
        <button
          type="submit"
          class="w-full px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold hover:opacity-90 transition-opacity"
        >
          Calculer la compatibilité
        </button>
      </form>

      <div id="result" class="mt-6 hidden">
        <div class="p-6 rounded-2xl bg-[#0f0a1e]/60 border border-amber-300/30">
          <div class="flex items-center justify-center gap-6 mb-6">
            <div class="text-center">
              <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Personne 1</p>
              <p id="life-a" class="text-5xl font-serif text-amber-300"></p>
            </div>
            <div class="text-4xl text-white/30">·</div>
            <div class="text-center">
              <p class="text-xs text-white/40 uppercase tracking-wider mb-1">Personne 2</p>
              <p id="life-b" class="text-5xl font-serif text-amber-300"></p>
            </div>
          </div>

          <div class="text-center mb-6">
            <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">Score de compatibilité</p>
            <div class="flex items-baseline justify-center gap-2">
              <span id="score-value" class="text-6xl font-serif text-amber-300"></span>
              <span class="text-2xl text-white/50">/100</span>
            </div>
            <p id="score-label" class="text-sm text-white/70 mt-2"></p>
          </div>

          <div class="space-y-4 mb-6">
            <div>
              <p class="text-xs uppercase tracking-widest text-emerald-300/80 mb-2">Dynamique du couple</p>
              <p id="dynamic-text" class="text-sm text-white/80 leading-relaxed"></p>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-purple-300/80 mb-2">Leçon karmique commune</p>
              <p id="lesson-text" class="text-sm text-white/80 leading-relaxed italic"></p>
            </div>
          </div>

          <div class="pt-4 border-t border-white/10 flex flex-col sm:flex-row flex-wrap gap-2 justify-center items-center">
            <a
              href="https://app.karmastro.com"
              class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium text-sm hover:opacity-90 transition-opacity"
            >
              Synastrie complète
            </a>
            <button id="download-pdf-btn" type="button" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-amber-300/40 text-amber-300 text-sm font-medium hover:bg-amber-300/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              Télécharger PDF
            </button>
            <button id="share-result-btn" type="button" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-amber-300/40 text-amber-300 text-sm font-medium hover:bg-amber-300/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line></svg>
              Partager
            </button>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">Qu'est-ce que la compatibilité numérologique ?</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        La <strong>compatibilité numérologique</strong> analyse la dynamique relationnelle entre deux personnes en croisant leurs chemins de vie. C'est une des méthodes les plus rapides et les plus fiables pour comprendre comment deux vibrations interagissent, que ce soit en amour, en amitié ou au travail. Contrairement à la compatibilité astrologique qui demande date, heure et lieu de naissance, la numérologie pythagoricienne se contente de deux dates.
      </p>
      <p class="text-white/80 leading-relaxed mb-4">
        Pour <a href="https://fr.wikipedia.org/wiki/Pythagore" class="text-amber-300 hover:underline">Pythagore</a>, chaque nombre émet une vibration unique. Quand deux personnes se rencontrent, leurs vibrations entrent en interaction : elles peuvent résonner harmoniquement (comme deux notes en accord), créer de la tension productive (comme un intervalle musical dissonant qui appelle une résolution), ou se neutraliser mutuellement. Le calcul de compatibilité ne prédit pas l'amour, il décrit la musique que vous jouez ensemble.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Comment Karmastro calcule la compatibilité</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        Le calcul se fait en trois étapes :
      </p>
      <ol class="text-white/80 space-y-2 mb-4 list-decimal pl-5">
        <li>On calcule le <strong>chemin de vie</strong> de chaque personne à partir de sa date de naissance, selon la méthode pythagoricienne classique</li>
        <li>On croise les deux chemins dans une <strong>matrice de compatibilité</strong> héritée de la tradition et validée par l'expérience clinique des numérologues</li>
        <li>On produit un <strong>score</strong> (de 0 à 100) et une interprétation de la dynamique relationnelle spécifique à ce couple de nombres</li>
      </ol>
      <p class="text-white/80 leading-relaxed mb-4">
        Important : <strong>un score élevé ne garantit pas le bonheur, et un score bas ne condamne pas la relation</strong>. Le score mesure la <em>fluidité</em> de l'interaction, pas sa profondeur ni son potentiel transformateur. Certains des couples les plus féconds de l'histoire ont des compatibilités numérologiques tendues : c'est la friction qui les a fait grandir.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Les grandes familles de compatibilité</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        En numérologie, les nombres se regroupent en trois grandes familles qui partagent une affinité naturelle :
      </p>
      <div class="not-prose overflow-x-auto mb-6">
        <table class="w-full text-sm text-left border-collapse">
          <thead>
            <tr class="border-b border-white/10">
              <th class="py-3 px-4 text-amber-300 font-serif">Famille</th>
              <th class="py-3 px-4 text-amber-300 font-serif">Nombres</th>
              <th class="py-3 px-4 text-amber-300 font-serif">Énergie</th>
            </tr>
          </thead>
          <tbody class="text-white/80">
            <tr class="border-b border-white/5">
              <td class="py-3 px-4">Famille créative</td>
              <td class="py-3 px-4">1, 3, 5</td>
              <td class="py-3 px-4">Action, expression, mouvement</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 px-4">Famille émotionnelle</td>
              <td class="py-3 px-4">2, 4, 6, 8</td>
              <td class="py-3 px-4">Stabilité, responsabilité, liens</td>
            </tr>
            <tr class="border-b border-white/5">
              <td class="py-3 px-4">Famille spirituelle</td>
              <td class="py-3 px-4">7, 9, 11, 22, 33</td>
              <td class="py-3 px-4">Profondeur, sagesse, mission</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-white/80 leading-relaxed mb-4">
        Les compatibilités <em>intra-famille</em> sont souvent les plus fluides, mais les plus transformatrices peuvent venir du croisement entre familles. Un 5 (aventurier) avec un 4 (bâtisseur) crée un ressort formidable si les deux acceptent leurs différences. Un 9 (sage) avec un 1 (pionnier) peut donner un couple visionnaire.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Au-delà du score : la synastrie astrologique</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        La numérologie donne une vision d'ensemble. Pour aller plus loin, les astrologues utilisent la <strong>synastrie</strong> : le croisement complet des deux thèmes natals. Ils regardent comment le Soleil de l'un aspecte la Lune de l'autre, comment Vénus et Mars s'alignent (attraction physique), comment Saturne stabilise ou bloque, comment Pluton transforme. C'est le niveau de précision le plus avancé en compatibilité.
      </p>
      <p class="text-white/80 leading-relaxed mb-4">
        Karmastro propose cette analyse complète dans son <a href="https://app.karmastro.com" class="text-amber-300 hover:underline">application</a>, où les guides (<a href="/notre-histoire/" class="text-amber-300 hover:underline">Sibylle pour l'astro profonde, Séléné pour les relations, Pythia pour les nombres</a>) croisent numérologie et astrologie pour te donner une lecture complète de ta relation. L'Oracle peut répondre à des questions précises sur ton couple.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Compatibilité et karma</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        Dans la tradition hindoue comme dans la philosophie grecque, les relations ne sont pas aléatoires. Le Bouddha disait : "Ce que tu es est ce que tu as été." Les gens que tu attires aujourd'hui sont souvent des âmes que tu as déjà croisées, selon la théorie karmique. Les <strong>nœuds lunaires</strong> en astrologie et les <strong>dettes karmiques</strong> en numérologie te montrent ce que tu es venu apprendre, et avec qui.
      </p>
      <p class="text-white/80 leading-relaxed mb-4">
        Certaines relations "faciles" sont en réalité des confirmations de ce que tu sais déjà (karma positif). D'autres, plus difficiles, sont des leçons à intégrer. C'est pour ça qu'on ne peut pas juger une relation uniquement sur son confort : parfois, celles qui grattent le plus sont celles qui nous font le plus grandir. Le calculateur ici est un point de départ, pas un verdict.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Questions fréquentes</h2>

      <h3 class="font-serif text-xl mb-2">Peut-on calculer la compatibilité avec quelqu'un de décédé ?</h3>
      <p class="text-white/80 leading-relaxed mb-4">
        Oui, la compatibilité se calcule toujours à partir de la date de naissance. C'est même une démarche émouvante que font beaucoup de personnes en deuil : comprendre la dynamique karmique qu'elles avaient avec un être cher disparu peut aider à faire la paix avec ce qui a été et ce qui n'a pas pu être.
      </p>

      <h3 class="font-serif text-xl mb-2">Qu'est-ce qu'un couple 11-11 ou 22-22 ?</h3>
      <p class="text-white/80 leading-relaxed mb-4">
        C'est extrêmement rare et très puissant. Deux maîtres nombres identiques forment un miroir : vous vous comprenez instantanément mais vous pouvez aussi vous enfermer dans votre bulle. C'est souvent le signe d'une mission spirituelle commune, une "équipe d'âmes" qui s'est retrouvée pour un travail précis.
      </p>

      <h3 class="font-serif text-xl mb-2">La compatibilité change-t-elle au fil du temps ?</h3>
      <p class="text-white/80 leading-relaxed mb-4">
        Les chemins de vie ne changent jamais, donc la compatibilité structurelle reste fixe. En revanche, l'<strong>année personnelle</strong> de chacun évolue d'année en année. Un couple peut traverser des années où les énergies s'alignent naturellement (années fluides) et d'autres où elles se frottent (années de croissance). C'est pour ça que beaucoup de couples consultent annuellement pour comprendre ce qui les attend.
      </p>

      <h3 class="font-serif text-xl mb-2">Cette calculatrice peut-elle me dire si je dois rompre ?</h3>
      <p class="text-white/80 leading-relaxed mb-4">
        Non. Aucun outil, aussi précis soit-il, ne peut répondre à cette question à ta place. La numérologie éclaire, elle ne décide pas. Si tu cherches de la clarté sur une relation complexe, parle-en à <a href="https://app.karmastro.com/oracle" class="text-amber-300 hover:underline">Séléné</a>, notre guide relationnelle : elle croisera la compatibilité numérologique avec ta synastrie astrologique et tes questions précises pour t'aider à y voir plus clair.
      </p>

      <h3 class="font-serif text-xl mb-2">Puis-je utiliser ce calcul pour l'amitié ou le travail ?</h3>
      <p class="text-white/80 leading-relaxed mb-4">
        Oui absolument. La dynamique énergétique entre deux nombres est la même en amour, en amitié et au travail, c'est l'<em>interprétation</em> qui diffère. Une forte tension numérologique peut être catastrophique en couple mais géniale dans un binôme créatif (elle pousse chacun à se dépasser). Une fluidité totale peut être un confort douillet en amour mais ennuyeuse au travail.
      </p>
    </section>

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center mb-10">
      <h3 class="font-serif text-xl mb-2">Synastrie complète = niveau supérieur</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed max-w-xl mx-auto">
        La numérologie donne la mélodie. L'astrologie donne l'orchestration. Pour une analyse de ton couple qui croise les deux (synastrie planétaire + chemins de vie + dettes karmiques), ouvre un profil dans l'app.
      </p>
      <a
        href="https://app.karmastro.com"
        class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity"
      >
        Analyser notre couple en profondeur
      </a>
    </div>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/outils/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">← Tous les outils</a>
      <a href="/outils/chemin-de-vie/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Chemin de vie</a>
      <a href="/outils/ascendant/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Ascendant</a>
      <a href="/horoscope/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Horoscope du jour</a>
    </nav>
  </article>
</BaseLayout>

<script>
  import { calculateLifePath } from "../../data/numerology-meanings";
  import { revealResult, animateNumberTo } from "../../scripts/karma-reveal";

  // Compatibility matrix: score 0-100 + interpretation
  // Based on traditional Pythagorean numerology (with master numbers reduced for matrix lookup)
  const COMPAT_MATRIX: Record<string, { score: number; dynamic: string; lesson: string }> = {
    "1-1": { score: 75, dynamic: "Deux leaders face à face. Puissant quand chacun reconnaît l'autre comme son égal, explosif quand l'ego prend le dessus. Vous avez besoin d'espaces séparés pour exister pleinement.", lesson: "Apprendre que la véritable force se partage sans se diluer." },
    "1-2": { score: 70, dynamic: "Le pionnier et le diplomate. Le 1 trace la voie, le 2 en assure la cohésion. Très complémentaire si le 1 respecte la sensibilité du 2, et si le 2 n'étouffe pas le 1 sous trop de soins.", lesson: "L'équilibre entre l'action et la douceur." },
    "1-3": { score: 85, dynamic: "Alliance créative et joyeuse. Le 1 pose les bases, le 3 illumine tout de sa couleur. Énergie contagieuse. Couple qui vit, qui crée, qui avance sans se prendre au sérieux.", lesson: "Garder le feu vivant sans s'y brûler." },
    "1-4": { score: 55, dynamic: "Tension productive. Le 1 veut avancer vite, le 4 veut construire patiemment. Friction inévitable, mais si chacun apprend de l'autre, vous bâtissez du solide qui résiste au temps.", lesson: "Marier la vitesse et la patience." },
    "1-5": { score: 90, dynamic: "Couple d'aventuriers. Énergie identique, même soif de liberté, même refus des cages. Vous avancez ensemble ou vous vous inspirez mutuellement à chaque pas. Combinaison magnétique.", lesson: "Rester libre ensemble sans s'oublier soi-même." },
    "1-6": { score: 65, dynamic: "Le guerrier et le protecteur. Le 1 admire le cœur du 6, le 6 veut ancrer le 1. Relation stable si le 1 n'écrase pas les besoins affectifs du 6, et si le 6 ne maternalise pas le 1.", lesson: "Offrir de la tendresse sans étouffer l'autonomie." },
    "1-7": { score: 60, dynamic: "Extraverti face à introspectif. Le 1 fonce dans le réel, le 7 plonge dans les mystères. Fascination mutuelle mais rythmes opposés. Fonctionne si chacun respecte les silences de l'autre.", lesson: "Honorer deux façons opposées de chercher la vérité." },
