      });
      const data = await r.json();
      if (data?.url) { window.location.href = data.url; }
      else { throw new Error(data?.error || "no url"); }
    } catch {
      btn.disabled = false;
      btn.textContent = original;
      alert("Une erreur est survenue, réessaie dans un instant.");
    }
  });

  // Profil complet 12,90€ : ici on a date ET nom → portrait 4/4 idéal.
  document.getElementById("km-buy-complete")?.addEventListener("click", async (ev) => {
    const btn = ev.currentTarget as HTMLButtonElement;
    btn.disabled = true;
    const original = btn.textContent;
    btn.textContent = "Redirection…";
    const birthDate = (document.getElementById("birth-date") as HTMLInputElement).value;
    const fullName = (document.getElementById("full-name") as HTMLInputElement)?.value || "";
    try {
      const r = await fetch(CHECKOUT_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ tool: "profil-complet", birthDate, fullName, locale: "fr" }),
      });
      const data = await r.json();
      if (data?.url) { window.location.href = data.url; }
      else { throw new Error(data?.error || "no url"); }
    } catch {
      btn.disabled = false;
      btn.textContent = original;
      alert("Une erreur est survenue, réessaie dans un instant.");
    }
  });
</script>
