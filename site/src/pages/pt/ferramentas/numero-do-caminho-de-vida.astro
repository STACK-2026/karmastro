</BaseLayout>

<script>
  import { calculateLifePath } from "../../../data/numerology-meanings";

  const MEANINGS_PT: Record<number, { title: string; summary: string; qualities: string[]; challenges: string[]; mission: string }> = {
    1: { title: "O Pioneiro", summary: "Nasceste para liderar, não para seguir. O Caminho de Vida 1 carrega a energia pura da iniciativa. Quando entras numa sala, algo muda. A tua missão é transformar essa força em criação, não em dominação.", qualities: ["Liderança natural", "Independência", "Ambição", "Coragem", "Originalidade"], challenges: ["Egocentrismo", "Impaciência", "Solidão", "Autoritarismo", "Rigidez"], mission: "Aprende a liderar sem esmagar, a ser forte sem endurecer. O 1 está aqui para criar terreno novo, para ousar onde outros esperam." },
    2: { title: "A Diplomata", summary: "Percebes as energias como outros ouvem sons. O Caminho de Vida 2 é o caminho da paz, da harmonia e da união. A tua missão é usar essa sensibilidade como um radar, não como uma ferida.", qualities: ["Diplomacia", "Sensibilidade", "Empatia", "Paciência", "Cooperação"], challenges: ["Dependência emocional", "Indecisão", "Hipersensibilidade", "Evitar conflitos", "Submissão"], mission: "Compreende que a suavidade é força, não fraqueza. O 2 está aqui para reconciliar, para ver o que os outros não veem." },
    3: { title: "A Artista", summary: "Transformas tudo em cor, palavras ou música. O Caminho de Vida 3 é o caminho da expressão criativa. A tua missão é dar forma ao intangível e partilhá-lo generosamente.", qualities: ["Criatividade", "Comunicação", "Otimismo", "Carisma", "Alegria"], challenges: ["Dispersão", "Superficialidade", "Fofocas", "Imaturidade emocional", "Escapismo"], mission: "Aprende que a profundidade não mata a alegria. O 3 está aqui para expressar, para inspirar, para lembrar aos outros a beleza do mundo." },
    4: { title: "O Construtor", summary: "Constróis o que outros apenas sonham. O Caminho de Vida 4 é o caminho da estabilidade, da estrutura e dos resultados duradouros. A tua missão é criar algo que te sobreviva.", qualities: ["Disciplina", "Fiabilidade", "Paciência", "Lealdade", "Destreza prática"], challenges: ["Rigidez", "Vício do trabalho", "Teimosia", "Medo da mudança", "Seriedade excessiva"], mission: "Aprende que a estrutura serve a liberdade, não o contrário. O 4 está aqui para construir o duradouro, com disciplina e cuidado." },
    5: { title: "A Aventureira", summary: "Precisas de liberdade como outros precisam de ar. O Caminho de Vida 5 é o caminho da mudança, da experiência e da liberdade pessoal. A tua missão é transformar o movimento em sabedoria.", qualities: ["Curiosidade", "Adaptabilidade", "Charme", "Versatilidade", "Coragem para mudar"], challenges: ["Inquietação", "Problemas de compromisso", "Impulsividade", "Tendências aditivas", "Energia dispersa"], mission: "Aprende que a liberdade sem direção é apenas deriva. O 5 está aqui para explorar com propósito, para transformar a experiência em visão." },
    6: { title: "O Cuidador", summary: "Carregas os outros como Atlas carregou o mundo. O Caminho de Vida 6 é o caminho da responsabilidade, do amor e do serviço. A tua missão é dar sem te perderes.", qualities: ["Instinto de cuidar", "Responsabilidade", "Lealdade", "Capacidade de ensinar", "Dons criativos"], challenges: ["Martírio", "Envolvimento excessivo", "Perfeccionismo", "Autossacrifício", "Intromissão"], mission: "Aprende que não podes servir a partir de um copo vazio. O 6 está aqui para curar, para ensinar, para criar beleza à volta dos que ama." },
    7: { title: "O Buscador", summary: "Nasceste a perguntar porquê. O Caminho de Vida 7 é o caminho da sabedoria, da introspeção e da compreensão espiritual. A tua missão é encontrar a verdade e partilhar o que aprendes.", qualities: ["Pensamento profundo", "Intuição", "Independência", "Mente analítica", "Consciência espiritual"], challenges: ["Isolamento", "Cinismo", "Análise excessiva", "Desconfiança", "Distância emocional"], mission: "Aprende que a verdade sem amor é estéril. O 7 está aqui para cavar sob a superfície e trazer o que encontra para os outros." },
    8: { title: "A Estratega", summary: "Entendes o poder sem te deixares seduzir por ele. O Caminho de Vida 8 é o caminho do domínio material, da abundância e da influência. A tua missão é construir algo que sirva mais do que a ti mesmo.", qualities: ["Liderança", "Intuição financeira", "Capacidade organizativa", "Resistência", "Autoridade"], challenges: ["Ganância", "Vício do trabalho", "Necessidade de controlar", "Materialismo", "Intimidação"], mission: "Aprende que o verdadeiro poder se mede pelo que cria, não pelo que domina. O 8 está aqui para dominar o mundo material com integridade." },
    9: { title: "O Humanitário", summary: "Chegas à vida sabendo coisas que outros têm de aprender. O Caminho de Vida 9 é o caminho do amor universal, da compaixão e do desapego. A tua missão é servir algo maior do que tu.", qualities: ["Compaixão", "Sabedoria", "Sensibilidade artística", "Perspetiva global", "Generosidade"], challenges: ["Desapego emocional", "Complexo de salvador", "Melancolia", "Dificuldade em soltar", "Autojustiça"], mission: "Aprende que render-se é força, não derrota. O 9 está aqui para amar sem possuir, para dar sem esperar retorno." },
    11: { title: "A Visionária (Número Mestre)", summary: "Nasceste ligada a uma frequência mais alta. O Número Mestre 11 carrega uma intuição intensa e um chamado para despertar os outros. A tua missão é canalizar a inspiração em forma concreta.", qualities: ["Intuição excecional", "Pensamento visionário", "Carisma", "Magnetismo espiritual", "Presença inspiradora"], challenges: ["Tensão nervosa", "Hipersensibilidade", "Dúvidas de si mesma", "Ansiedade", "Martírio"], mission: "Aprende que a tua sensibilidade é o teu dom, não a tua ferida. O 11 está aqui para trazer luz aos que caminham na escuridão." },
    22: { title: "O Mestre Construtor (Número Mestre)", summary: "Podes transformar o impossível num plano. O Número Mestre 22 combina a intuição espiritual do 11 com a força prática do 4. A tua missão é construir algo que mude o mundo.", qualities: ["Pragmatismo visionário", "Liderança", "Inovação", "Resistência", "Pensamento em grande escala"], challenges: ["Pressão esmagadora", "Perfeccionismo", "Esgotamento", "Tendências ditatoriais", "Paralisia pela dúvida"], mission: "Aprende que a paciência não é fraqueza. O 22 está aqui para construir monumentos do espírito, sejam edifícios, movimentos ou ideias." },
    33: { title: "O Curador Universal (Número Mestre)", summary: "Nasceste com uma frequência rara de amor desinteressado. O Número Mestre 33 é o caminho de vida mais raro. A tua missão é curar o mundo com sabedoria e compaixão.", qualities: ["Amor incondicional", "Dom para ensinar", "Cura criativa", "Devoção espiritual", "Serviço sagrado"], challenges: ["Martírio", "Exaustão emocional", "Perfeccionismo", "Esquecimento de si", "Responsabilidade esmagadora"], mission: "Aprende que dar a partir do vazio não é dar. O 33 está aqui para curar através da presença, não do sacrifício." },
  };

  const form = document.getElementById("life-path-form") as HTMLFormElement;
  const resultDiv = document.getElementById("result") as HTMLDivElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = document.getElementById("birth-date") as HTMLInputElement;
    const value = input.value;
    if (!value) return;

    const [y, m, d] = value.split("-").map(Number);
    const result = calculateLifePath(d, m, y);
    const meaning = MEANINGS_PT[result.number] || MEANINGS_PT[9];

    (document.getElementById("result-number") as HTMLElement).textContent = String(result.number);
    (document.getElementById("result-title") as HTMLElement).textContent = meaning.title;
    (document.getElementById("result-calc") as HTMLElement).textContent = result.calculation;
    (document.getElementById("result-summary") as HTMLElement).textContent = meaning.summary;

    const qualitiesList = document.getElementById("result-qualities") as HTMLElement;
    qualitiesList.innerHTML = meaning.qualities.map((q) => `<li>✦ ${q}</li>`).join("");

    const challengesList = document.getElementById("result-challenges") as HTMLElement;
    challengesList.innerHTML = meaning.challenges.map((c) => `<li>◆ ${c}</li>`).join("");

    (document.getElementById("result-mission") as HTMLElement).textContent = meaning.mission;

    resultDiv.classList.remove("hidden");
    resultDiv.scrollIntoView({ behavior: "smooth", block: "start" });
  });
</script>
