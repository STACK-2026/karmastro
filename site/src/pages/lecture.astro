---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Ta lecture · Karmastro";
const description = "Ta lecture personnalisée.";
---

<BaseLayout title={title} description={description} noIndex={true}>
  <article class="max-w-2xl mx-auto px-4 py-16 min-h-[60vh]">
    <div id="lc-loading" class="text-center py-20">
      <p class="text-4xl mb-4 animate-pulse">✦</p>
      <p class="font-serif text-2xl text-white mb-2">Génération de ta lecture…</p>
      <p class="text-sm text-white/60">Orion consulte les nombres. Quelques secondes.</p>
    </div>
    <div id="lc-content" class="prose prose-invert max-w-none hidden"></div>
    <div id="lc-error" class="hidden text-center py-20">
      <p class="text-4xl mb-4">✦</p>
      <p class="font-serif text-2xl text-white mb-2">Ta lecture arrive…</p>
      <p class="text-sm text-white/60 max-w-md mx-auto leading-relaxed">
        Si rien ne s'affiche d'ici une minute, recharge la page. Ton paiement est bien pris en compte
        et ta lecture t'est aussi envoyée par email.
      </p>
    </div>
  </article>
</BaseLayout>

<script>
  const GET_READING = "https://nkjbmbdrvejemzrggxvr.supabase.co/functions/v1/get-reading";
  const params = new URLSearchParams(location.search);
  const token = params.get("token");
  const lang = params.get("lang") === "en" ? "en" : "fr";
  const loading = document.getElementById("lc-loading")!;
  const content = document.getElementById("lc-content")!;
  const errEl = document.getElementById("lc-error")!;

  // Localise les libellés UI (le contenu de la lecture vient déjà localisé du backend).
  const STR = {
    fr: {
      loadingTitle: "Génération de ta lecture…", loadingSub: "Orion consulte les nombres. Quelques secondes.",
      errorTitle: "Ta lecture arrive…",
      errorSub: "Si rien ne s'affiche d'ici une minute, recharge la page. Ton paiement est bien pris en compte et ta lecture t'est aussi envoyée par email.",
      emailNote: "Une copie t'a été envoyée par email. Garde ce lien pour retrouver ta lecture à tout moment.",
      crossTitle: "Continue ton exploration",
      tools: [["/outils/chemin-de-vie/", "Chemin de vie"], ["/outils/ascendant/", "Ascendant"], ["/outils/compatibilite/", "Compatibilité"], ["/outils/transits/", "Transits du jour"]],
    },
    en: {
      loadingTitle: "Generating your reading…", loadingSub: "Orion is consulting the numbers. A few seconds.",
      errorTitle: "Your reading is on its way…",
      errorSub: "If nothing shows within a minute, reload the page. Your payment went through and your reading is also sent to you by email.",
      emailNote: "A copy has been sent to your email. Keep this link to find your reading any time.",
      crossTitle: "Keep exploring",
      tools: [["/en/tools/life-path-number/", "Life path"], ["/en/tools/rising-sign/", "Rising sign"], ["/en/tools/personal-year/", "Personal year"], ["/en/tools/expression-number/", "Expression number"]],
    },
  }[lang];
  if (lang === "en") {
    loading.children[1].textContent = STR.loadingTitle;
    loading.children[2].textContent = STR.loadingSub;
    errEl.children[1].textContent = STR.errorTitle;
    errEl.children[2].textContent = STR.errorSub;
  }

  function esc(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }

  // Rendu markdown minimal : titres ## / # + paragraphes (le contenu vient de Claude).
  function mdToHtml(md: string): string {
    return md.split(/\n{2,}/).map((block) => {
      const b = esc(block.trim());
      if (!b) return "";
      if (b.startsWith("## ")) return `<h2 class="font-serif text-2xl mt-8 mb-3 text-amber-300">${b.slice(3)}</h2>`;
      if (b.startsWith("# ")) return `<h1 class="font-serif text-3xl mb-4">${b.slice(2)}</h1>`;
      return `<p class="text-white/85 leading-relaxed mb-4">${b.replace(/\n/g, "<br>")}</p>`;
    }).join("");
  }

  function showError() {
    loading.classList.add("hidden");
    errEl.classList.remove("hidden");
  }

  let tries = 0;
  async function poll() {
    if (!token) { showError(); return; }
    try {
      const r = await fetch(`${GET_READING}?token=${encodeURIComponent(token)}`);
      const data = await r.json();
      if (data.status === "ready" && data.content) {
        loading.classList.add("hidden");
        const crossLinks = STR.tools
          .map(([href, label]) => `<a href="${href}" class="px-4 py-2 rounded-xl border border-amber-300/30 text-amber-300 text-sm hover:bg-amber-300/10 transition-colors no-underline">${label}</a>`)
          .join("");
        const subCta = lang === "fr"
          ? `<div class="mt-8 p-5 rounded-2xl border border-amber-300/30 bg-gradient-to-r from-purple-400/10 to-amber-300/10 not-prose text-center">
               <p class="font-serif text-base text-white mb-1">Et si Orion t'écrivait chaque mois ?</p>
               <p class="text-xs text-white/60 mb-3 max-w-sm mx-auto leading-relaxed">Ta guidance personnalisée du mois, livrée par email. 4,90€/mois, sans engagement.</p>
               <a href="/abonnement/" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold text-sm">Recevoir ma guidance chaque mois ✦</a>
             </div>`
          : "";
        content.innerHTML = mdToHtml(data.content) +
          `<p class="text-xs text-white/40 mt-10 border-t border-white/10 pt-4">${STR.emailNote}</p>` +
          `<div class="mt-12 pt-8 border-t border-white/10 text-center not-prose">
             <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-4">${STR.crossTitle}</p>
             <div class="flex flex-wrap gap-2 justify-center">${crossLinks}</div>
           </div>` + subCta;
        content.classList.remove("hidden");
        // Conversion event : lecture payée ET livrée à l'écran.
        try { (window as any).km?.trackEvent("reading_delivered", { tool: data.tool_type || "", locale: lang, path: location.pathname }); } catch { /* noop */ }
        return;
      }
      if (data.status === "error") { showError(); return; }
    } catch { /* transient, on retente */ }
    if (++tries > 20) { showError(); return; }
    setTimeout(poll, 2000);
  }
  poll();
</script>
