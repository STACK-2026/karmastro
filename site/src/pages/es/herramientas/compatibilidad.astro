---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const title = "Calculadora de Compatibilidad Zodiacal Gratis | Karmastro";
const description =
  "Compatibilidad zodiacal gratis: amor, amistad, trabajo y compatibilidad kármica entre dos signos. Basada en elementos, modalidades y aspectos planetarios. Precisión profesional.";

const jsonLd = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://karmastro.com/es/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Herramientas",
      "item": "https://karmastro.com/es/herramientas"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Compatibilidad",
      "item": "https://karmastro.com/es/herramientas/compatibilidad"
    }
  ]
},
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Calculadora de Compatibilidad Zodiacal",
    description,
    url: "https://karmastro.com/es/herramientas/compatibilidad",
    applicationCategory: "UtilitiesApplication",
    operatingSystem: "Any",
    inLanguage: "es",
    offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
    aggregateRating: { "@type": "AggregateRating", ratingValue: "4.8", ratingCount: "356" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      { "@type": "Question", name: "¿Cómo funciona la compatibilidad zodiacal?", acceptedAnswer: { "@type": "Answer", text: "La compatibilidad zodiacal analiza las relaciones entre elementos (fuego, tierra, aire, agua), modalidades (cardinal, fijo, mutable) y planetas regentes de dos signos. Los signos del mismo elemento o de elementos complementarios suelen tener mayor afinidad natural." } },
      { "@type": "Question", name: "¿Es suficiente con el signo solar?", acceptedAnswer: { "@type": "Answer", text: "No, es solo la primera capa. Una compatibilidad real cruza sol, luna, Venus, Marte y el ascendente de ambas personas. La sinastría completa es lo que de verdad revela la química." } },
      { "@type": "Question", name: "¿Los signos opuestos se atraen?", acceptedAnswer: { "@type": "Answer", text: "Sí y no. Los signos opuestos comparten el eje (Aries-Libra, Tauro-Escorpio, etc.) y están hechos para complementarse, pero necesitan trabajo consciente. La atracción inicial es fuerte, la convivencia requiere madurez." } },
      { "@type": "Question", name: "¿Qué signos son más compatibles?", acceptedAnswer: { "@type": "Answer", text: "Los signos del mismo elemento (fuego con fuego, tierra con tierra, etc.) tienen afinidad natural. Los elementos complementarios también funcionan: fuego y aire se alimentan, tierra y agua se nutren. Pero cada carta natal completa cuenta una historia única." } },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/es" class="hover:text-amber-300">Inicio</a>
      <span class="mx-2">/</span>
      <a href="/es/herramientas" class="hover:text-amber-300">Herramientas</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">Compatibilidad</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Astrología Relacional</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Compatibilidad Zodiacal Gratis</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        ¿Qué signos encajan de verdad? Nuestra calculadora cruza elementos, modalidades, planetas regentes y aspectos para darte una lectura honesta de la afinidad entre dos signos.
      </p>
    </header>

    <aside data-speakable class="max-w-2xl mx-auto mb-10 p-5 md:p-6 rounded-2xl border border-amber-300/25 bg-gradient-to-br from-amber-300/[0.06] to-purple-400/[0.04]">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">En breve</p>
      <p class="text-[15px] md:text-base text-white/90 leading-relaxed">
        La <strong>compatibilidad zodiacal</strong> mide cómo interactúan dos signos entre los 12 signos, 4 elementos (fuego, tierra, aire, agua) y 3 cualidades (cardinal, fija, mutable). La astrología tradicional puntúa cada pareja en 5 ejes: amor, amistad, trabajo, karma y tensión. Fuego y aire se amplifican, tierra y agua se nutren, las parejas de misma cualidad chocan por el control. Esta calculadora gratis te devuelve las cinco puntuaciones al instante a partir de tus dos signos solares.
      </p>
    </aside>

    <div class="p-8 md:p-10 rounded-3xl border border-pink-300/30 bg-gradient-to-br from-pink-300/10 to-purple-400/10 mb-10 text-center">
      <div class="text-5xl mb-4">♥</div>
      <h2 class="text-2xl md:text-3xl font-serif text-white mb-3">Descubre vuestra compatibilidad real</h2>
      <p class="text-white/70 mb-6 max-w-xl mx-auto leading-relaxed">
        Indica los dos signos solares y accede a un análisis completo: amor, amistad, trabajo, compatibilidad kármica. Para profundizar con las cartas natales completas, usa la Sinastría del Oráculo.
      </p>
      <a href="https://app.karmastro.com/oracle?lang=es" class="inline-block px-6 py-3 rounded-xl bg-gradient-to-r from-pink-400 to-purple-400 text-white font-semibold hover:opacity-90 transition-opacity">
        Calcular la compatibilidad
      </a>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">La lógica de la compatibilidad</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        La astrología no se limita a decir "Aries y Leo encajan". Existen cuatro capas que combinadas dan una lectura fina: elementos, modalidades, planetas regentes y aspectos entre los astros personales (Sol, Luna, Venus, Marte).
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Los cuatro elementos</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>Fuego</strong> (Aries, Leo, Sagitario): pasión, acción, entusiasmo.</li>
        <li><strong>Tierra</strong> (Tauro, Virgo, Capricornio): estabilidad, sensualidad, pragmatismo.</li>
        <li><strong>Aire</strong> (Géminis, Libra, Acuario): mente, palabra, conexión social.</li>
        <li><strong>Agua</strong> (Cáncer, Escorpio, Piscis): emoción, intuición, profundidad.</li>
      </ul>
      <p class="text-white/80 leading-relaxed mb-4">
        Fuego y aire se alimentan (el viento aviva la llama). Tierra y agua se nutren (el agua da vida a la tierra). Las combinaciones opuestas generan tensión y, con trabajo, transformación.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Las modalidades</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>Cardinal</strong> (Aries, Cáncer, Libra, Capricornio): iniciadores.</li>
        <li><strong>Fijo</strong> (Tauro, Leo, Escorpio, Acuario): constructores, leales.</li>
        <li><strong>Mutable</strong> (Géminis, Virgo, Sagitario, Piscis): adaptables.</li>
      </ul>

      <h2 class="font-serif text-3xl mb-4 mt-10">Más allá del signo solar</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        Una compatibilidad seria cruza la <strong>Luna</strong> (necesidades emocionales), <strong>Venus</strong> (estilo amoroso), <strong>Marte</strong> (deseo y conflicto) y el <strong>Ascendente</strong> (primera impresión). Dos personas con el mismo signo solar pueden ser muy distintas si el resto de su carta cambia. Para esta profundidad, acude a nuestra <a href="/es/herramientas/carta-natal" class="text-amber-300 hover:underline">Calculadora de Carta Natal</a>.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Compatibilidad kármica</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        Ciertos aspectos (conjunción Saturno-Venus, nodo lunar sobre planeta personal, Quirón-Marte) indican vínculos kármicos: relaciones que vienen a enseñar algo concreto. No son necesariamente "buenas" o "malas", son lecciones. La numerología también aporta su capa: compara el <a href="/es/herramientas/camino-de-vida" class="text-amber-300 hover:underline">camino de vida</a> de ambos.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Fuentes autorizadas</h2>
      <ul class="text-white/80 space-y-1 mb-4 list-disc pl-5">
        <li><a href="https://es.wikipedia.org/wiki/Zodiaco" class="text-amber-300 hover:underline" rel="external">Zodiaco en Wikipedia</a></li>
        <li><a href="https://www.britannica.com/topic/zodiac" class="text-amber-300 hover:underline" rel="external">Zodiac - Britannica</a></li>
        <li><a href="https://es.wikipedia.org/wiki/Sinastr%C3%ADa" class="text-amber-300 hover:underline" rel="external">Sinastría - Wikipedia</a></li>
      </ul>
    </section>

    <div class="p-6 rounded-2xl border border-pink-300/30 bg-pink-300/5 text-center mb-10">
      <h3 class="font-serif text-xl mb-2">¿Quieres una sinastría completa?</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed max-w-xl mx-auto">
        La compatibilidad por signo es el comienzo. La sinastría compara dos cartas natales enteras para ver la química real. Disponible en el Oráculo.
      </p>
      <a href="https://app.karmastro.com/oracle?lang=es" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-pink-400 to-purple-400 text-white font-medium hover:opacity-90 transition-opacity">
        Abrir la sinastría
      </a>
    </div>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/es/herramientas" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Todas las herramientas</a>
      <a href="/es/herramientas/carta-natal" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Carta natal</a>
      <a href="/es/herramientas/ascendente" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Ascendente</a>
      <a href="/es/herramientas/camino-de-vida" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Camino de vida</a>
      <a href="/es/herramientas/numero-expresion" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Número de expresión</a>
      <a href="/es/herramientas/ano-personal" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Año personal</a>
      <a href="/es/horoscopo" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Horóscopo</a>
      <a href="/es/blog" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Blog</a>
    </nav>
  </article>
</BaseLayout>
