---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ToolEditorial from "../../../components/ToolEditorial.astro";
import ReadingPaywallCTA from "../../../components/ReadingPaywallCTA.astro";
import { getToolEditorial } from "../../../data/tool-editorials";
const editorial_expression_number = getToolEditorial("expression-number", "es");

const title = "Calculadora del Número de Expresión (Número del Destino) | Karmastro";
const description =
  "Calcula tu número de expresión gratis, también llamado número del destino. Revela tus talentos innatos, tu misión y la dirección natural de tu vida. Numerología pitagórica.";

const jsonLd = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://karmastro.com/es/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Herramientas",
      "item": "https://karmastro.com/es/herramientas"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Número de expresión",
      "item": "https://karmastro.com/es/herramientas/numero-expresion"
    }
  ]
},
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Calculadora del Número de Expresión",
    description,
    url: "https://karmastro.com/es/herramientas/numero-expresion",
    applicationCategory: "UtilitiesApplication",
    operatingSystem: "Any",
    inLanguage: "es",
    offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
    aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", ratingCount: "298" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      { "@type": "Question", name: "¿Qué es el número de expresión?", acceptedAnswer: { "@type": "Answer", text: "El número de expresión, también llamado número del destino, se obtiene a partir del nombre completo de nacimiento. Revela los talentos innatos, las habilidades naturales y la misión vital que traes de fábrica." } },
      { "@type": "Question", name: "¿En qué se diferencia del camino de vida?", acceptedAnswer: { "@type": "Answer", text: "El camino de vida se calcula desde la fecha de nacimiento y muestra el viaje. El número de expresión se calcula desde el nombre completo de nacimiento y muestra las herramientas que traes para recorrerlo." } },
      { "@type": "Question", name: "¿Qué nombre debo usar?", acceptedAnswer: { "@type": "Answer", text: "Siempre el nombre completo que figura en tu certificado de nacimiento, incluyendo segundos nombres y apellidos. No el nombre casado, ni el apodo, ni el nombre artístico. El número de expresión viene de la vibración original del nacimiento." } },
      { "@type": "Question", name: "¿Qué son los números maestros 11, 22 y 33?", acceptedAnswer: { "@type": "Answer", text: "Los números maestros 11, 22 y 33 no se reducen. Cargan una vibración elevada: 11 intuición visionaria, 22 maestro constructor, 33 maestro sanador. Son dones exigentes que piden madurez." } },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/es/" class="hover:text-amber-300">Inicio</a>
      <span class="mx-2">/</span>
      <a href="/es/herramientas/" class="hover:text-amber-300">Herramientas</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">Número de expresión</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Numerología Pitagórica</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Calculadora del Número de Expresión</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        También llamado número del destino. Revela los talentos innatos que traes desde el nacimiento y la dirección natural de tu vida. Gratis, preciso, en español.
      </p>
    </header>

    <aside data-speakable class="max-w-2xl mx-auto mb-10 p-5 md:p-6 rounded-2xl border border-amber-300/25 bg-gradient-to-br from-amber-300/[0.06] to-purple-400/[0.04]">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">En breve</p>
      <p class="text-[15px] md:text-base text-white/90 leading-relaxed">
        Tu <strong>número de expresión</strong>, también llamado número del destino, es la vibración de un solo dígito que lleva tu nombre completo de nacimiento. La numerología pitagórica asigna a cada letra un valor de 1 a 9, los suma y reduce el total a una cifra de 1 a 9 (o los números maestros 11, 22, 33). El resultado revela tus talentos naturales y la caja de herramientas con la que llegaste a esta vida. Esta calculadora gratis lo devuelve en segundos desde tu nombre completo de nacimiento.
      </p>
    </aside>

    <div id="calculator" class="p-6 md:p-8 rounded-3xl border border-amber-300/20 bg-amber-300/5 mb-10">
      <form id="expr-form" class="space-y-4">
        <div>
          <label for="full-name" class="block text-sm font-medium text-white/80 mb-2">Tu nombre completo de nacimiento</label>
          <input type="text" id="full-name" required placeholder="p. ej. María Isabel García" class="w-full px-4 py-3 rounded-xl bg-[#0f0a1e]/50 border border-white/10 text-white placeholder-white/30 focus:border-amber-300 focus:outline-none transition-colors" />
          <p class="text-xs text-white/50 mt-1">Usa el nombre completo de tu certificado de nacimiento, incluyendo segundos nombres y apellidos.</p>
        </div>
        <button type="submit" class="w-full px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold hover:opacity-90 transition-opacity">
          Calcular mi número de expresión
        </button>
      </form>

      <div id="result" class="mt-6 hidden">
        <div class="p-6 rounded-2xl bg-[#0f0a1e]/60 border border-amber-300/30">
          <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">Tu número de expresión</p>
          <div class="flex items-baseline gap-4 mb-4">
            <span id="result-number" class="text-7xl font-serif text-amber-300"></span>
            <span id="result-title" class="text-xl font-serif text-white/90"></span>
          </div>
          <p class="text-xs text-white/50 mb-4">Letras: <span id="result-letters" class="text-white/70"></span></p>
          <p class="text-xs text-white/50 mb-4">Cálculo: <span id="result-calc" class="text-white/70"></span></p>
          <p id="result-summary" class="text-white/80 leading-relaxed mb-6"></p>
          <div>
            <p class="text-xs uppercase tracking-widest text-emerald-300/80 mb-2">Tus talentos naturales</p>
            <ul id="result-talents" class="text-sm text-white/70 space-y-1 mb-4"></ul>
          </div>
          <div class="pt-4 border-t border-white/10">
            <p class="text-xs uppercase tracking-widest text-purple-300/80 mb-2">Tu camino</p>
            <p id="result-path" class="text-sm text-white/80 italic leading-relaxed"></p>
          </div>
          <ReadingPaywallCTA tool="nombre-expression" locale="es" />
        </div>
      </div>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">¿Qué es el número de expresión?</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        El número de expresión (también conocido como número del destino) es una de las cifras fundamentales de la numerología pitagórica. Mientras el <a href="/es/herramientas/camino-de-vida/" class="text-amber-300 hover:underline">camino de vida</a> describe el viaje que recorres, el número de expresión describe las <strong>herramientas con las que naces para recorrerlo</strong>: tus talentos innatos, tu vocación natural, la misión que trae tu vibración original.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Cómo se calcula</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        El método pitagórico asigna un número del 1 al 9 a cada letra del alfabeto: A=1, B=2, C=3, ..., I=9, J=1, etc. Se suman todos los valores de tu nombre completo de nacimiento y se reduce el total a una sola cifra, salvo cuando aparecen los números maestros 11, 22 o 33, que se conservan.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Significado breve de cada número</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>1 El Pionero</strong>: liderazgo, originalidad, independencia.</li>
        <li><strong>2 El Diplomático</strong>: sensibilidad, cooperación, mediación.</li>
        <li><strong>3 El Artista</strong>: expresión, creatividad, carisma.</li>
        <li><strong>4 El Constructor</strong>: disciplina, estructura, fiabilidad.</li>
        <li><strong>5 El Aventurero</strong>: libertad, cambio, versatilidad.</li>
        <li><strong>6 El Cuidador</strong>: responsabilidad, amor, servicio.</li>
        <li><strong>7 El Buscador</strong>: sabiduría, introspección, espiritualidad.</li>
        <li><strong>8 El Estratega</strong>: poder, abundancia, organización.</li>
        <li><strong>9 El Humanitario</strong>: compasión, visión universal, cierre de ciclos.</li>
        <li><strong>11 El Visionario</strong>: intuición elevada, inspiración.</li>
        <li><strong>22 El Maestro Constructor</strong>: realización material a gran escala.</li>
        <li><strong>33 El Maestro Sanador</strong>: amor incondicional al servicio del mundo.</li>
      </ul>

      <h2 class="font-serif text-3xl mb-4 mt-10">Expresión, alma y personalidad</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        El número de expresión se construye con todas las letras del nombre. A partir de él, la numerología deriva dos cifras complementarias: el <strong>número del alma</strong> (solo vocales: lo que deseas en el fondo) y el <strong>número de la personalidad</strong> (solo consonantes: cómo te perciben los demás). Los tres juntos forman tu firma numerológica.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Por qué usar el nombre de nacimiento</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        La tradición pitagórica sostiene que el primer nombre dado al nacer carga la vibración original con la que llegas al mundo. Cambiar de apellido al casarte, usar un apodo o un nombre artístico añade vibraciones secundarias, pero no reemplaza tu número de expresión nativo. Es el código madre.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Fuentes autorizadas</h2>
      <ul class="text-white/80 space-y-1 mb-4 list-disc pl-5">
        <li><a href="https://es.wikipedia.org/wiki/Numerolog%C3%ADa" class="text-amber-300 hover:underline" rel="external">Numerología - Wikipedia</a></li>
        <li><a href="https://www.britannica.com/topic/numerology" class="text-amber-300 hover:underline" rel="external">Numerology - Britannica</a></li>
        <li><a href="https://es.wikipedia.org/wiki/Pit%C3%A1goras" class="text-amber-300 hover:underline" rel="external">Pitágoras - Wikipedia</a></li>
      </ul>
    </section>

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center mb-10">
      <h3 class="font-serif text-xl mb-2">¿Quieres tu lectura numerológica completa?</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed max-w-xl mx-auto">
        Camino de vida, expresión, alma, personalidad, año personal, deuda kármica. Pythia, nuestra guía numerológica, los cruza todos en una lectura única.
      </p>
      <a href="https://karmastro.com/oracle/" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity">
        Consultar a Pythia
      </a>
    </div>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/es/herramientas/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Todas las herramientas</a>
      <a href="/es/herramientas/camino-de-vida/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Camino de vida</a>
      <a href="/es/herramientas/ano-personal/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Año personal</a>
      <a href="/es/herramientas/carta-natal/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Carta natal</a>
      <a href="/es/herramientas/ascendente/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Ascendente</a>
      <a href="/es/herramientas/compatibilidad/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Compatibilidad</a>
      <a href="/es/blog/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Horóscopo</a>
      <a href="/es/blog/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Blog</a>
    </nav>
  
    {editorial_expression_number && (
      <ToolEditorial
        intro={editorial_expression_number.intro}
        sections={editorial_expression_number.sections}
        faq={editorial_expression_number.faq}
        sources={editorial_expression_number.sources}
        labels={editorial_expression_number.labels}
        dir="ltr"
      />
    )}
  </article>
</BaseLayout>

<script>
  import { calculateExpression } from "../../../data/numerology-meanings";

  const MEANINGS_ES: Record<number, { title: string; talents: string[]; path: string; summary: string }> = {
    1: { title: "El Original", talents: ["Liderazgo", "Innovación", "Independencia", "Coraje"], path: "Abrir caminos nuevos, emprender proyectos, destacar.", summary: "Tu nombre vibra con energía pionera. Estás aquí para liderar, para originar, para ser el primero. Tu talento es convertir la visión en acción antes de que nadie más vea siquiera la oportunidad." },
    2: { title: "El Conciliador", talents: ["Diplomacia", "Intuición", "Cooperación", "Sensibilidad artística"], path: "Tender puentes, mediar, crear armonía.", summary: "Tu nombre vibra con inteligencia relacional. Lees a las personas como otros leen libros. Tu talento es entretejer personas e ideas sin que nadie note el hilo." },
    3: { title: "El Comunicador", talents: ["Expresión creativa", "Escritura", "Escenario", "Carisma"], path: "Hacer visibles las ideas, entretener, inspirar.", summary: "Tu nombre vibra con un genio expresivo. Las palabras, las imágenes, la música, las historias son tus herramientas. Tu talento es hacer que la gente sienta algo que no sabía que necesitaba sentir." },
    4: { title: "El Arquitecto", talents: ["Disciplina", "Oficio", "Organización", "Solidez"], path: "Construir sistemas y estructuras que perduran.", summary: "Tu nombre vibra con una energía sólida, paciente y fundacional. Construyes lo que otros solo sueñan. Tu talento es convertir el caos en un plano y luego el plano en algo real." },
    5: { title: "El Buscador de Libertad", talents: ["Adaptabilidad", "Comunicación", "Viajes", "Ventas"], path: "Movimiento, variedad, conectar mundos.", summary: "Tu nombre vibra con una curiosidad inquieta. Floreces en movimiento. Tu talento es traducir entre culturas, sistemas o ideas que normalmente nunca se encuentran." },
    6: { title: "El Cuidador", talents: ["Enseñanza", "Sanación", "Acompañamiento", "Crear belleza"], path: "Nutrir, proteger, embellecer.", summary: "Tu nombre vibra con responsabilidad y amor. La gente te trae sus problemas porque algo en ti se mantiene firme. Tu talento es hacer que los demás se sientan en casa." },
    7: { title: "El Místico", talents: ["Análisis profundo", "Investigación", "Espiritualidad", "Maestría"], path: "Descubrir verdades ocultas, transmitir sabiduría.", summary: "Tu nombre vibra con la energía del buscador. Siempre vas más allá de la superficie. Tu talento es encontrar patrones que nadie más percibe y expresarlos con claridad." },
    8: { title: "El Ejecutivo", talents: ["Visión de negocio", "Liderazgo", "Estrategia", "Maestría financiera"], path: "Crear riqueza e influencia, organizar a gran escala.", summary: "Tu nombre vibra con maestría material. Entiendes el poder sin dejarte corromper por él. Tu talento es convertir la visión en infraestructura y la infraestructura en legado." },
    9: { title: "El Humanitario", talents: ["Compasión", "Enseñanza", "Arte", "Pensamiento global"], path: "Servir al colectivo, inspirar con el ejemplo.", summary: "Tu nombre vibra con la sabiduría de un alma antigua. Ves más allá de las fronteras de la tribu, hacia el todo. Tu talento es servir a causas más grandes que tú sin perder tu propio centro." },
    11: { title: "El Iluminador (Número Maestro)", talents: ["Visión espiritual", "Inspiración", "Visión de futuro", "Magnetismo"], path: "Despertar a los demás con tu presencia y tu ejemplo.", summary: "Tu nombre vibra con el número maestro 11, un 2 duplicado. Eres un canal para la inspiración. Tu talento es entrar en una sala y cambiar la energía sin decir una palabra." },
    22: { title: "El Maestro Constructor", talents: ["Pragmatismo visionario", "Proyectos de gran escala", "Liderazgo", "Resistencia"], path: "Convertir grandes visiones en una realidad duradera.", summary: "Tu nombre vibra con el número maestro 22, un 4 duplicado. Estás aquí para construir a gran escala. Tu talento es tomar sueños imposibles y convertirlos en sistemas que funcionan." },
    33: { title: "El Maestro Sanador", talents: ["Amor incondicional", "Sanación", "Enseñanza", "Servicio desinteresado"], path: "Sanar el mundo a través de una enseñanza compasiva.", summary: "Tu nombre vibra con el número maestro 33, el más raro de todos. Estás aquí para amar sin condiciones y enseñar sin ego. Tu talento es la presencia misma." },
  };

  const form = document.getElementById("expr-form") as HTMLFormElement;
  const resultDiv = document.getElementById("result") as HTMLDivElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const name = (document.getElementById("full-name") as HTMLInputElement).value;
    if (!name.trim()) return;
    const result = calculateExpression(name);
    const meaning = MEANINGS_ES[result.number] || MEANINGS_ES[1];
    (document.getElementById("result-number") as HTMLElement).textContent = String(result.number);
    (document.getElementById("result-title") as HTMLElement).textContent = meaning.title;
    (document.getElementById("result-letters") as HTMLElement).textContent = result.letters;
    (document.getElementById("result-calc") as HTMLElement).textContent = result.calculation;
    (document.getElementById("result-summary") as HTMLElement).textContent = meaning.summary;
    (document.getElementById("result-talents") as HTMLElement).innerHTML = meaning.talents.map((t) => `<li>✦ ${t}</li>`).join("");
    (document.getElementById("result-path") as HTMLElement).textContent = meaning.path;
    resultDiv.classList.remove("hidden");
    resultDiv.scrollIntoView({ behavior: "smooth", block: "start" });
  });
</script>
