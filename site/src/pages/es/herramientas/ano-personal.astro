---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ToolEditorial from "../../../components/ToolEditorial.astro";
import ReadingPaywallCTA from "../../../components/ReadingPaywallCTA.astro";
import { getToolEditorial } from "../../../data/tool-editorials";
const editorial_personal_year = getToolEditorial("personal-year", "es");
const currentYear = 2026;

const title = "Calculadora del Año Personal - Numerología del año | Karmastro";
const description =
  "Calcula tu año personal gratis. Cada año carga un tema numerológico específico del ciclo 1 al 9. Descubre la energía de tu año en curso y alinea tus decisiones.";

const jsonLd = [
  {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://karmastro.com/es/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Herramientas",
      "item": "https://karmastro.com/es/herramientas"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Año personal",
      "item": "https://karmastro.com/es/herramientas/ano-personal"
    }
  ]
},
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Calculadora del Año Personal",
    description,
    url: "https://karmastro.com/es/herramientas/ano-personal",
    applicationCategory: "UtilitiesApplication",
    operatingSystem: "Any",
    inLanguage: "es",
    offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
    aggregateRating: { "@type": "AggregateRating", ratingValue: "4.8", ratingCount: "267" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      { "@type": "Question", name: "¿Qué es un año personal?", acceptedAnswer: { "@type": "Answer", text: "El año personal es un número del 1 al 9 (a veces 11, 22 o 33) que describe la energía numerológica del año que estás viviendo. Forma parte de un ciclo de 9 años que se repite a lo largo de la vida y marca siembras, cosechas y cierres." } },
      { "@type": "Question", name: "¿Cómo se calcula?", acceptedAnswer: { "@type": "Answer", text: "Suma el día de tu nacimiento, el mes de tu nacimiento y el año en curso (no el año de nacimiento). Reduce el total a una sola cifra, salvo si obtienes 11, 22 o 33, que son números maestros y no se reducen." } },
      { "@type": "Question", name: "¿Cuándo empieza el año personal?", acceptedAnswer: { "@type": "Answer", text: "La mayoría de los numerólogos lo hacen comenzar el 1 de enero, alineado con el año civil. Otros prefieren tu cumpleaños como punto de arranque. Ambas escuelas tienen lógica, elige la que resuene contigo." } },
      { "@type": "Question", name: "¿Qué hacer en cada año?", acceptedAnswer: { "@type": "Answer", text: "Año 1: sembrar. Año 2: cultivar relaciones. Año 3: expresarte. Año 4: construir. Año 5: cambiar. Año 6: responsabilizarte. Año 7: introspección. Año 8: cosechar. Año 9: cerrar y soltar." } },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/es/" class="hover:text-amber-300">Inicio</a>
      <span class="mx-2">/</span>
      <a href="/es/herramientas/" class="hover:text-amber-300">Herramientas</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">Año personal</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Numerología Pitagórica</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Calculadora del Año Personal</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        Cada año carga un tema numerológico. Descubre el tuyo y alinéate con su energía en lugar de remar en contra.
      </p>
    </header>

    <aside data-speakable class="max-w-2xl mx-auto mb-10 p-5 md:p-6 rounded-2xl border border-amber-300/25 bg-gradient-to-br from-amber-300/[0.06] to-purple-400/[0.04]">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">En breve</p>
      <p class="text-[15px] md:text-base text-white/90 leading-relaxed">
        Tu <strong>número de año personal</strong> es el tema numerológico que colorea los 12 meses de un año determinado para ti. Se calcula sumando tu día, mes de nacimiento y el año universal en curso, luego reduciendo a una cifra de 1 a 9. El ciclo de 9 años se repite toda la vida: el año 1 planta, el año 5 gira, el año 9 cierra. Esta calculadora gratis te devuelve tu tema anual actual en segundos desde tu fecha de nacimiento.
      </p>
    </aside>

    <div id="calculator" class="p-6 md:p-8 rounded-3xl border border-amber-300/20 bg-amber-300/5 mb-10">
      <form id="py-form" class="space-y-4">
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label for="birth-date" class="block text-sm font-medium text-white/80 mb-2">Tu fecha de nacimiento</label>
            <input type="date" id="birth-date" required class="w-full px-4 py-3 rounded-xl bg-[#0f0a1e]/50 border border-white/10 text-white focus:border-amber-300 focus:outline-none transition-colors" />
          </div>
          <div>
            <label for="target-year" class="block text-sm font-medium text-white/80 mb-2">Año a analizar</label>
            <input type="number" id="target-year" value={currentYear} min="1900" max="2100" required class="w-full px-4 py-3 rounded-xl bg-[#0f0a1e]/50 border border-white/10 text-white focus:border-amber-300 focus:outline-none transition-colors" />
          </div>
        </div>
        <button type="submit" class="w-full px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold hover:opacity-90 transition-opacity">
          Calcular mi año personal
        </button>
      </form>

      <div id="result" class="mt-6 hidden">
        <div class="p-6 rounded-2xl bg-[#0f0a1e]/60 border border-amber-300/30">
          <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">Tu año personal <span id="result-year" class="text-white"></span></p>
          <div class="flex items-baseline gap-4 mb-4">
            <span id="result-number" class="text-7xl font-serif text-amber-300"></span>
            <span id="result-title" class="text-xl font-serif text-white/90"></span>
          </div>
          <p class="text-xs text-white/50 mb-1">Tema: <span id="result-theme" class="text-amber-300/80"></span></p>
          <p class="text-xs text-white/50 mb-4">Cálculo: <span id="result-calc" class="text-white/70"></span></p>
          <p id="result-summary" class="text-white/80 leading-relaxed mb-6"></p>
          <div class="grid md:grid-cols-2 gap-4 mb-4">
            <div>
              <p class="text-xs uppercase tracking-widest text-emerald-300/80 mb-2">En qué concentrarte</p>
              <ul id="result-focus" class="text-sm text-white/70 space-y-1"></ul>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-pink-300/80 mb-2">Qué conviene evitar</p>
              <ul id="result-avoid" class="text-sm text-white/70 space-y-1"></ul>
            </div>
          </div>
          <div class="pt-4 border-t border-white/10">
            <p class="text-xs uppercase tracking-widest text-purple-300/80 mb-2">Meses más favorables</p>
            <p id="result-months" class="text-sm text-white/80"></p>
          </div>
          <ReadingPaywallCTA tool="annee-personnelle" locale="es" />
        </div>
      </div>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">El ciclo de nueve años</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        La numerología pitagórica considera que la vida avanza en ciclos de nueve años. Cada año, tu número personal progresa de 1 a 9 y vuelve a empezar. Saber en qué año estás te permite elegir mejor tus acciones: sembrar en un año 1, construir en un año 4, soltar en un año 9.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Cómo calcular tu año personal</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        Suma tu día de nacimiento + tu mes de nacimiento + el <strong>año en curso</strong> (no tu año de nacimiento). Reduce a una sola cifra. Ejemplo para alguien nacido el 12 de marzo en 2026: 1+2+3+2+0+2+6 = 16 → 1+6 = 7. Año personal 7.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Los nueve temas</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>Año 1 · Siembra</strong>: nuevos comienzos, decisiones fundacionales.</li>
        <li><strong>Año 2 · Relaciones</strong>: paciencia, alianzas, colaboración.</li>
        <li><strong>Año 3 · Expresión</strong>: creatividad, comunicación, visibilidad.</li>
        <li><strong>Año 4 · Construcción</strong>: disciplina, cimientos sólidos.</li>
        <li><strong>Año 5 · Cambio</strong>: libertad, movimiento, nuevas experiencias.</li>
        <li><strong>Año 6 · Responsabilidad</strong>: familia, servicio, compromisos.</li>
        <li><strong>Año 7 · Introspección</strong>: pausa, estudio, espiritualidad.</li>
        <li><strong>Año 8 · Cosecha</strong>: logros materiales, poder, abundancia.</li>
        <li><strong>Año 9 · Cierre</strong>: soltar, completar, preparar un nuevo ciclo.</li>
      </ul>

      <h2 class="font-serif text-3xl mb-4 mt-10">El año personal dentro de tu camino de vida</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        El año personal cobra más sentido combinado con tu <a href="/es/herramientas/camino-de-vida/" class="text-amber-300 hover:underline">camino de vida</a>. Un año 5 (cambio) vivido por un camino 4 (estructura) crea tensión productiva. Un año 8 (cosecha) para un camino 8 amplifica la energía al máximo. La lectura completa cruza varias capas numerológicas.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Transición de un año al siguiente</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        La vibración del nuevo año personal no aparece el 1 de enero como un interruptor. Empieza a sentirse a partir de octubre del año anterior y domina plenamente desde tu cumpleaños. Aprovecha ese preludio para prepararte: liquida lo pendiente del ciclo anterior antes de abrir el siguiente.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Fuentes autorizadas</h2>
      <ul class="text-white/80 space-y-1 mb-4 list-disc pl-5">
        <li><a href="https://es.wikipedia.org/wiki/Numerolog%C3%ADa" class="text-amber-300 hover:underline" rel="external">Numerología - Wikipedia</a></li>
        <li><a href="https://www.britannica.com/topic/numerology" class="text-amber-300 hover:underline" rel="external">Numerology - Britannica</a></li>
        <li><a href="https://es.wikipedia.org/wiki/Pit%C3%A1goras" class="text-amber-300 hover:underline" rel="external">Pitágoras - Wikipedia</a></li>
      </ul>
    </section>

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center mb-10">
      <h3 class="font-serif text-xl mb-2">¿Quieres la lectura completa del año?</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed max-w-xl mx-auto">
        Cruza tu año personal, tu camino de vida, tu número de expresión y el calendario astrológico con Pythia.
      </p>
      <a href="https://karmastro.com/oracle/" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity">
        Abrir el Oráculo
      </a>
    </div>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/es/herramientas/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Todas las herramientas</a>
      <a href="/es/herramientas/camino-de-vida/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Camino de vida</a>
      <a href="/es/herramientas/numero-expresion/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Número de expresión</a>
      <a href="/es/herramientas/carta-natal/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Carta natal</a>
      <a href="/es/herramientas/ascendente/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Ascendente</a>
      <a href="/es/herramientas/compatibilidad/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Compatibilidad</a>
      <a href="/es/blog/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Horóscopo</a>
      <a href="/es/blog/" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Blog</a>
    </nav>
  
    {editorial_personal_year && (
      <ToolEditorial
        intro={editorial_personal_year.intro}
        sections={editorial_personal_year.sections}
        faq={editorial_personal_year.faq}
        sources={editorial_personal_year.sources}
        labels={editorial_personal_year.labels}
        dir="ltr"
      />
    )}
  </article>
</BaseLayout>

<script>
  import { calculatePersonalYear } from "../../../data/numerology-meanings";

  type PY = { title: string; theme: string; summary: string; focus: string[]; avoid: string[]; months: string };
  const MEANINGS_ES: Record<number, PY> = {
    1: { title: "Año 1: El gran comienzo", theme: "Nuevo ciclo de 9 años", summary: "Es el inicio de un ciclo de 9 años. Plantas las semillas de lo que crecerá hasta el año 9. Todo lo que empieces ahora tiene un alcance amplificado. Toma iniciativas, aunque sean pequeñas.", focus: ["Lanzar un nuevo proyecto", "Tomar decisiones", "Afirmarte", "Renovar tu identidad"], avoid: ["El inmovilismo", "Quedarte en la sombra", "Posponer"], months: "Marzo, junio, octubre" },
    2: { title: "Año 2: Paciencia y vínculos", theme: "Consolidación de relaciones", summary: "Año suave que pide paciencia. Ya no empujas, dejas madurar. Las relaciones pasan al frente: amistades profundas, amor, colaboraciones. Evita forzar las cosas.", focus: ["Cultivar las relaciones", "Escuchar", "Esperar", "Cuidar los detalles"], avoid: ["La precipitación", "El conflicto frontal", "Las decisiones impulsivas"], months: "Febrero, mayo, septiembre" },
    3: { title: "Año 3: Expresión y alegría", theme: "Creatividad y comunicación", summary: "Año solar, ligero, creativo. Es el año ideal para escribir, hablar, crear, mostrarte. Irradias de forma natural y las ocasiones sociales se multiplican. Disfruta, pero no te disperses demasiado.", focus: ["Crear", "Comunicar", "Viajar", "Divertirte con inteligencia"], avoid: ["La dispersión", "La superficialidad", "Los gastos compulsivos"], months: "Marzo, julio, diciembre" },
    4: { title: "Año 4: Construcción y disciplina", theme: "Trabajo metódico", summary: "Año de esfuerzo y estructura. Construyes piedra a piedra. No es el año más glamuroso, pero es el que crea los cimientos sólidos de los ciclos siguientes. Disciplina y perseverancia.", focus: ["Estructurar", "Ahorrar", "Trabajar duro", "Construir a largo plazo"], avoid: ["La rutina apagada", "Los atajos", "La rigidez excesiva"], months: "Abril, agosto, enero" },
    5: { title: "Año 5: Cambio y libertad", theme: "Movimiento y transformación", summary: "Año de movimiento. Cambios, viajes, imprevistos, oportunidades nuevas. Todo se mueve, a veces demasiado rápido. Tu misión es aprovechar las aperturas sin perder tu centro.", focus: ["Viajar", "Cambiar lo que deba cambiar", "Asumir riesgos calculados", "Abrirte"], avoid: ["La inestabilidad caótica", "Las adicciones", "La huida"], months: "Mayo, septiembre, febrero" },
    6: { title: "Año 6: Responsabilidad y amor", theme: "Familia y compromiso", summary: "Año en que las responsabilidades familiares, afectivas y domésticas pasan al frente. Ideal para comprometerte, casarte, fundar una familia, crear un hogar. Cuida no olvidarte de ti al cuidar de los demás.", focus: ["Comprometerte", "Cuidar", "Crear un hogar", "Resolver conflictos familiares"], avoid: ["El sacrificio excesivo", "La posesividad", "La intromisión"], months: "Junio, septiembre, marzo" },
    7: { title: "Año 7: Introspección y sabiduría", theme: "Retiro y profundización", summary: "Año más solitario, más interior. Es el momento de estudiar, meditar, buscar. Evita las grandes decisiones precipitadas. Es una pausa fecunda antes del año 8 de realización material.", focus: ["Estudiar", "Meditar", "Recargarte", "Profundizar en la espiritualidad"], avoid: ["El aislamiento tóxico", "Las decisiones precipitadas", "El cinismo"], months: "Julio, octubre, enero" },
    8: { title: "Año 8: Poder y cosecha material", theme: "Logro financiero y profesional", summary: "Año de cosecha. Lo que sembraste desde el año 1 vuelve amplificado. Ideal para los grandes proyectos profesionales, las inversiones, los reconocimientos públicos. Año exigente pero gratificante.", focus: ["Invertir", "Negociar", "Firmar grandes contratos", "Construir tu autoridad"], avoid: ["El materialismo puro", "El autoritarismo", "El agotamiento por exceso de ambición"], months: "Agosto, noviembre, marzo" },
    9: { title: "Año 9: Fin de ciclo y soltar", theme: "Compleción y transmisión", summary: "Año de cierre. Cierras un ciclo de 9 años. Es el momento de terminar lo pendiente, perdonar, transmitir, dar. Año emocional y reflexivo. Deja partir lo que debe partir para poder renacer en el año 1.", focus: ["Concluir", "Transmitir", "Perdonar", "Hacer balance"], avoid: ["Empezar nuevos grandes proyectos", "Aferrarte", "Los arrepentimientos"], months: "Septiembre, diciembre, abril" },
  };

  const form = document.getElementById("py-form") as HTMLFormElement;
  const resultDiv = document.getElementById("result") as HTMLDivElement;
  const $ = (id: string) => document.getElementById(id) as HTMLElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const dateStr = (document.getElementById("birth-date") as HTMLInputElement).value;
    const yearVal = parseInt((document.getElementById("target-year") as HTMLInputElement).value, 10);
    if (!dateStr || !yearVal) return;
    const [, m, d] = dateStr.split("-").map(Number);
    const result = calculatePersonalYear(d, m, yearVal);
    const meaning = MEANINGS_ES[result.number] || MEANINGS_ES[9];

    $("result-year").textContent = String(yearVal);
    $("result-number").textContent = String(result.number);
    $("result-title").textContent = meaning.title;
    $("result-theme").textContent = meaning.theme;
    $("result-calc").textContent = result.calculation.replace(/jour/g, "día").replace(/mois/g, "mes").replace(/année/g, "año");
    $("result-summary").textContent = meaning.summary;
    $("result-focus").innerHTML = meaning.focus.map((q) => `<li>✦ ${q}</li>`).join("");
    $("result-avoid").innerHTML = meaning.avoid.map((c) => `<li>◆ ${c}</li>`).join("");
    $("result-months").textContent = meaning.months;

    resultDiv.classList.remove("hidden");
    resultDiv.scrollIntoView({ behavior: "smooth", block: "start" });
  });
</script>
