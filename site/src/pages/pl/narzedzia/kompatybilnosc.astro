---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const title = "Kalkulator Kompatybilności Zodiakalnej Darmowy | Karmastro";
const description =
  "Darmowa kompatybilność zodiakalna: miłość, przyjaźń, praca i karmiczna więź między dwoma znakami. Na bazie żywiołów, cech i aspektów planetarnych.";

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebApplication", name: "Kalkulator Kompatybilności", description, url: "https://karmastro.com/pl/narzedzia/kompatybilnosc", applicationCategory: "UtilitiesApplication", inLanguage: "pl", offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" }, aggregateRating: { "@type": "AggregateRating", ratingValue: "4.8", ratingCount: "198" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: [
    { "@type": "Question", name: "Jak działa kompatybilność?", acceptedAnswer: { "@type": "Answer", text: "Analizuje żywioły (ogień, ziemia, powietrze, woda), cechy (kardynalny, stały, zmienny) i planety władające dwóch znaków." } },
    { "@type": "Question", name: "Czy wystarczy znak słoneczny?", acceptedAnswer: { "@type": "Answer", text: "Nie. Prawdziwa kompatybilność krzyżuje Słońce, Księżyc, Wenus, Marsa i Ascendent obu osób." } },
    { "@type": "Question", name: "Czy przeciwieństwa się przyciągają?", acceptedAnswer: { "@type": "Answer", text: "Tak i nie. Przeciwne znaki dzielą oś i są stworzone do uzupełniania, ale wymagają świadomej pracy." } },
    { "@type": "Question", name: "Które znaki są najbardziej kompatybilne?", acceptedAnswer: { "@type": "Answer", text: "Znaki tego samego żywiołu mają naturalne pokrewieństwo. Komplementarne żywioły też działają: ogień i powietrze, ziemia i woda." } },
  ] },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/pl" class="hover:text-amber-300">Strona główna</a><span class="mx-2">/</span>
      <a href="/pl/narzedzia" class="hover:text-amber-300">Narzędzia</a><span class="mx-2">/</span>
      <span class="text-white/80">Kompatybilność</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Astrologia Relacyjna</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Kompatybilność Zodiakalna Darmowa</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">Które znaki naprawdę pasują? Kalkulator krzyżuje żywioły, cechy, planety władające i aspekty.</p>
    </header>

    <div class="p-8 md:p-10 rounded-3xl border border-pink-300/30 bg-gradient-to-br from-pink-300/10 to-purple-400/10 mb-10 text-center">
      <div class="text-5xl mb-4">♥</div>
      <h2 class="text-2xl md:text-3xl font-serif text-white mb-3">Odkryjcie waszą prawdziwą zgodność</h2>
      <a href="https://app.karmastro.com/oracle?lang=pl" class="inline-block px-6 py-3 rounded-xl bg-gradient-to-r from-pink-400 to-purple-400 text-white font-semibold hover:opacity-90 transition-opacity">Obliczyć kompatybilność</a>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">Logika kompatybilności</h2>
      <p class="text-white/80 leading-relaxed mb-4">Cztery warstwy połączone dają subtelną interpretację: żywioły, cechy, planety władające i aspekty między astrami osobistymi.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Cztery żywioły</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>Ogień</strong> (Baran, Lew, Strzelec): pasja, działanie.</li>
        <li><strong>Ziemia</strong> (Byk, Panna, Koziorożec): stabilność, pragmatyzm.</li>
        <li><strong>Powietrze</strong> (Bliźnięta, Waga, Wodnik): umysł, słowo.</li>
        <li><strong>Woda</strong> (Rak, Skorpion, Ryby): emocja, głębia.</li>
      </ul>

      <h2 class="font-serif text-3xl mb-4 mt-10">Cechy</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>Kardynalny</strong>: inicjatorzy.</li>
        <li><strong>Stały</strong>: budowniczowie.</li>
        <li><strong>Zmienny</strong>: adaptacyjni.</li>
      </ul>

      <h2 class="font-serif text-3xl mb-4 mt-10">Poza znakiem słonecznym</h2>
      <p class="text-white/80 leading-relaxed mb-4">Prawdziwa kompatybilność krzyżuje Księżyc, Wenus, Marsa, Ascendent. Użyj naszego <a href="/pl/narzedzia/horoskop-natalny" class="text-amber-300 hover:underline">Kalkulatora Horoskopu Natalnego</a>.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Kompatybilność karmiczna</h2>
      <p class="text-white/80 leading-relaxed mb-4">Porównaj też <a href="/pl/narzedzia/liczba-drogi-zycia" class="text-amber-300 hover:underline">drogi życia</a>.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Autorytatywne źródła</h2>
      <ul class="text-white/80 space-y-1 mb-4 list-disc pl-5">
        <li><a href="https://pl.wikipedia.org/wiki/Zodiak" class="text-amber-300 hover:underline" rel="external">Zodiak - Wikipedia</a></li>
        <li><a href="https://www.britannica.com/topic/zodiac" class="text-amber-300 hover:underline" rel="external">Zodiac - Britannica</a></li>
        <li><a href="https://pl.wikipedia.org/wiki/Synastria" class="text-amber-300 hover:underline" rel="external">Synastria - Wikipedia</a></li>
      </ul>
    </section>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/pl/narzedzia" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Wszystkie narzędzia</a>
      <a href="/pl/narzedzia/horoskop-natalny" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Horoskop natalny</a>
      <a href="/pl/narzedzia/wschodzacy-znak" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Ascendent</a>
      <a href="/pl/narzedzia/liczba-drogi-zycia" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Droga życia</a>
      <a href="/pl/narzedzia/liczba-ekspresji" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Liczba ekspresji</a>
      <a href="/pl/narzedzia/rok-osobisty" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Rok osobisty</a>
      <a href="/pl/horoskop" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Horoskop</a>
      <a href="/pl/blog" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Blog</a>
    </nav>
  </article>
</BaseLayout>
