---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const title = "Kalkulator Liczby Ekspresji (Liczba Przeznaczenia) | Karmastro";
const description =
  "Oblicz darmo swoją liczbę ekspresji, zwaną też liczbą przeznaczenia. Ujawnia wrodzone talenty, misję i naturalny kierunek życia. Numerologia pitagorejska.";

const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebApplication", name: "Kalkulator Liczby Ekspresji", description, url: "https://karmastro.com/pl/narzedzia/liczba-ekspresji", applicationCategory: "UtilitiesApplication", inLanguage: "pl", offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" }, aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", ratingCount: "156" } },
  { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: [
    { "@type": "Question", name: "Czym jest liczba ekspresji?", acceptedAnswer: { "@type": "Answer", text: "Liczba obliczana z pełnego imienia i nazwiska z narodzin. Ujawnia wrodzone talenty i życiową misję." } },
    { "@type": "Question", name: "Różnica od drogi życia?", acceptedAnswer: { "@type": "Answer", text: "Droga życia wynika z daty urodzenia i pokazuje podróż. Liczba ekspresji wynika z imienia i pokazuje narzędzia." } },
    { "@type": "Question", name: "Jakie imię?", acceptedAnswer: { "@type": "Answer", text: "Pełne imię z aktu urodzenia, bez ślubnego ani pseudonimu." } },
    { "@type": "Question", name: "Liczby mistrzowskie 11, 22, 33?", acceptedAnswer: { "@type": "Answer", text: "Nie redukują się. 11 intuicja wizjonerska, 22 mistrz budowniczy, 33 mistrz uzdrowiciel." } },
  ] },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/pl" class="hover:text-amber-300">Strona główna</a><span class="mx-2">/</span>
      <a href="/pl/narzedzia" class="hover:text-amber-300">Narzędzia</a><span class="mx-2">/</span>
      <span class="text-white/80">Liczba ekspresji</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Numerologia Pitagorejska</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Kalkulator Liczby Ekspresji</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">Zwana też liczbą przeznaczenia. Ujawnia wrodzone talenty i naturalny kierunek życia.</p>
    </header>

    <div class="p-8 md:p-10 rounded-3xl border border-amber-300/30 bg-gradient-to-br from-amber-300/10 to-purple-400/10 mb-10 text-center">
      <div class="text-5xl mb-4">A</div>
      <a href="https://app.karmastro.com/oracle?lang=pl" class="inline-block px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold hover:opacity-90 transition-opacity">Obliczyć moją liczbę ekspresji</a>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">Czym jest liczba ekspresji?</h2>
      <p class="text-white/80 leading-relaxed mb-4">Jedna z fundamentalnych liczb numerologii pitagorejskiej. Podczas gdy <a href="/pl/narzedzia/liczba-drogi-zycia" class="text-amber-300 hover:underline">droga życia</a> opisuje podróż, liczba ekspresji opisuje <strong>narzędzia</strong>.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Jak obliczyć</h2>
      <p class="text-white/80 leading-relaxed mb-4">Każda litera dostaje cyfrę 1-9: A=1, B=2, ..., I=9, J=1. Sumuj wartości pełnego imienia i zredukuj, z wyjątkiem 11, 22, 33.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Znaczenie liczb</h2>
      <ul class="text-white/80 space-y-2 mb-4 list-disc pl-5">
        <li><strong>1 Pionier</strong>: przywództwo.</li>
        <li><strong>2 Dyplomata</strong>: wrażliwość.</li>
        <li><strong>3 Artysta</strong>: ekspresja.</li>
        <li><strong>4 Budowniczy</strong>: dyscyplina.</li>
        <li><strong>5 Awanturnik</strong>: wolność.</li>
        <li><strong>6 Opiekun</strong>: służba.</li>
        <li><strong>7 Poszukiwacz</strong>: mądrość.</li>
        <li><strong>8 Strateg</strong>: władza.</li>
        <li><strong>9 Humanista</strong>: współczucie.</li>
        <li><strong>11</strong> wizjoner, <strong>22</strong> mistrz budowniczy, <strong>33</strong> mistrz uzdrowiciel.</li>
      </ul>

      <h2 class="font-serif text-3xl mb-4 mt-10">Ekspresja, dusza, osobowość</h2>
      <p class="text-white/80 leading-relaxed mb-4">Z ekspresji wynikają liczba duszy (samogłoski) i osobowości (spółgłoski).</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Dlaczego imię z narodzin</h2>
      <p class="text-white/80 leading-relaxed mb-4">Pierwsze imię niesie oryginalną wibrację. Późniejsze zmiany dodają warstwy, ale nie zastępują.</p>

      <h2 class="font-serif text-3xl mb-4 mt-10">Źródła</h2>
      <ul class="text-white/80 space-y-1 mb-4 list-disc pl-5">
        <li><a href="https://pl.wikipedia.org/wiki/Numerologia" class="text-amber-300 hover:underline" rel="external">Numerologia - Wikipedia</a></li>
        <li><a href="https://www.britannica.com/topic/numerology" class="text-amber-300 hover:underline" rel="external">Numerology - Britannica</a></li>
        <li><a href="https://pl.wikipedia.org/wiki/Pitagoras" class="text-amber-300 hover:underline" rel="external">Pitagoras - Wikipedia</a></li>
      </ul>
    </section>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/pl/narzedzia" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Wszystkie narzędzia</a>
      <a href="/pl/narzedzia/liczba-drogi-zycia" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Droga życia</a>
      <a href="/pl/narzedzia/rok-osobisty" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Rok osobisty</a>
      <a href="/pl/narzedzia/horoskop-natalny" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Horoskop natalny</a>
      <a href="/pl/narzedzia/wschodzacy-znak" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Ascendent</a>
      <a href="/pl/narzedzia/kompatybilnosc" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Kompatybilność</a>
      <a href="/pl/horoskop" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Horoskop</a>
      <a href="/pl/blog" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">Blog</a>
    </nav>
  </article>
</BaseLayout>
