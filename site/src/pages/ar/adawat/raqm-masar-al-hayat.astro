    famousExamples: "ديفيد بوي، هيو جاكمان، أليك بالدوين",
  },
  4: {
    title: "البنّاء",
    archetype: "العامل المنهجي، المهندس، الذي يضع الأسس.",
    summary: "أنت تبني ما يحلم به الآخرون فقط. مسار الحياة 4 هو طريق الاستقرار والبنية والنتائج الدائمة. مهمتك هي إنشاء شيء يعيش بعدك.",
    qualities: ["الانضباط", "الموثوقية", "الصبر", "الولاء", "المهارة العملية"],
