---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-12" dir="rtl">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/ar" class="hover:text-amber-300">الرئيسية</a>
      <span class="mx-2">/</span>
      <a href="/ar/adawat" class="hover:text-amber-300">الأدوات</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">مسار الحياة</span>
    </nav>

    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">علم الأعداد الفيثاغوري</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">حاسبة رقم مسار الحياة</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        رقم مسار حياتك هو الرقم الأهم في علم الأعداد. يكشف عن مهمتك، ومواهبك الفطرية، والدروس الكارمية لهذا الوجود. حساب مجاني، طريقة فيثاغورية شفافة، تفسير كامل.
      </p>
    </header>

    <div id="calculator" class="p-6 md:p-8 rounded-3xl border border-amber-300/20 bg-amber-300/5 mb-10">
      <form id="life-path-form" class="space-y-4">
        <div>
          <label for="birth-date" class="block text-sm font-medium text-white/80 mb-2">تاريخ ميلادك</label>
          <input type="date" id="birth-date" name="birth-date" required class="w-full px-4 py-3 rounded-xl bg-[#0f0a1e]/50 border border-white/10 text-white focus:border-amber-300 focus:outline-none transition-colors" />
        </div>
        <button type="submit" class="w-full px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold hover:opacity-90 transition-opacity">
          احسب رقم مسار حياتي
        </button>
      </form>

      <div id="result" class="mt-6 hidden">
        <div class="p-6 rounded-2xl bg-[#0f0a1e]/60 border border-amber-300/30">
          <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">رقم مسار حياتك</p>
          <div class="flex items-baseline gap-4 mb-4">
            <span id="result-number" class="text-7xl font-serif text-amber-300"></span>
            <span id="result-title" class="text-xl font-serif text-white/90"></span>
          </div>
          <p class="text-xs text-white/50 mb-4">الحساب: <span id="result-calc" class="text-white/70"></span></p>
          <p id="result-summary" class="text-white/80 leading-relaxed mb-6"></p>
          <div class="grid md:grid-cols-2 gap-4 mb-4">
            <div>
              <p class="text-xs uppercase tracking-widest text-emerald-300/80 mb-2">نقاط القوة</p>
              <ul id="result-qualities" class="text-sm text-white/70 space-y-1"></ul>
            </div>
            <div>
              <p class="text-xs uppercase tracking-widest text-pink-300/80 mb-2">التحديات</p>
              <ul id="result-challenges" class="text-sm text-white/70 space-y-1"></ul>
            </div>
          </div>
          <div class="pt-4 border-t border-white/10">
            <p class="text-xs uppercase tracking-widest text-purple-300/80 mb-2">المهمة</p>
            <p id="result-mission" class="text-sm text-white/80 italic leading-relaxed"></p>
          </div>
          <div class="mt-6 pt-4 border-t border-white/10 text-center">
            <a href="https://app.karmastro.com/oracle?lang=ar" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium text-sm hover:opacity-90 transition-opacity">
              تعمق مع العراف
            </a>
          </div>
        </div>
      </div>
    </div>

    <section class="prose prose-invert max-w-none mb-10">
      <h2 class="font-serif text-3xl mb-4">ما هو رقم مسار الحياة؟</h2>
      <p class="text-white/80 leading-relaxed mb-4">
        <strong>رقم مسار حياتك</strong> هو الرقم المركزي في علم الأعداد الفيثاغوري. محسوبًا من تاريخ ميلادك، يكشف عن المهمة الأساسية لوجودك. فكر فيه على أنه المعادل العددي لعلامة الشمس في علم التنجيم: الاهتزاز الأساسي الذي يلون كل ما تفعله، النموذج الأولي الذي جئت لتجسده.
      </p>
      <p class="text-white/80 leading-relaxed mb-4">
        بالنسبة لـ<strong>فيثاغورس</strong> وتلاميذه في القرن السادس قبل الميلاد، كان كل رقم يحمل اهتزازًا فريدًا، توقيعًا للطاقة. الأرقام من 1 إلى 9 تغطي جميع النماذج الأولية البشرية. الأرقام الرئيسية 11 و22 و33 تحمل ترددًا أندر وأكثر تطلبًا.
      </p>

      <h2 class="font-serif text-3xl mb-4 mt-10">كيفية حساب رقم مسار حياتك</h2>
      <div class="p-5 rounded-xl bg-white/[0.03] border border-white/10 mb-6 not-prose">
        <p class="text-sm text-white/90 mb-3"><strong>مثال: 14 أبريل 1992</strong></p>
        <ul class="text-sm text-white/70 space-y-1">
          <li>اليوم: 1 + 4 = 5</li>
          <li>الشهر: 4 = 4</li>
          <li>السنة: 1 + 9 + 9 + 2 = 21 ← 2 + 1 = 3</li>
          <li>المجموع: 5 + 4 + 3 = <strong class="text-amber-300">12 ← 1 + 2 = 3</strong></li>
        </ul>
        <p class="text-sm text-white/60 mt-3">رقم مسار الحياة = 3 (الفنانة)</p>
      </div>

      <h2 class="font-serif text-3xl mb-4 mt-10">9 مسارات الحياة (و3 أرقام رئيسية)</h2>
      <div class="not-prose grid md:grid-cols-2 gap-3 mb-8">
        {DISPLAY_ORDER.map((n) => {
          const meaning = MEANINGS[n];
          return (
            <div class="p-4 rounded-xl border border-white/10 bg-white/[0.02]">
              <div class="flex items-baseline gap-3 mb-2">
                <span class="text-3xl font-serif text-amber-300">{n}</span>
                <span class="text-sm text-white/80 font-medium">{meaning.title}</span>
              </div>
              <p class="text-xs text-white/60 leading-relaxed">{meaning.archetype}</p>
            </div>
          );
        })}
      </div>
    </section>

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center mb-10">
      <h3 class="font-serif text-xl mb-2">هل تريد قراءة كاملة؟</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed max-w-xl mx-auto">
        رقم مسار الحياة هو البداية فقط. لعبور أرقام علم الأعداد الخمسة مع خريطة ميلادك الكاملة وتلقي إرشاد شخصي، تحدث مع أحد مرشدينا الكونيين الأربعة.
      </p>
      <a href="https://app.karmastro.com/oracle?lang=ar" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity">
        استشر العراف مجانًا
      </a>
    </div>

    <nav class="flex flex-wrap gap-2 justify-center pt-6 border-t border-white/10 text-sm">
      <a href="/ar/adawat" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">← جميع الأدوات</a>
      <a href="/ar/adawat/al-taaali" class="px-3 py-1.5 rounded-full border border-white/10 hover:border-amber-300/40 hover:text-amber-300 transition-colors">الطالع</a>
    </nav>
  </article>
</BaseLayout>

<script>
  import { calculateLifePath } from "../../../data/numerology-meanings";

  const MEANINGS_AR: Record<number, { title: string; summary: string; qualities: string[]; challenges: string[]; mission: string }> = {
    1: { title: "الرائد", summary: "لقد ولدت لتقود، لا لتتبع. مسار الحياة 1 يحمل الطاقة النقية للمبادرة.", qualities: ["القيادة الطبيعية", "الاستقلالية", "الطموح", "الشجاعة", "الأصالة"], challenges: ["الأنانية", "نفاد الصبر", "الوحدة", "السلطوية", "الجمود"], mission: "تعلم أن تقود دون أن تسحق." },
    2: { title: "الدبلوماسية", summary: "أنت تشعر بالطاقات كما يسمع الآخرون الأصوات. مسار الحياة 2 هو طريق السلام والانسجام والاتحاد.", qualities: ["الدبلوماسية", "الحساسية", "التعاطف", "الصبر", "التعاون"], challenges: ["الاعتماد العاطفي", "التردد", "فرط الحساسية", "تجنب الصراع", "الخضوع"], mission: "افهمي أن اللطف قوة، لا ضعف." },
    3: { title: "الفنانة", summary: "أنت تحولين كل شيء إلى لون أو كلمات أو موسيقى. مسار الحياة 3 هو طريق التعبير الإبداعي.", qualities: ["الإبداع", "التواصل", "التفاؤل", "الكاريزما", "الفرح"], challenges: ["التشتت", "السطحية", "الثرثرة", "عدم النضج العاطفي", "الهروب"], mission: "تعلمي أن العمق لا يقتل الفرح." },
    4: { title: "البنّاء", summary: "أنت تبني ما يحلم به الآخرون فقط. مسار الحياة 4 هو طريق الاستقرار والبنية والنتائج الدائمة.", qualities: ["الانضباط", "الموثوقية", "الصبر", "الولاء", "المهارة العملية"], challenges: ["الجمود", "إدمان العمل", "العناد", "الخوف من التغيير", "الجدية المفرطة"], mission: "تعلم أن البنية تخدم الحرية، لا العكس." },
    5: { title: "المغامرة", summary: "أنت تحتاجين إلى الحرية كما يحتاج الآخرون إلى الهواء. مسار الحياة 5 هو طريق التغيير والتجربة والحرية الشخصية.", qualities: ["الفضول", "القدرة على التكيف", "السحر", "التنوع", "الشجاعة للتغيير"], challenges: ["القلق", "مشاكل الالتزام", "الاندفاع", "ميول الإدمان", "الطاقة المشتتة"], mission: "تعلمي أن الحرية بدون اتجاه مجرد انجراف." },
    6: { title: "الراعي", summary: "أنت تحمل الآخرين كما حمل أطلس العالم. مسار الحياة 6 هو طريق المسؤولية والحب والخدمة.", qualities: ["غريزة الرعاية", "المسؤولية", "الولاء", "القدرة على التعليم", "المواهب الإبداعية"], challenges: ["الاستشهاد", "المشاركة المفرطة", "الكمالية", "التضحية بالذات", "التدخل"], mission: "تعلم أنك لا تستطيع أن تسكب من كوب فارغ." },
    7: { title: "الباحث", summary: "لقد ولدت وأنت تسأل لماذا. مسار الحياة 7 هو طريق الحكمة والتأمل والفهم الروحي.", qualities: ["التفكير العميق", "الحدس", "الاستقلالية", "العقل التحليلي", "الوعي الروحي"], challenges: ["العزلة", "السخرية", "التحليل المفرط", "عدم الثقة", "المسافة العاطفية"], mission: "تعلم أن الحقيقة بدون حب عقيمة." },
    8: { title: "الاستراتيجية", summary: "أنت تفهمين السلطة دون أن تنخدعي بها. مسار الحياة 8 هو طريق الإتقان المادي والوفرة والنفوذ.", qualities: ["القيادة", "الحدس المالي", "المهارات التنظيمية", "القدرة على التحمل", "السلطة"], challenges: ["الجشع", "إدمان العمل", "الحاجة للسيطرة", "المادية", "الترهيب"], mission: "تعلمي أن القوة الحقيقية تُقاس بما تخلقه." },
    9: { title: "الإنساني", summary: "أنت تأتي إلى الحياة وأنت تعرف أشياء يجب على الآخرين تعلمها. مسار الحياة 9 هو طريق الحب الكوني.", qualities: ["الرحمة", "الحكمة", "الحساسية الفنية", "المنظور العالمي", "الكرم"], challenges: ["الانفصال العاطفي", "عقدة المنقذ", "الكآبة", "صعوبة التخلي", "البر الذاتي"], mission: "تعلم أن الاستسلام قوة، لا هزيمة." },
    11: { title: "الرؤيوية (رقم رئيسي)", summary: "لقد ولدت متصلة بتردد أعلى. الرقم الرئيسي 11 يحمل حدسًا مكثفًا.", qualities: ["الحدس الاستثنائي", "التفكير الرؤيوي", "الكاريزما", "المغناطيسية الروحية", "الحضور الملهم"], challenges: ["التوتر العصبي", "فرط الحساسية", "الشك بالنفس", "القلق", "الاستشهاد"], mission: "تعلمي أن حساسيتك هي هديتك، لا جرحك." },
    22: { title: "البنّاء الرئيسي (رقم رئيسي)", summary: "يمكنك تحويل المستحيل إلى خطة. الرقم الرئيسي 22 يجمع الحدس الروحي للرقم 11 مع القوة العملية للرقم 4.", qualities: ["البراغماتية الرؤيوية", "القيادة", "الابتكار", "القدرة على التحمل", "التفكير على نطاق واسع"], challenges: ["الضغط الساحق", "الكمالية", "الإرهاق", "الميول الاستبدادية", "شلل الشك"], mission: "تعلم أن الصبر ليس ضعفًا." },
    33: { title: "المعالج الكوني (رقم رئيسي)", summary: "لقد ولدت بتردد نادر من الحب غير الأناني. الرقم الرئيسي 33 هو أندر مسار حياة.", qualities: ["الحب غير المشروط", "موهبة التعليم", "الشفاء الإبداعي", "التفاني الروحي", "الخدمة المقدسة"], challenges: ["الاستشهاد", "الإرهاق العاطفي", "الكمالية", "نسيان الذات", "المسؤولية الساحقة"], mission: "تعلم أن العطاء من الفراغ ليس عطاءً." },
  };

  const form = document.getElementById("life-path-form") as HTMLFormElement;
  const resultDiv = document.getElementById("result") as HTMLDivElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = document.getElementById("birth-date") as HTMLInputElement;
    const value = input.value;
    if (!value) return;

    const [y, m, d] = value.split("-").map(Number);
    const result = calculateLifePath(d, m, y);
    const meaning = MEANINGS_AR[result.number] || MEANINGS_AR[9];

    (document.getElementById("result-number") as HTMLElement).textContent = String(result.number);
    (document.getElementById("result-title") as HTMLElement).textContent = meaning.title;
    (document.getElementById("result-calc") as HTMLElement).textContent = result.calculation;
    (document.getElementById("result-summary") as HTMLElement).textContent = meaning.summary;

    const qualitiesList = document.getElementById("result-qualities") as HTMLElement;
    qualitiesList.innerHTML = meaning.qualities.map((q) => `<li>✦ ${q}</li>`).join("");

    const challengesList = document.getElementById("result-challenges") as HTMLElement;
    challengesList.innerHTML = meaning.challenges.map((c) => `<li>◆ ${c}</li>`).join("");

    (document.getElementById("result-mission") as HTMLElement).textContent = meaning.mission;

    resultDiv.classList.remove("hidden");
    resultDiv.scrollIntoView({ behavior: "smooth", block: "start" });
  });
</script>
