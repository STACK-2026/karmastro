---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const title = "ライフパスナンバー計算機 - ピタゴラス数秘術 | Karmastro";
const description =
  "ピタゴラス数秘術で自分のライフパスナンバーを無料で計算。あなたの使命、才能、課題、12個の数字（マスター数11、22、33を含む）の意味を発見。";

const MEANINGS: Record<number, { title: string; archetype: string; summary: string; qualities: string[]; challenges: string[]; mission: string; famousExamples: string }> = {
  1: {
    title: "開拓者",
    archetype: "孤独な指導者、始める者、新しい道を開く者。",
    summary: "あなたは従うためではなく、導くために生まれた。ライフパス1は純粋な主導権のエネルギーを運ぶ。あなたが部屋に入ると、何かが変わる。あなたの使命は、その力を支配ではなく創造に変えることだ。",
    qualities: ["生まれながらのリーダーシップ", "独立", "野心", "勇気", "独創性"],
    challenges: ["自己中心性", "短気", "孤独", "権威主義", "硬直性"],
    mission: "押しつぶすことなく導き、固くならずに強くあることを学ぼう。1は新しい地を生み出し、他の人が待っている場所で敢えて行動するためにここにいる。",
    famousExamples: "ナポレオン・ボナパルト、スティーブ・ジョブズ、マーティン・ルーサー・キング・ジュニア",
  },
  2: {
    title: "外交官",
    archetype: "調停者、直感的な人、絆を織る者。",
    summary: "あなたは他の人が音を聞くようにエネルギーを感じる。ライフパス2は平和、調和、結合の道だ。あなたの使命は、この感受性を傷ではなくレーダーとして使うことだ。",
    qualities: ["外交", "感受性", "共感", "忍耐", "協力"],
    challenges: ["感情的依存", "優柔不断", "過敏性", "対立回避", "服従"],
    mission: "優しさは弱さではなく力であることを理解しよう。2は和解するため、他の人が見えないものを見るためにここにいる。",
    famousExamples: "バラク・オバマ、マドンナ、マハトマ・ガンジー",
  },
  3: {
    title: "芸術家",
    archetype: "創造的表現、世界の子供、光を与える者。",
    summary: "あなたはすべてを色、言葉、音楽に変える。ライフパス3は創造的表現の道だ。あなたの使命は、無形のものに形を与え、惜しみなく共有することだ。",
    qualities: ["創造性", "コミュニケーション", "楽観主義", "カリスマ性", "喜び"],
    challenges: ["散漫", "浅薄さ", "噂話", "感情的未熟", "逃避"],
    mission: "深さは喜びを殺さないことを学ぼう。3は表現し、インスピレーションを与え、他の人に世界の美しさを思い出させるためにここにいる。",
    famousExamples: "デヴィッド・ボウイ、ヒュー・ジャックマン、アレック・ボールドウィン",
  },
