<script>
  import { calculateLifePath } from "../../../data/numerology-meanings";

  const MEANINGS_JA: Record<number, { title: string; summary: string; qualities: string[]; challenges: string[]; mission: string }> = {
    1: { title: "開拓者", summary: "あなたは従うためではなく、導くために生まれた。ライフパス1は純粋な主導権のエネルギーを運ぶ。", qualities: ["生まれながらのリーダーシップ", "独立", "野心", "勇気", "独創性"], challenges: ["自己中心性", "短気", "孤独", "権威主義", "硬直性"], mission: "押しつぶすことなく導き、固くならずに強くあることを学ぼう。" },
    2: { title: "外交官", summary: "あなたは他の人が音を聞くようにエネルギーを感じる。ライフパス2は平和、調和、結合の道だ。", qualities: ["外交", "感受性", "共感", "忍耐", "協力"], challenges: ["感情的依存", "優柔不断", "過敏性", "対立回避", "服従"], mission: "優しさは弱さではなく力であることを理解しよう。" },
    3: { title: "芸術家", summary: "あなたはすべてを色、言葉、音楽に変える。ライフパス3は創造的表現の道だ。", qualities: ["創造性", "コミュニケーション", "楽観主義", "カリスマ性", "喜び"], challenges: ["散漫", "浅薄さ", "噂話", "感情的未熟", "逃避"], mission: "深さは喜びを殺さないことを学ぼう。" },
    4: { title: "建設者", summary: "あなたは他の人が夢見るだけのものを築く。ライフパス4は安定性、構造、持続的な結果の道だ。", qualities: ["規律", "信頼性", "忍耐", "忠誠心", "実践的なスキル"], challenges: ["硬直性", "仕事中毒", "頑固さ", "変化への恐れ", "過度の真面目さ"], mission: "構造は自由に奉仕するもので、その逆ではないことを学ぼう。" },
    5: { title: "冒険者", summary: "あなたは他の人が空気を必要とするように自由を必要とする。ライフパス5は変化、経験、個人的自由の道だ。", qualities: ["好奇心", "適応性", "魅力", "多才さ", "変化への勇気"], challenges: ["落ち着きのなさ", "コミットメントの問題", "衝動性", "依存傾向", "散漫なエネルギー"], mission: "方向性のない自由はただの漂流であることを学ぼう。" },
    6: { title: "養育者", summary: "あなたはアトラスが世界を背負ったように他の人を背負う。ライフパス6は責任、愛、奉仕の道だ。", qualities: ["養育の本能", "責任", "忠誠心", "教える能力", "創造的な才能"], challenges: ["殉教", "過度の関与", "完璧主義", "自己犠牲", "干渉"], mission: "空のカップからは注げないことを学ぼう。" },
    7: { title: "探求者", summary: "あなたは「なぜ」と問いながら生まれた。ライフパス7は知恵、内省、霊的理解の道だ。", qualities: ["深い思考", "直感", "独立", "分析的精神", "霊的意識"], challenges: ["孤立", "冷笑", "過剰分析", "不信", "感情的距離"], mission: "愛のない真実は不毛であることを学ぼう。" },
    8: { title: "戦略家", summary: "あなたは力に誘惑されることなく力を理解する。ライフパス8は物質的熟達、豊かさ、影響力の道だ。", qualities: ["リーダーシップ", "財政的直感", "組織スキル", "持久力", "権威"], challenges: ["貪欲", "仕事中毒", "支配の必要性", "物質主義", "威圧"], mission: "真の力は支配するものではなく、創造するもので測られることを学ぼう。" },
    9: { title: "人道主義者", summary: "あなたは他の人が学ばなければならないことを知って人生に来る。ライフパス9は普遍的な愛、思いやり、手放しの道だ。", qualities: ["思いやり", "知恵", "芸術的感受性", "グローバルな視点", "寛大さ"], challenges: ["感情的な離脱", "救世主コンプレックス", "憂鬱", "手放すことの難しさ", "自己正当化"], mission: "降伏は敗北ではなく力であることを学ぼう。" },
    11: { title: "預言者（マスター数）", summary: "あなたはより高い周波数につながって生まれた。マスター数11は強烈な直感を運ぶ。", qualities: ["並外れた直感", "預言的思考", "カリスマ性", "霊的な磁気", "インスピレーションの存在"], challenges: ["神経の緊張", "過敏性", "自己疑念", "不安", "殉教"], mission: "あなたの感受性はあなたの傷ではなくあなたの贈り物であることを学ぼう。" },
    22: { title: "マスタービルダー（マスター数）", summary: "あなたは不可能を計画に変えることができる。マスター数22は11の霊的直感と4の実践的な力を組み合わせる。", qualities: ["預言的実用主義", "リーダーシップ", "革新", "持久力", "大規模な思考"], challenges: ["圧倒的なプレッシャー", "完璧主義", "燃え尽き", "独裁的傾向", "疑念による麻痺"], mission: "忍耐は弱さではないことを学ぼう。" },
    33: { title: "宇宙的な癒し手（マスター数）", summary: "あなたは無私の愛の稀な周波数を持って生まれた。マスター数33は最も稀なライフパスだ。", qualities: ["無条件の愛", "教えの才能", "創造的な癒し", "霊的な献身", "神聖な奉仕"], challenges: ["殉教", "感情的な疲労", "完璧主義", "自己忘却", "圧倒的な責任"], mission: "空虚から与えることは与えることではないことを学ぼう。" },
  };

  const form = document.getElementById("life-path-form") as HTMLFormElement;
  const resultDiv = document.getElementById("result") as HTMLDivElement;

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = document.getElementById("birth-date") as HTMLInputElement;
    const value = input.value;
    if (!value) return;

    const [y, m, d] = value.split("-").map(Number);
    const result = calculateLifePath(d, m, y);
    const meaning = MEANINGS_JA[result.number] || MEANINGS_JA[9];

    (document.getElementById("result-number") as HTMLElement).textContent = String(result.number);
    (document.getElementById("result-title") as HTMLElement).textContent = meaning.title;
    (document.getElementById("result-calc") as HTMLElement).textContent = result.calculation;
    (document.getElementById("result-summary") as HTMLElement).textContent = meaning.summary;

    const qualitiesList = document.getElementById("result-qualities") as HTMLElement;
    qualitiesList.innerHTML = meaning.qualities.map((q) => `<li>✦ ${q}</li>`).join("");

    const challengesList = document.getElementById("result-challenges") as HTMLElement;
    challengesList.innerHTML = meaning.challenges.map((c) => `<li>◆ ${c}</li>`).join("");

    (document.getElementById("result-mission") as HTMLElement).textContent = meaning.mission;

    resultDiv.classList.remove("hidden");
    resultDiv.scrollIntoView({ behavior: "smooth", block: "start" });
  });
</script>
