---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ZodiacSymbol from "../../../components/ZodiacSymbol.astro";
import { ZODIAC_SIGNS, formatFrenchDate } from "../../../data/zodiac";
import { LOCALES, DEFAULT_LOCALE, type Locale } from "../../../i18n/config";
import { getContent } from "../../../i18n/content";
import { t } from "../../../i18n/translations";
import fs from "fs";
import path from "path";

export function getStaticPaths() {
  return LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Locale };
const content = getContent(lang);

// Load today's horoscope data (same as main /horoscope)
const dataDir = path.join(process.cwd(), "src/data/horoscope");
let todayData: Record<string, any> = {};
let todayDate = new Date().toISOString().slice(0, 10);
let hasData = false;

try {
  if (fs.existsSync(dataDir)) {
    const files = fs
      .readdirSync(dataDir)
      .filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f))
      .sort();
    if (files.length > 0) {
      const latestFile = files[files.length - 1];
      todayDate = latestFile.replace(".json", "");
      todayData = JSON.parse(fs.readFileSync(path.join(dataDir, latestFile), "utf-8"));
      hasData = true;
    }
  }
} catch (e) {
  console.warn("Horoscope data not available:", e);
}

const dateFormatted = formatFrenchDate(todayDate);

// Sign name mapping : use t("signs.*") based on sign slug
const signNameKeys: Record<string, string> = {
  belier: "signs.aries",
  taureau: "signs.taurus",
  gemeaux: "signs.gemini",
  cancer: "signs.cancer",
  lion: "signs.leo",
  vierge: "signs.virgo",
  balance: "signs.libra",
  scorpion: "signs.scorpio",
  sagittaire: "signs.sagittarius",
  capricorne: "signs.capricorn",
  verseau: "signs.aquarius",
  poissons: "signs.pisces",
};
---

<BaseLayout
  title={content.seo.horoscope.title}
  description={content.seo.horoscope.description}
  jsonLd={[
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: content.seo.horoscope.title,
      description: content.seo.horoscope.description,
      inLanguage: lang,
      url: `https://karmastro.com/${lang}/horoscope`,
      isPartOf: { "@type": "WebSite", name: "Karmastro", url: "https://karmastro.com" },
      about: { "@type": "Thing", name: "Horoscope", description: "Daily zodiac horoscope for the 12 signs" },
      hasPart: ZODIAC_SIGNS.map((sign) => ({
        "@type": "WebPage",
        name: t(signNameKeys[sign.slug] as any, lang) || sign.name,
        url: `https://karmastro.com/${lang}/horoscope/${sign.slug}`,
      })),
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Karmastro", item: `https://karmastro.com/${lang}` },
        { "@type": "ListItem", position: 2, name: t("horoscope.title", lang), item: `https://karmastro.com/${lang}/horoscope` },
      ],
    },
  ]}
>
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">{t("horoscope.daily", lang)}</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">{dateFormatted}</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        {content.seo.horoscope.description}
      </p>
    </div>

    {hasData && (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {ZODIAC_SIGNS.map((sign) => {
          const entry = todayData[sign.slug];
          const localSignName = t(signNameKeys[sign.slug] as any, lang);
          return (
            <a
              href={`/${lang}/horoscope/${sign.slug}`}
              class="group block p-5 rounded-2xl border border-white/10 bg-white/[0.02] hover:border-amber-300/40 hover:bg-amber-300/5 transition-all"
            >
              <div class="flex items-center justify-between mb-2">
                <ZodiacSymbol sign={sign.name} size={40} color="#D4A017" />
                <span class="text-xs text-white/40 uppercase tracking-wider">{sign.element}</span>
              </div>
              <h2 class="font-serif text-xl mb-1 group-hover:text-amber-300 transition-colors">{localSignName}</h2>
              <p class="text-xs text-white/50 mb-3">{sign.dates}</p>
              {entry?.intro && (
                <p class="text-sm text-white/70 line-clamp-2 leading-relaxed">{entry.intro.slice(0, 90)}...</p>
              )}
              <p class="mt-3 text-xs text-amber-300/80 group-hover:text-amber-300">→</p>
            </a>
          );
        })}
      </div>
    )}

    <div class="mt-16 text-center">
      <div class="inline-block p-8 rounded-3xl border border-purple-400/20 bg-purple-400/5 max-w-xl">
        <h3 class="font-serif text-2xl mb-3">{t("oracle.choose_guide", lang)}</h3>
        <p class="text-white/70 mb-5 leading-relaxed">{t("tools.subtitle", lang)}</p>
        <a
          href="https://app.karmastro.com/oracle"
          class="inline-block px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity"
        >
          {t("tools.cta_oracle", lang)}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
