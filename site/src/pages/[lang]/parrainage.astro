---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ShareButton from "../../components/ShareButton.astro";
import { LOCALES, DEFAULT_LOCALE, type Locale } from "../../i18n/config";
import { getContent } from "../../i18n/content";
import { t } from "../../i18n/translations";

export function getStaticPaths() {
  return LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Locale };
const content = getContent(lang);
---

<BaseLayout
  title={content.seo.referral.title}
  description={content.seo.referral.description}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: content.seo.referral.title,
    description: content.seo.referral.description,
    inLanguage: lang,
    url: `https://karmastro.com/${lang}/parrainage`,
    isPartOf: { "@type": "WebSite", name: "Karmastro", url: "https://karmastro.com" },
  }}
>
  <section class="max-w-4xl mx-auto px-4 py-16">
    <div class="text-center mb-14">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">{t("nav.referral", lang)}</p>
      <h1 class="text-4xl md:text-6xl font-serif mb-6">{content.seo.referral.title.split("-")[1] || content.seo.referral.title}</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        {content.seo.referral.description}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-4 mb-14">
      <div class="p-6 rounded-2xl border border-pink-400/20 bg-pink-400/5">
        <div class="text-3xl mb-3">✨</div>
        <h2 class="font-serif text-xl mb-2 text-pink-300">{t("oracle.feedback_resonates", lang)}</h2>
        <p class="text-sm text-white/80 leading-relaxed">{content.ctaSubtitle}</p>
      </div>
      <div class="p-6 rounded-2xl border border-purple-400/20 bg-purple-400/5">
        <div class="text-3xl mb-3">🌙</div>
        <h2 class="font-serif text-xl mb-2 text-purple-300">{t("common.learn_more", lang)}</h2>
        <p class="text-sm text-white/80 leading-relaxed">{content.heroFreeTeaser}</p>
      </div>
    </div>

    <div class="text-center mb-14">
      <a
        href="https://app.karmastro.com"
        class="inline-block px-8 py-4 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold text-lg hover:opacity-90 transition-opacity"
      >
        {t("common.cta_app", lang)}
      </a>
    </div>

    <div class="flex justify-center">
      <ShareButton
        title={content.seo.referral.title}
        text={content.seo.referral.description}
        url={`https://karmastro.com/${lang}/parrainage`}
        variant="secondary"
        label={t("common.share", lang)}
      />
    </div>
  </section>
</BaseLayout>
