---
import BlogLayout from "../../../layouts/BlogLayout.astro";
import { getCollection, render } from "astro:content";
import { LOCALES, DEFAULT_LOCALE, type Locale } from "../../../i18n/config";

export async function getStaticPaths() {
  const now = new Date();
  const posts = await getCollection("blog", ({ data }) => !data.draft && data.lang !== DEFAULT_LOCALE && data.date.valueOf() <= now.valueOf());
  return posts
    .filter((post) => LOCALES.includes(post.data.lang as Locale))
    .map((post) => ({
      params: { lang: post.data.lang, slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  author={post.data.author}
  category={post.data.category}
  tags={post.data.tags}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  slug={post.id}
  keywords={post.data.keywords}
  lang={post.data.lang}
  lastReviewed={post.data.lastReviewed}
  reviewedBy={post.data.reviewedBy}
  body={post.body}
>
  <Content />
</BlogLayout>
