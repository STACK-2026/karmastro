---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import Features from "../../components/Features.astro";
import StatsSection from "../../components/StatsSection.astro";
import DiscoverySection from "../../components/DiscoverySection.astro";
import FAQ from "../../components/FAQ.astro";
import CTA from "../../components/CTA.astro";
import { LOCALES, DEFAULT_LOCALE, type Locale } from "../../i18n/config";
import { getContent } from "../../i18n/content";
import { jsonLdHomepage } from "../../utils/seo";

// Generate one page per non-default locale
export function getStaticPaths() {
  return LOCALES.filter((l) => l !== DEFAULT_LOCALE).map((lang) => ({
    params: { lang },
  }));
}

const { lang } = Astro.params as { lang: Locale };
const content = getContent(lang);
---

<BaseLayout
  title={content.seo.home.title}
  description={content.seo.home.description}
  jsonLd={jsonLdHomepage()}
>
  <Hero />
  <Features />
  <DiscoverySection />
  <StatsSection />
  <FAQ />
  <CTA />
</BaseLayout>
