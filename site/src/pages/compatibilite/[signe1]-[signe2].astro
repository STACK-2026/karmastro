---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ZodiacSymbol from "../../components/ZodiacSymbol.astro";
import { ZODIAC_SIGNS, SIGN_SLUGS, getSignBySlug } from "../../data/zodiac";
import { compatibilityScore, compatibilityInterpretation } from "../../data/compatibility-matrix";

export function getStaticPaths() {
  const paths: any[] = [];
  for (const a of SIGN_SLUGS) {
    for (const b of SIGN_SLUGS) {
      paths.push({ params: { signe1: a, signe2: b } });
    }
  }
  return paths;
}

const { signe1, signe2 } = Astro.params as { signe1: string; signe2: string };
const sign1 = getSignBySlug(signe1)!;
const sign2 = getSignBySlug(signe2)!;

const scores = compatibilityScore(
  sign1.element as any,
  sign1.quality as any,
  sign2.element as any,
  sign2.quality as any
);
const interp = compatibilityInterpretation(
  sign1.name,
  sign1.element as any,
  sign1.quality as any,
  sign2.name,
  sign2.element as any,
  sign2.quality as any
);

const isSameSign = signe1 === signe2;
const title = isSameSign
  ? `Compatibilité ${sign1.name} - ${sign2.name} : deux ${sign1.name} ensemble - Karmastro`
  : `Compatibilité ${sign1.name} - ${sign2.name} : amour, amitié, travail, karma - Karmastro`;

const description = isSameSign
  ? `${sign1.name} × ${sign2.name} : ce que signifie aimer ou travailler avec son propre signe. Score global ${scores.global}/100, analyse Swiss Ephemeris.`
  : `${sign1.name} et ${sign2.name} : compatibilité amoureuse, amitié et professionnelle. Score global ${scores.global}/100. Forces, frictions et guidance karmique.`;

const scoreColor = (n: number) => n >= 80 ? "text-emerald-300" : n >= 60 ? "text-amber-300" : n >= 40 ? "text-orange-300" : "text-rose-300";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: title,
    description,
    datePublished: "2026-04-11",
    inLanguage: "fr-FR",
    author: { "@type": "Person", name: "Séléné", description: "Guide relationnelle de Karmastro, inspirée de la déesse grecque de la Lune" },
    publisher: {
      "@type": "Organization",
      name: "Karmastro",
      url: "https://karmastro.com",
      logo: { "@type": "ImageObject", url: "https://karmastro.com/favicon.svg" },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `https://karmastro.com/compatibilite/${signe1}-${signe2}`,
    },
    keywords: `compatibilité ${sign1.name}, compatibilité ${sign2.name}, ${sign1.name} ${sign2.name} amour, synastrie, astrologie`,
    about: [
      { "@type": "Thing", name: sign1.name, sameAs: `https://fr.wikipedia.org/wiki/${sign1.name}_(astrologie)` },
      { "@type": "Thing", name: sign2.name, sameAs: `https://fr.wikipedia.org/wiki/${sign2.name}_(astrologie)` },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Karmastro", item: "https://karmastro.com" },
      { "@type": "ListItem", position: 2, name: "Compatibilités", item: "https://karmastro.com/compatibilite" },
      { "@type": "ListItem", position: 3, name: `${sign1.name} × ${sign2.name}`, item: `https://karmastro.com/compatibilite/${signe1}-${signe2}` },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd} ogType="article">
  <article class="max-w-3xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/" class="hover:text-amber-300">Accueil</a>
      <span class="mx-2">/</span>
      <a href="/compatibilite/" class="hover:text-amber-300">Compatibilités</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">{sign1.name} × {sign2.name}</span>
    </nav>

    <header class="text-center mb-10">
      <div class="flex justify-center items-center gap-8 mb-4">
        <div class="flex flex-col items-center">
          <ZodiacSymbol sign={sign1.name} size={80} color="#D4A017" />
          <p class="mt-2 text-sm text-white/70">{sign1.name}</p>
          <p class="text-[10px] text-white/40">{sign1.element} · {sign1.quality}</p>
        </div>
        <div class="text-5xl text-amber-300/40 font-thin">×</div>
        <div class="flex flex-col items-center">
          <ZodiacSymbol sign={sign2.name} size={80} color="#8B5CF6" />
          <p class="mt-2 text-sm text-white/70">{sign2.name}</p>
          <p class="text-[10px] text-white/40">{sign2.element} · {sign2.quality}</p>
        </div>
      </div>
      <h1 class="text-4xl md:text-5xl font-serif mb-2">Compatibilité {sign1.name} & {sign2.name}</h1>
      <p class="text-sm text-white/50">Analyse croisée élément, modalité · karma</p>
    </header>

    <div class="p-6 rounded-2xl border border-amber-300/20 bg-amber-300/5 mb-8 text-center">
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-2">Score global</p>
      <p class={`text-6xl font-serif ${scoreColor(scores.global)}`}>{scores.global}%</p>
      <p class="text-xs text-white/50 mt-2">Basé sur l'affinité des éléments (60%) et des modalités (40%)</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-10">
      {([
        { label: "Amour", value: scores.love, color: "text-pink-300" },
        { label: "Amitié", value: scores.friendship, color: "text-emerald-300" },
        { label: "Travail", value: scores.work, color: "text-amber-300" },
        { label: "Karma", value: scores.karma, color: "text-purple-300" },
        { label: "Tension", value: scores.tension, color: "text-rose-300" },
      ]).map((s) => (
        <div class="p-3 rounded-xl border border-white/10 bg-white/[0.02] text-center">
          <p class="text-[10px] uppercase tracking-wider text-white/50 mb-1">{s.label}</p>
          <p class={`text-2xl font-serif ${s.color}`}>{s.value}</p>
          <div class="h-1 bg-white/10 rounded-full mt-2 overflow-hidden">
            <div class="h-full bg-gradient-to-r from-amber-300 to-purple-400" style={`width: ${s.value}%`}></div>
          </div>
        </div>
      ))}
    </div>

    <section class="mb-10">
      <h2 class="font-serif text-2xl text-emerald-300 mb-4">Forces de cette combinaison</h2>
      <ul class="space-y-3">
        {interp.strengths.map((s) => (
          <li class="p-4 rounded-xl border border-emerald-300/20 bg-emerald-300/5 text-white/85 leading-relaxed">
            <span class="text-emerald-300 mr-2">✦</span>{s}
          </li>
        ))}
      </ul>
    </section>

    <section class="mb-10">
      <h2 class="font-serif text-2xl text-rose-300 mb-4">Points de friction</h2>
      <ul class="space-y-3">
        {interp.frictions.map((f) => (
          <li class="p-4 rounded-xl border border-rose-300/20 bg-rose-300/5 text-white/85 leading-relaxed">
            <span class="text-rose-300 mr-2">⚠</span>{f}
          </li>
        ))}
      </ul>
    </section>

    <section class="mb-10">
      <h2 class="font-serif text-2xl text-amber-300 mb-4">Guidance karmique</h2>
      <p class="p-5 rounded-xl border border-amber-300/20 bg-amber-300/5 text-white/85 leading-relaxed italic">
        "{interp.guidance}"
      </p>
    </section>

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center mb-10">
      <h3 class="font-serif text-xl mb-2">Une analyse plus précise ?</h3>
      <p class="text-white/70 mb-4 text-sm leading-relaxed">
        La compatibilité entre signes solaires ne couvre que 30% de votre dynamique réelle. Pour une synastrie complète qui croise les 10 planètes, les ascendants et les aspects majeurs, pose ta question à l'Oracle ou essaie notre calculateur de synastrie gratuit.
      </p>
      <div class="flex gap-3 flex-wrap justify-center">
        <a href="https://app.karmastro.com/compatibility" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity">
          Synastrie complète
        </a>
        <a href="/outils/synastrie/" class="inline-block px-5 py-2.5 rounded-xl border border-white/20 text-white/70 hover:border-amber-300/40 hover:text-amber-300 transition-colors">
          Calculateur gratuit
        </a>
      </div>
    </div>

    <section class="mb-10">
      <h2 class="font-serif text-xl mb-4">Explore d'autres combinaisons pour {sign1.name}</h2>
      <div class="grid grid-cols-3 md:grid-cols-4 gap-2">
        {ZODIAC_SIGNS.filter((s) => s.slug !== sign1.slug).map((s) => (
          <a
            href={`/compatibilite/${sign1.slug}-${s.slug}`}
            class="p-3 rounded-lg border border-white/10 bg-white/[0.02] hover:border-amber-300/40 transition-colors text-center"
          >
            <div class="flex justify-center mb-1">
              <ZodiacSymbol sign={s.name} size={28} color="#D4A017" />
            </div>
            <p class="text-xs text-white/70">{s.name}</p>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
