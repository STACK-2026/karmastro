---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ZodiacSymbol from "../../components/ZodiacSymbol.astro";
import { ZODIAC_SIGNS } from "../../data/zodiac";
import { compatibilityScore } from "../../data/compatibility-matrix";

const title = "Compatibilité des 12 signes astrologiques - 144 combinaisons - Karmastro";
const description =
  "Découvre la compatibilité amoureuse, amicale et karmique entre les 12 signes du zodiaque. 144 combinaisons analysées avec scores et guidance détaillée. Analyse Swiss Ephemeris gratuite.";
const canonical = "https://karmastro.com/compatibilite";

// First-party aggregate over the 66 distinct sign pairs (real, computed from the
// same engine as the detail pages) -> citable answers for "signes les plus
// compatibles" + a Dataset.
const pairs: { a: any; b: any; global: number }[] = [];
for (let i = 0; i < ZODIAC_SIGNS.length; i++) {
  for (let j = i + 1; j < ZODIAC_SIGNS.length; j++) {
    const a = ZODIAC_SIGNS[i], b = ZODIAC_SIGNS[j];
    const s = compatibilityScore(a.element as any, a.quality as any, b.element as any, b.quality as any);
    pairs.push({ a, b, global: s.global });
  }
}
const avgGlobal = Math.round(pairs.reduce((s, p) => s + p.global, 0) / pairs.length);
const sortedPairs = [...pairs].sort((x, y) => y.global - x.global);
const bestPair = sortedPairs[0];
const worstPair = sortedPairs[sortedPairs.length - 1];

const tldr = `Karmastro a calculé la compatibilité des 144 combinaisons des 12 signes du zodiaque. Sur les 66 paires de signes différents, le score moyen est de ${avgGlobal}/100. La paire la plus compatible est ${bestPair.a.name} et ${bestPair.b.name} (${bestPair.global}%), la moins compatible ${worstPair.a.name} et ${worstPair.b.name} (${worstPair.global}%). Le score croise l'affinité des éléments (60%) et des modalités (40%).`;

const faq = [
  {
    q: "Quels signes du zodiaque sont les plus compatibles ?",
    a: `D'après les scores Karmastro, la paire de signes différents la plus compatible est ${bestPair.a.name} et ${bestPair.b.name}, avec ${bestPair.global}% de compatibilité globale. Les affinités les plus fortes apparaissent entre signes de même élément ou d'éléments complémentaires (feu et air, terre et eau).`,
  },
  {
    q: "Quels signes sont les moins compatibles ?",
    a: `La paire la moins compatible selon Karmastro est ${worstPair.a.name} et ${worstPair.b.name} (${worstPair.global}%). Un score faible n'interdit pas la relation : il signale surtout des modes de fonctionnement différents à concilier.`,
  },
  {
    q: "Quel est le score de compatibilité moyen entre les signes ?",
    a: `Sur les 66 paires de signes différents, le score de compatibilité moyen calculé par Karmastro est de ${avgGlobal}/100.`,
  },
  {
    q: "Comment Karmastro calcule la compatibilité entre deux signes ?",
    a: "Le score croise l'affinité des éléments (feu, terre, air, eau) pour 60% et des modalités (cardinal, fixe, mutable) pour 40%, complété par une lecture karmique. La compatibilité des signes solaires ne couvre qu'environ 30% de la dynamique réelle : une synastrie complète croise les 10 planètes, les ascendants et les aspects.",
  },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: canonical,
    inLanguage: "fr-FR",
    isPartOf: { "@type": "WebSite", name: "Karmastro", url: "https://karmastro.com" },
    about: {
      "@type": "Thing",
      name: "Compatibilité astrologique",
      description: "Analyse de la compatibilité entre les 12 signes du zodiaque tropical",
    },
    speakable: { "@type": "SpeakableSpecification", cssSelector: ["h1", "[data-speakable='true']"] },
  },
  {
    "@context": "https://schema.org",
    "@type": "Dataset",
    name: "Compatibilité des 12 signes du zodiaque : scores Karmastro",
    description: `Scores de compatibilité (0 à 100) des 66 paires de signes du zodiaque. Score moyen ${avgGlobal}/100, paire la plus compatible ${bestPair.a.name} et ${bestPair.b.name} (${bestPair.global}).`,
    url: canonical,
    isAccessibleForFree: true,
    creator: { "@type": "Organization", name: "Karmastro", url: "https://karmastro.com" },
    measurementTechnique: "Karmastro : affinité des éléments (60%) et des modalités (40%) entre deux signes, complétée par une lecture karmique.",
    variableMeasured: [
      { "@type": "PropertyValue", name: "Paires de signes analysées", value: pairs.length },
      { "@type": "PropertyValue", name: "Score de compatibilité moyen (0-100)", value: avgGlobal },
      { "@type": "PropertyValue", name: "Meilleur score de paire (0-100)", value: bestPair.global },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
  },
];

// JSON serialisé pour le client JS
const signsForClient = ZODIAC_SIGNS.map((s) => ({
  slug: s.slug,
  name: s.name,
  element: s.element,
  quality: s.quality,
}));
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-5xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/" class="hover:text-amber-300">Accueil</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">Compatibilités</span>
    </nav>

    <header class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Compatibilité des 12 signes</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        Sélectionne deux signes, découvre leur dynamique. 144 combinaisons, analyse hellénistique gratuite.
      </p>
    </header>

    <p data-speakable="true" class="mb-10 p-5 rounded-2xl border border-white/10 bg-white/[0.03] text-white/85 leading-relaxed max-w-3xl mx-auto">
      {tldr}
    </p>

    {/* ═══ PICKER 2 ETAPES ═══ */}
    <section class="mb-10 p-6 md:p-8 rounded-2xl border border-amber-300/30 bg-gradient-to-b from-amber-300/[0.04] to-transparent">
      <div class="flex items-center justify-between mb-6 flex-wrap gap-3">
        <h2 class="font-serif text-2xl">Choisis deux signes</h2>
        <div id="compat-progress" class="text-xs text-white/50">
          <span data-step="0" class="hidden">Commence par ton signe.</span>
          <span data-step="1" class="hidden text-amber-300/80">Signe 1 choisi. Pick le deuxième.</span>
          <span data-step="2" class="hidden text-emerald-300/80">✓ Prêt. Clique sur "Découvrir".</span>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {/* Slot 1 */}
        <div>
          <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-3">Signe 1</p>
          <div id="sign1-display" class="mb-3 min-h-[76px] p-4 rounded-xl border border-dashed border-white/15 bg-white/[0.02] flex items-center gap-3">
            <span class="text-white/40 text-sm">Aucun signe sélectionné</span>
          </div>
          <div class="grid grid-cols-4 gap-2" data-slot="sign1">
            {ZODIAC_SIGNS.map((sign) => (
              <button
                type="button"
                data-slug={sign.slug}
                data-name={sign.name}
                data-element={sign.element}
                data-quality={sign.quality}
                class="compat-btn group p-2.5 rounded-lg border border-white/10 bg-white/[0.02] hover:border-amber-300/40 hover:bg-amber-300/[0.04] transition-colors text-center focus:outline-none focus:ring-2 focus:ring-amber-300/50"
                aria-label={`Choisir ${sign.name} comme signe 1`}
              >
                <div class="flex justify-center mb-1 opacity-80 group-hover:opacity-100 transition-opacity">
                  <ZodiacSymbol sign={sign.name} size={24} color="#D4A017" />
                </div>
                <p class="text-[11px] text-white/70 leading-tight group-hover:text-amber-300 transition-colors">{sign.name}</p>
              </button>
            ))}
          </div>
        </div>

        {/* Slot 2 */}
        <div>
          <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-3">Signe 2</p>
          <div id="sign2-display" class="mb-3 min-h-[76px] p-4 rounded-xl border border-dashed border-white/15 bg-white/[0.02] flex items-center gap-3">
            <span class="text-white/40 text-sm">Aucun signe sélectionné</span>
          </div>
          <div class="grid grid-cols-4 gap-2" data-slot="sign2">
            {ZODIAC_SIGNS.map((sign) => (
              <button
                type="button"
                data-slug={sign.slug}
                data-name={sign.name}
                data-element={sign.element}
                data-quality={sign.quality}
                class="compat-btn group p-2.5 rounded-lg border border-white/10 bg-white/[0.02] hover:border-amber-300/40 hover:bg-amber-300/[0.04] transition-colors text-center focus:outline-none focus:ring-2 focus:ring-amber-300/50"
                aria-label={`Choisir ${sign.name} comme signe 2`}
              >
                <div class="flex justify-center mb-1 opacity-80 group-hover:opacity-100 transition-opacity">
                  <ZodiacSymbol sign={sign.name} size={24} color="#D4A017" />
                </div>
                <p class="text-[11px] text-white/70 leading-tight group-hover:text-amber-300 transition-colors">{sign.name}</p>
              </button>
            ))}
          </div>
        </div>
      </div>

      <div class="mt-6 flex items-center justify-between flex-wrap gap-3">
        <button
          type="button"
          id="compat-reset"
          class="text-xs text-white/50 hover:text-white/80 underline underline-offset-4"
        >
          Réinitialiser
        </button>
        <button
          type="button"
          id="compat-go"
          disabled
          class="px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity text-sm disabled:opacity-30 disabled:cursor-not-allowed disabled:hover:opacity-30"
        >
          Découvrir la compatibilité →
        </button>
      </div>
    </section>

    <div class="mb-10 p-6 rounded-2xl border border-amber-300/20 bg-amber-300/5">
      <h2 class="font-serif text-xl mb-3">Méthode de calcul</h2>
      <p class="text-white/80 text-sm leading-relaxed mb-3">
        Chaque compatibilité est calculée à partir de deux dimensions traditionnelles de l'astrologie hellénistique :
      </p>
      <ul class="text-white/70 text-sm space-y-2 ml-4">
        <li><strong class="text-amber-300">Les éléments (60%)</strong> : feu, terre, air, eau. Deux feux s'allument mutuellement, terre et eau se fertilisent, feu et air se nourrissent, mais feu et eau s'annulent sans travail conscient.</li>
        <li><strong class="text-amber-300">Les modalités (40%)</strong> : cardinal (initiateur), fixe (constructeur), mutable (adaptable). Deux cardinaux se challenge, deux fixes résistent mais durent, deux mutables s'adaptent mais peuvent dériver.</li>
      </ul>
      <p class="text-white/60 text-xs mt-3 italic">
        Note : cette analyse de 144 combinaisons donne une vue d'ensemble à ~30% de précision. Pour une synastrie à 85%, il faut croiser les 10 planètes et les ascendants des deux thèmes natals.
      </p>
    </div>

    <div class="p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center">
      <h2 class="font-serif text-xl mb-2">Tu veux une analyse 10x plus précise ?</h2>
      <p class="text-white/70 mb-4 text-sm leading-relaxed">
        Les signes solaires ne couvrent que 30% de votre dynamique réelle. La synastrie croise les 10 planètes et les ascendants des deux thèmes natals pour monter à 85% de précision.
      </p>
      <a
        href="https://app.karmastro.com/compatibility"
        class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity"
      >
        Synastrie complète
      </a>
    </div>

    <section class="mb-10 max-w-3xl mx-auto">
      <h2 class="font-serif text-2xl mb-4">Questions fréquentes</h2>
      <div class="space-y-3">
        {faq.map((item) => (
          <div class="p-5 rounded-xl border border-white/10 bg-white/[0.02]">
            <h3 class="font-semibold text-white mb-2">{item.q}</h3>
            <p class="text-white/75 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </section>
  </article>

  <script is:inline define:vars={{ signsForClient, basePath: "/compatibilite" }}>
    (function () {
      const state = { sign1: null, sign2: null };

      function findSign(slug) {
        return signsForClient.find((s) => s.slug === slug) || null;
      }

      function renderDisplay(slot) {
        const el = document.getElementById(`${slot}-display`);
        if (!el) return;
        const sign = state[slot];
        if (!sign) {
          el.innerHTML = '<span class="text-white/40 text-sm">Aucun signe sélectionné</span>';
          return;
        }
        el.innerHTML = `
          <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-amber-300/10 border border-amber-300/40 text-amber-300 text-2xl font-serif">✦</span>
          <div>
            <p class="font-serif text-xl text-white">${sign.name}</p>
            <p class="text-[11px] text-white/50">${sign.element} · ${sign.quality}</p>
          </div>
          <button type="button" data-clear="${slot}" class="ml-auto text-[11px] text-white/40 hover:text-white/80 underline underline-offset-4">Changer</button>
        `;
      }

      function updateButtons() {
        for (const slot of ["sign1", "sign2"]) {
          const container = document.querySelector(`[data-slot="${slot}"]`);
          if (!container) continue;
          const current = state[slot];
          container.querySelectorAll(".compat-btn").forEach((btn) => {
            const slug = btn.dataset.slug;
            const isSelected = current && current.slug === slug;
            btn.classList.toggle("border-amber-300", isSelected);
            btn.classList.toggle("bg-amber-300/10", isSelected);
            btn.classList.toggle("border-white/10", !isSelected);
            btn.setAttribute("aria-pressed", isSelected ? "true" : "false");
          });
        }
      }

      function updateProgress() {
        const el = document.getElementById("compat-progress");
        if (!el) return;
        let step = 0;
        if (state.sign1 && state.sign2) step = 2;
        else if (state.sign1 || state.sign2) step = 1;
        el.querySelectorAll("[data-step]").forEach((s) => {
          s.classList.toggle("hidden", parseInt(s.dataset.step, 10) !== step);
        });
      }

      function updateGoButton() {
        const btn = document.getElementById("compat-go");
        if (!btn) return;
        btn.disabled = !(state.sign1 && state.sign2);
      }

      function persist() {
        try {
          const qs = new URLSearchParams();
          if (state.sign1) qs.set("s1", state.sign1.slug);
          if (state.sign2) qs.set("s2", state.sign2.slug);
          const next = qs.toString() ? `?${qs.toString()}` : window.location.pathname;
          window.history.replaceState({}, "", window.location.pathname + (qs.toString() ? `?${qs.toString()}` : ""));
        } catch (e) {}
      }

      function rerender() {
        renderDisplay("sign1");
        renderDisplay("sign2");
        updateButtons();
        updateProgress();
        updateGoButton();
        persist();
      }

      function setSign(slot, slug) {
        state[slot] = findSign(slug);
        rerender();
      }

      function clearSign(slot) {
        state[slot] = null;
        rerender();
      }

      // Bind buttons
      document.querySelectorAll('[data-slot]').forEach((container) => {
        const slot = container.dataset.slot;
        container.addEventListener("click", (e) => {
          const btn = e.target.closest(".compat-btn");
          if (!btn) return;
          setSign(slot, btn.dataset.slug);
        });
      });

      // Clear buttons (delegated)
      document.addEventListener("click", (e) => {
        const clearBtn = e.target.closest("[data-clear]");
        if (clearBtn) {
          clearSign(clearBtn.dataset.clear);
          return;
        }
      });

      // Reset
      const resetBtn = document.getElementById("compat-reset");
      resetBtn?.addEventListener("click", () => {
        state.sign1 = null;
        state.sign2 = null;
        rerender();
      });

      // Go
      const goBtn = document.getElementById("compat-go");
      goBtn?.addEventListener("click", () => {
        if (!state.sign1 || !state.sign2) return;
        window.location.href = `${basePath}/${state.sign1.slug}-${state.sign2.slug}`;
      });

      // Restore from query string
      try {
        const qs = new URLSearchParams(window.location.search);
        const s1 = qs.get("s1");
        const s2 = qs.get("s2");
        if (s1) state.sign1 = findSign(s1);
        if (s2) state.sign2 = findSign(s2);
      } catch (e) {}

      rerender();
    })();
  </script>
</BaseLayout>
