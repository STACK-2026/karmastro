---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ZodiacSymbol from "../../components/ZodiacSymbol.astro";
import { ZODIAC_SIGNS } from "../../data/zodiac";

const title = "Compatibilité des 12 signes astrologiques - 144 combinaisons - Karmastro";
const description =
  "Découvre la compatibilité amoureuse, amicale et karmique entre les 12 signes du zodiaque. 144 combinaisons analysées avec scores et guidance détaillée. Analyse Swiss Ephemeris gratuite.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: title,
  description,
  url: "https://karmastro.com/compatibilite",
  inLanguage: "fr-FR",
  isPartOf: {
    "@type": "WebSite",
    name: "Karmastro",
    url: "https://karmastro.com",
  },
  about: {
    "@type": "Thing",
    name: "Compatibilité astrologique",
    description: "Analyse de la compatibilité entre les 12 signes du zodiaque tropical",
  },
};
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-5xl mx-auto px-4 py-12">
    <nav class="text-sm text-white/50 mb-6" aria-label="breadcrumb">
      <a href="/" class="hover:text-amber-300">Accueil</a>
      <span class="mx-2">/</span>
      <span class="text-white/80">Compatibilités</span>
    </nav>

    <header class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Compatibilité des 12 signes</h1>
      <p class="text-lg text-white/70 max-w-2xl mx-auto leading-relaxed">
        Explore les 144 combinaisons possibles du zodiaque. Clique sur ton signe puis sur celui qui t'intéresse pour découvrir amour, amitié, travail et guidance karmique.
      </p>
    </header>

    <div class="mb-10 p-6 rounded-2xl border border-amber-300/20 bg-amber-300/5">
      <h2 class="font-serif text-xl mb-3">Méthode de calcul</h2>
      <p class="text-white/80 text-sm leading-relaxed mb-3">
        Chaque compatibilité est calculée à partir de deux dimensions traditionnelles de l'astrologie hellénistique :
      </p>
      <ul class="text-white/70 text-sm space-y-2 ml-4">
        <li><strong class="text-amber-300">Les éléments (60%)</strong> : feu, terre, air, eau. Deux feux s'allument mutuellement, terre et eau se fertilisent, feu et air se nourrissent, mais feu et eau s'annulent sans travail conscient.</li>
        <li><strong class="text-amber-300">Les modalités (40%)</strong> : cardinal (initiateur), fixe (constructeur), mutable (adaptable). Deux cardinaux se challenge, deux fixes résistent mais durent, deux mutables s'adaptent mais peuvent dériver.</li>
      </ul>
      <p class="text-white/60 text-xs mt-3 italic">
        Note : cette analyse de 144 combinaisons donne une vue d'ensemble à ~30% de précision. Pour une synastrie à 85%, il faut croiser les 10 planètes et les ascendants des deux thèmes natals.
      </p>
    </div>

    <h2 class="font-serif text-2xl mb-6">Choisis ton signe</h2>
    <div class="space-y-8">
      {ZODIAC_SIGNS.map((sign) => (
        <section class="p-6 rounded-2xl border border-white/10 bg-white/[0.02]">
          <div class="flex items-center gap-4 mb-4">
            <ZodiacSymbol sign={sign.name} size={48} color="#D4A017" />
            <div>
              <h3 class="font-serif text-2xl">{sign.name}</h3>
              <p class="text-xs text-white/50">{sign.dates} · {sign.element} · {sign.quality}</p>
            </div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2">
            {ZODIAC_SIGNS.map((other) => (
              <a
                href={`/compatibilite/${sign.slug}-${other.slug}`}
                class={`p-2.5 rounded-lg border transition-colors text-center ${
                  sign.slug === other.slug
                    ? "border-amber-300/40 bg-amber-300/5"
                    : "border-white/10 bg-white/[0.02] hover:border-amber-300/40 hover:bg-amber-300/[0.03]"
                }`}
              >
                <div class="flex justify-center mb-1">
                  <ZodiacSymbol sign={other.name} size={24} color="#D4A017" />
                </div>
                <p class="text-[11px] text-white/70 leading-tight">{other.name}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <div class="mt-12 p-6 rounded-2xl border border-purple-400/30 bg-purple-400/5 text-center">
      <h2 class="font-serif text-xl mb-2">Tu veux une analyse 10x plus précise ?</h2>
      <p class="text-white/70 mb-4 text-sm leading-relaxed">
        Les signes solaires ne couvrent que 30% de votre dynamique réelle. La synastrie croise les 10 planètes et les ascendants des deux thèmes natals pour monter à 85% de précision.
      </p>
      <a
        href="https://app.karmastro.com/compatibility"
        class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-medium hover:opacity-90 transition-opacity"
      >
        Synastrie complète
      </a>
    </div>
  </article>
</BaseLayout>
