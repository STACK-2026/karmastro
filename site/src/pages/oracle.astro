---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Parle à l'Oracle gratuitement - guidance astro & numérologie en ligne";
const description =
  "Pose ta question à l'Oracle de Karmastro et reçois une guidance instantanée mêlant astrologie et numérologie. Gratuit, sans inscription, écrit en direct par une IA nourrie de Swiss Ephemeris.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    name: "Oracle de Karmastro",
    description,
    url: "https://karmastro.com/oracle/",
    applicationCategory: "LifestyleApplication",
    operatingSystem: "Any",
    offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-2xl mx-auto px-4 py-12">
    <header class="text-center mb-8">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Guidance en direct</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Parle à l'Oracle</h1>
      <p class="text-lg text-white/70 max-w-xl mx-auto leading-relaxed">
        Pose ta question. L'Oracle lit le ciel et les nombres pour te répondre, à l'instant. Gratuit, sans inscription.
      </p>
      <a data-oracle-handoff data-next="/oracle" href="https://app.karmastro.com/auth?next=%2Foracle" class="inline-block mt-4 text-sm text-amber-300/80 hover:text-amber-300 underline underline-offset-4">
        Tu as déjà un profil ? Ouvre ton Oracle personnalisé
      </a>
    </header>

    <div id="oracle-box" class="rounded-3xl border border-amber-300/20 bg-[#0f0a1e]/40 overflow-hidden">
      <div id="oracle-thread" class="px-4 md:px-6 py-6 space-y-4 min-h-[280px] max-h-[60vh] overflow-y-auto">
        <div id="oracle-empty" class="text-center py-8">
          <p class="text-4xl mb-4">✦</p>
          <div class="max-w-lg mx-auto mb-6 rounded-2xl border border-amber-300/25 bg-gradient-to-br from-amber-300/[0.07] to-purple-400/[0.06] p-4 text-left">
            <p class="font-serif text-lg text-white text-center mb-1">Pour que l'Oracle parle vraiment de toi</p>
            <p class="text-xs text-white/60 text-center mb-4">Prénom et date suffisent. L'heure et la ville rendent le thème natal plus précis.</p>
            <form id="oracle-profile-form" class="grid sm:grid-cols-2 gap-2">
              <input id="oracle-first-name" type="text" maxlength="60" required autocomplete="given-name" placeholder="Ton prénom" class="px-3 py-2.5 rounded-xl bg-white/[0.06] border border-white/15 text-white placeholder:text-white/40 focus:border-amber-300/60 focus:outline-none text-sm" />
              <input id="oracle-birth-date" type="date" required autocomplete="bday" aria-label="Date de naissance" class="px-3 py-2.5 rounded-xl bg-white/[0.06] border border-white/15 text-white focus:border-amber-300/60 focus:outline-none text-sm" />
              <input id="oracle-birth-time" type="time" autocomplete="off" aria-label="Heure de naissance facultative" class="px-3 py-2.5 rounded-xl bg-white/[0.06] border border-white/15 text-white focus:border-amber-300/60 focus:outline-none text-sm" />
              <input id="oracle-birth-place" type="text" maxlength="120" autocomplete="address-level2" placeholder="Ville de naissance (facultatif)" class="px-3 py-2.5 rounded-xl bg-white/[0.06] border border-white/15 text-white placeholder:text-white/40 focus:border-amber-300/60 focus:outline-none text-sm" />
              <button type="submit" class="sm:col-span-2 mt-1 px-5 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold text-sm hover:opacity-90 transition-opacity">Lire mon ciel maintenant ✦</button>
            </form>
            <p id="oracle-profile-status" class="text-[11px] text-amber-100/65 text-center mt-2">Enregistrées pour personnaliser cet échange et ton profil si tu crées un compte.</p>
          </div>
          <p class="text-white/70 mb-5 text-sm">Ou commence avec une question :</p>
          <div class="flex flex-wrap gap-2 justify-center" id="oracle-starters">
            <button class="oracle-chip px-4 py-2 rounded-full border border-amber-300/30 text-amber-300 text-sm hover:bg-amber-300/10 transition-colors" data-personal="true" data-q="Que disent les astres pour moi en ce moment ?">Que disent les astres pour moi ?</button>
            <button class="oracle-chip px-4 py-2 rounded-full border border-amber-300/30 text-amber-300 text-sm hover:bg-amber-300/10 transition-colors" data-personal="true" data-q="Que révèle mon chemin de vie ?">Mon chemin de vie ?</button>
            <button class="oracle-chip px-4 py-2 rounded-full border border-amber-300/30 text-amber-300 text-sm hover:bg-amber-300/10 transition-colors" data-q="Un conseil pour ma semaine ?">Un conseil pour ma semaine ?</button>
          </div>
        </div>
      </div>
      <div class="border-t border-white/10 p-3 flex gap-2">
        <input id="oracle-input" type="text" maxlength="500" placeholder="Pose ta question à l'Oracle…" class="flex-1 px-4 py-3 rounded-xl bg-white/[0.05] border border-white/15 text-white placeholder:text-white/40 focus:border-amber-300/60 focus:outline-none text-sm" />
        <button id="oracle-send" type="button" class="px-5 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold text-sm hover:opacity-90 transition-opacity whitespace-nowrap">Envoyer ✦</button>
      </div>
    </div>

    <div id="oracle-suggestions" class="flex flex-wrap gap-2 justify-center mt-4"></div>

    <div class="mt-10 p-5 rounded-2xl border border-amber-300/30 bg-gradient-to-r from-purple-400/10 to-amber-300/10 text-center">
      <p class="font-serif text-base text-white mb-1">Garde ton profil et cette conversation</p>
      <p class="text-xs text-white/60 mb-4 max-w-md mx-auto leading-relaxed">Retrouve tes échanges, ton thème natal et tes nombres dans ton espace personnel.</p>
      <div class="flex flex-wrap gap-2 justify-center">
        <a data-oracle-handoff data-next="/oracle" href="https://app.karmastro.com/auth?next=%2Foracle" class="px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold text-sm">Retrouver mon Oracle personnalisé</a>
        <a href="/abonnement/" class="px-5 py-2.5 rounded-xl border border-amber-300/40 text-amber-300 text-sm hover:bg-amber-300/10 transition-colors">Découvrir Étoile</a>
      </div>
    </div>
  </article>
</BaseLayout>

<script>
  const CHAT_URL = "https://nkjbmbdrvejemzrggxvr.supabase.co/functions/v1/oracle-chat";
  const READING_CHECKOUT_URL = "https://nkjbmbdrvejemzrggxvr.supabase.co/functions/v1/reading-checkout";
  const PROFILE_KEY = "km_oracle_profile";
  const thread = document.getElementById("oracle-thread")!;
  const empty = document.getElementById("oracle-empty");
  const input = document.getElementById("oracle-input") as HTMLInputElement;
  const sendBtn = document.getElementById("oracle-send") as HTMLButtonElement;
  const sugWrap = document.getElementById("oracle-suggestions")!;
  const profileForm = document.getElementById("oracle-profile-form") as HTMLFormElement;
  const firstNameInput = document.getElementById("oracle-first-name") as HTMLInputElement;
  const birthDateInput = document.getElementById("oracle-birth-date") as HTMLInputElement;
  const birthTimeInput = document.getElementById("oracle-birth-time") as HTMLInputElement;
  const birthPlaceInput = document.getElementById("oracle-birth-place") as HTMLInputElement;
  const profileStatus = document.getElementById("oracle-profile-status")!;

  function sessionId(): string {
    let s = localStorage.getItem("km_oracle_session");
    if (!s) { s = "site-" + Math.random().toString(36).slice(2) + Date.now().toString(36); localStorage.setItem("km_oracle_session", s); }
    return s;
  }
  type SiteOracleProfile = {
    firstName: string;
    birthDate: string;
    birthTime?: string;
    birthPlace?: string;
  };
  function savedProfile(): SiteOracleProfile | null {
    try {
      const parsed = JSON.parse(localStorage.getItem(PROFILE_KEY) || "null");
      if (!parsed || typeof parsed.firstName !== "string" || !/^\d{4}-\d{2}-\d{2}$/.test(parsed.birthDate || "")) return null;
      return parsed;
    } catch { return null; }
  }
  function currentProfile(): SiteOracleProfile | null {
    const profile: SiteOracleProfile = {
      firstName: firstNameInput.value.trim(),
      birthDate: birthDateInput.value,
      birthTime: birthTimeInput.value || undefined,
      birthPlace: birthPlaceInput.value.trim() || undefined,
    };
    return profile.firstName && /^\d{4}-\d{2}-\d{2}$/.test(profile.birthDate) ? profile : null;
  }
  function handoffUrl(next: string): string {
    const url = new URL("https://app.karmastro.com/auth");
    url.searchParams.set("oracle_session", sessionId());
    url.searchParams.set("next", next === "/pricing" ? "/pricing" : "/oracle");
    return url.toString();
  }
  document.querySelectorAll<HTMLElement>("[data-oracle-handoff]").forEach((link) => {
    const next = link.dataset.next || "/oracle";
    if (link instanceof HTMLAnchorElement) link.href = handoffUrl(next);
    link.addEventListener("click", () => {
      try { (window as any).km?.trackEvent("oracle_handoff_click", { next }); } catch {}
    });
  });

  type OracleHandoff = {
    source: string;
    question?: string;
    profile?: { birthDate?: string; birthTime?: string; birthPlace?: string };
  };
  const handoffApi = (window as any).kmOracleHandoff;
  const incomingHandoff = (handoffApi?.consume?.() || null) as OracleHandoff | null;
  const urlSource = new URLSearchParams(location.search).get("src") || "";
  const oracleSource = incomingHandoff?.source
    || (/^[a-z0-9][a-z0-9-]{1,39}$/.test(urlSource) ? urlSource : "direct");
  const legacyQuestion = handoffApi?.consumeLegacyQuestion?.() || "";
  let pendingQuestion = incomingHandoff?.question || legacyQuestion;

  const initialProfile = savedProfile();
  if (initialProfile) {
    firstNameInput.value = initialProfile.firstName;
    birthDateInput.value = initialProfile.birthDate;
    birthTimeInput.value = initialProfile.birthTime || "";
    birthPlaceInput.value = initialProfile.birthPlace || "";
    profileStatus.textContent = `Profil prêt pour ${initialProfile.firstName}. Tu peux lancer une question personnelle.`;
  }
  if (incomingHandoff?.profile) {
    if (incomingHandoff.profile.birthDate) birthDateInput.value = incomingHandoff.profile.birthDate;
    if (incomingHandoff.profile.birthTime) birthTimeInput.value = incomingHandoff.profile.birthTime;
    if (incomingHandoff.profile.birthPlace) birthPlaceInput.value = incomingHandoff.profile.birthPlace;
    profileStatus.textContent = firstNameInput.value
      ? `Tes données de ${oracleSource.replace(/-/g, " ")} sont prêtes. Tu peux continuer.`
      : "Ajoute seulement ton prénom pour que l'Oracle relie ce résultat à toi.";
  }
  const history: { role: string; content: string }[] = [];
  let conversationId: string | null = null;
  let busy = false;
  let firstResponseTracked = false;

  try {
    (window as any).km?.trackEvent("oracle_entry_viewed", {
      source: oracleSource,
      locale: document.documentElement.lang || "fr",
      has_handoff: Boolean(incomingHandoff),
    });
  } catch {}

  let profileStartedTracked = false;
  profileForm.addEventListener("focusin", () => {
    if (profileStartedTracked) return;
    profileStartedTracked = true;
    try { (window as any).km?.trackEvent("oracle_profile_started", { source: oracleSource, stage: "profile_form" }); } catch {}
  });

  function bubble(role: string, text: string): HTMLElement {
    const wrap = document.createElement("div");
    wrap.className = role === "user" ? "text-right" : "text-left";
    const b = document.createElement("div");
    b.className = role === "user"
      ? "inline-block max-w-[85%] px-4 py-2.5 rounded-2xl bg-purple-400/20 text-white text-sm text-left"
      : "inline-block max-w-[90%] px-4 py-2.5 rounded-2xl bg-white/[0.04] border border-white/10 text-white/90 text-sm text-left leading-relaxed";
    b.textContent = text;
    wrap.appendChild(b);
    thread.appendChild(wrap);
    thread.scrollTop = thread.scrollHeight;
    return b;
  }

  function renderSuggestions(items: string[]) {
    sugWrap.innerHTML = "";
    (items || []).slice(0, 3).forEach((q) => {
      const btn = document.createElement("button");
      btn.className = "px-4 py-2 rounded-full border border-amber-300/30 text-amber-300 text-sm hover:bg-amber-300/10 transition-colors";
      btn.textContent = q;
      btn.onclick = () => { if (!busy) send(q); };
      sugWrap.appendChild(btn);
    });
  }

  // Carte paywall (limite quotidienne atteinte) : le moment de conversion vers Étoile.
  function renderPaywall(out: HTMLElement, pw: any) {
    const wrap = out.parentElement;
    if (!wrap) return;
    wrap.className = "text-left";
    const isAnon = !!(pw && pw.is_anon);
    const isFr = (document.documentElement.lang || "fr").startsWith("fr");
    const msg = (pw && pw.message) || "Tu as atteint ta limite de messages cosmiques du jour.";
    const esc = (value: string) => value.replace(/[<>&"]/g, (char) => ({ "<": "&lt;", ">": "&gt;", "&": "&amp;", '"': "&quot;" }[char] || char));
    const etoileHref = isAnon ? handoffUrl("/pricing") : "/abonnement/";
    const profile = savedProfile();
    wrap.innerHTML =
      '<div class="inline-block w-full max-w-md p-5 rounded-2xl bg-gradient-to-r from-purple-400/10 to-amber-300/10 border border-amber-300/30 text-center">'
      + '<p class="text-2xl mb-1">✦</p>'
      + '<p class="text-sm text-white/90 mb-4 leading-relaxed">' + esc(msg) + "</p>"
      + '<ul class="text-xs text-white/70 text-left max-w-xs mx-auto space-y-1 mb-4">'
      + "<li>✦ Oracle illimité, jour et nuit</li>"
      + "<li>✦ Profil et historique conservés</li>"
      + "<li>✦ Guidance personnalisée chaque mois</li>"
      + "</ul>"
      + '<a href="' + etoileHref + '" id="km-pw-etoile" class="inline-block w-full max-w-xs px-5 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold text-sm hover:opacity-90 transition-opacity">'
      + (isFr ? "Débloquer l'Oracle illimité - 5,99 €/mois" : "Unlock unlimited Oracle - €5.99/month")
      + "</a>"
      + (isAnon
        ? '<details id="km-pw-one-shot" class="mt-4 text-left max-w-xs mx-auto rounded-xl border border-white/10 bg-white/[0.03]">'
          + '<summary class="cursor-pointer px-3 py-2.5 text-xs text-white/65 text-center">' + (isFr ? "Je préfère une lecture unique à 4,90 €" : "I prefer a one-time €4.90 reading") + "</summary>"
          + '<div class="px-3 pb-3 text-center">'
          + '<p class="text-xs text-white/55 mb-2">' + (isFr ? "Une lecture écrite de ton Chemin de Vie, sans abonnement." : "A written Life Path reading, with no subscription.") + "</p>"
          + '<input id="km-pw-birth" type="date" required class="w-full block mb-2 px-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white text-sm" />'
          + '<button id="km-pw-buy" type="button" class="w-full px-4 py-2 rounded-lg border border-amber-300/40 text-amber-300 font-semibold text-sm hover:bg-amber-300/10 transition-colors">' + (isFr ? "Recevoir ma lecture - 4,90 €" : "Get my reading - €4.90") + "</button>"
          + '<p id="km-pw-buy-err" class="text-[11px] text-red-300 mt-2" hidden></p>'
          + "</div></details>"
        : "")
      + '<p class="text-[11px] text-white/40 mt-3">Paiement sécurisé Stripe · sans engagement</p>'
      + "</div>";
    const etoileLink = wrap.querySelector("#km-pw-etoile");
    if (etoileLink) etoileLink.addEventListener("click", () => { try { (window as any).km?.trackEvent("paywall_etoile_click", { source: oracleSource, billing_cycle: "monthly" }); } catch {} });
    const oneShot = wrap.querySelector("#km-pw-one-shot") as HTMLDetailsElement | null;
    if (oneShot) oneShot.addEventListener("toggle", () => {
      if (oneShot.open) { try { (window as any).km?.trackEvent("paywall_offer_view", { tool: "chemin-de-vie" }); } catch {} }
    }, { once: true });
    // Offre lecture (anonyme) : checkout invite Chemin de Vie, sans compte requis.
    const buyBtn = wrap.querySelector("#km-pw-buy") as HTMLButtonElement | null;
    const birthInput = wrap.querySelector("#km-pw-birth") as HTMLInputElement | null;
    if (buyBtn && birthInput) {
      if (profile?.birthDate) birthInput.value = profile.birthDate;
      birthInput.addEventListener("change", () => {
        if (birthInput.value) { try { (window as any).km?.trackEvent("paywall_offer_date_entered", {}); } catch {} }
      });
      buyBtn.addEventListener("click", async () => {
        const birthDate = birthInput.value;
        const err = wrap.querySelector("#km-pw-buy-err") as HTMLElement | null;
        if (!birthDate) { birthInput.classList.add("ring-2", "ring-amber-300"); return; }
        const original = buyBtn.textContent;
        buyBtn.disabled = true; buyBtn.textContent = "…";
        if (err) err.hidden = true;
        try { (window as any).km?.trackEvent("paywall_offer_checkout_click", { tool: "chemin-de-vie" }); } catch {}
        try {
          const r = await fetch(READING_CHECKOUT_URL, {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ tool: "chemin-de-vie", birthDate, locale: document.documentElement.lang || "fr" }),
          });
          const d = await r.json().catch(() => ({}));
          if (d && d.url) { window.location.href = d.url; return; }
          throw new Error((d && d.error) || "no url");
        } catch {
          buyBtn.disabled = false; buyBtn.textContent = original;
          if (err) { err.hidden = false; err.textContent = "Une erreur est survenue, réessaie."; }
        }
      });
    }
  }

  async function send(text: string) {
    const cleanText = text.trim().slice(0, 500);
    if (busy || !cleanText) return;
    busy = true; sendBtn.disabled = true;
    const startedAt = performance.now();
    const turn = history.filter((m) => m.role === "user").length + 1;
    if (empty) empty.remove();
    sugWrap.innerHTML = "";
    history.push({ role: "user", content: cleanText });
    bubble("user", cleanText);
    input.value = "";
    try {
      (window as any).km?.trackEvent("oracle_message_sent", { source: oracleSource, turn });
      if (turn === 2) (window as any).km?.trackEvent("oracle_second_turn", { source: oracleSource });
    } catch {}
    const out = bubble("assistant", "…");
    let full = "";
    try {
      const resp = await fetch(CHAT_URL, {
        method: "POST", headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          messages: history,
          profile: currentProfile() || savedProfile() || {},
          guide: "oracle",
          sessionId: sessionId(),
          conversationId,
        }),
      });
      // Limite quotidienne atteinte : l'edge function renvoie un 402 + objet paywall.
      if (resp.status === 402) {
        const data = await resp.json().catch(() => null);
        const pw = (data && data.paywall) || {};
        renderPaywall(out, pw);
        try {
          (window as any).km?.trackEvent("oracle_limit_hit", { source: oracleSource, turn, is_anon: !!pw.is_anon });
          (window as any).km?.trackEvent("paywall_viewed", { source: oracleSource, surface: "oracle", is_anon: !!pw.is_anon });
        } catch {}
        return;
      }
      if (!resp.ok || !resp.body) {
        out.textContent = "Une brume cosmique passe. Réessaie dans un instant.";
        return;
      }
      const reader = resp.body.getReader();
      const dec = new TextDecoder();
      let buf = "";
      let suggestions: string[] = [];
      while (true) {
        const { done, value } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        const lines = buf.split("\n");
        buf = lines.pop() || "";
        for (const line of lines) {
          const l = line.trim();
          if (!l.startsWith("data:")) continue;
          const p = l.slice(5).trim();
          if (p === "[DONE]") continue;
          try {
            const d = JSON.parse(p);
            const delta = d.choices?.[0]?.delta?.content;
            if (delta) {
              full += delta; out.textContent = full; thread.scrollTop = thread.scrollHeight;
              if (!firstResponseTracked && turn === 1) {
                firstResponseTracked = true;
                const latency = performance.now() - startedAt;
                const latencyBucket = latency < 1000 ? "under_1s" : latency < 3000 ? "1_3s" : latency < 6000 ? "3_6s" : "over_6s";
                try { (window as any).km?.trackEvent("oracle_first_response", { source: oracleSource, latency_bucket: latencyBucket }); } catch {}
              }
            }
            if (d.suggestions) suggestions = d.suggestions;
            if (d.conversation_id) conversationId = d.conversation_id;
          } catch {}
        }
      }
      if (full) history.push({ role: "assistant", content: full });
      else out.textContent = "L'Oracle médite… réessaie dans un instant.";
      renderSuggestions(suggestions);
    } catch {
      out.textContent = "Une brume cosmique passe. Réessaie dans un instant.";
    } finally {
      busy = false; sendBtn.disabled = false; input.focus();
    }
  }

  profileForm.addEventListener("submit", (event) => {
    event.preventDefault();
    const profile = currentProfile();
    if (!profile) return;
    localStorage.setItem(PROFILE_KEY, JSON.stringify(profile));
    profileStatus.textContent = `Profil prêt pour ${profile.firstName}. L'Oracle croise maintenant ton ciel et tes nombres.`;
    try {
      (window as any).km?.trackEvent("oracle_profile_submitted", {
        source: oracleSource,
        profile_completeness: profile.birthTime && profile.birthPlace ? "complete" : profile.birthTime ? "date_time" : profile.birthPlace ? "date_place" : "date_only",
        surface: "site_oracle",
      });
    } catch {}
    const question = pendingQuestion || "Que disent les astres pour moi en ce moment ?";
    pendingQuestion = "";
    send(question);
  });

  sendBtn.addEventListener("click", () => send(input.value));
  input.addEventListener("keydown", (e) => { if (e.key === "Enter") send(input.value); });
  document.querySelectorAll(".oracle-chip").forEach((c) => {
    c.addEventListener("click", () => {
      const chip = c as HTMLElement;
      if (chip.dataset.personal === "true" && !currentProfile()) {
        profileStatus.textContent = "Ajoute ton prénom et ta date pour éviter une réponse générique.";
        profileForm.scrollIntoView({ behavior: "smooth", block: "center" });
        firstNameInput.focus();
        return;
      }
      send(chip.dataset.q || "");
    });
  });

  if (pendingQuestion) {
    if (incomingHandoff?.profile && !currentProfile()) {
      profileForm.scrollIntoView({ behavior: "smooth", block: "center" });
      firstNameInput.focus();
    } else {
      const question = pendingQuestion;
      pendingQuestion = "";
      send(question);
    }
  }
</script>
