---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Désabonnement - Karmastro";
const description = "Se désabonner de l'horoscope quotidien Karmastro.";
---

<BaseLayout title={title} description={description} noIndex>
  <section class="max-w-md mx-auto px-4 py-20 text-center">
    <div id="loading">
      <div class="text-4xl mb-4 animate-pulse">✦</div>
      <p class="text-white/70">Traitement en cours...</p>
    </div>

    <div id="success" class="hidden">
      <div class="text-4xl mb-4">🌙</div>
      <h1 class="font-serif text-2xl text-white mb-3">Les astres respectent ton choix</h1>
      <p class="text-white/70 mb-8 leading-relaxed">
        Tu ne recevras plus d'horoscope quotidien de notre part. Ton email est marqué comme désabonné.
      </p>
      <p class="text-sm text-white/50 mb-8 italic">
        Si tu changes d'avis, tu peux te réabonner depuis n'importe quelle page horoscope.
      </p>
      <a href="/" class="inline-block px-6 py-3 rounded-xl border border-white/20 text-white/70 hover:border-amber-300/40 hover:text-amber-300 transition-colors">
        Retour à l'accueil
      </a>
    </div>

    <div id="error" class="hidden">
      <div class="text-5xl mb-4">⚠</div>
      <h1 class="font-serif text-2xl text-white mb-3">Lien invalide</h1>
      <p class="text-white/70 mb-8">Ce lien de désabonnement n'est plus valide ou tu es déjà désabonné.</p>
      <a href="/" class="inline-block px-6 py-3 rounded-xl border border-amber-300/40 text-amber-300 hover:bg-amber-300/10 transition-colors">
        Retour à l'accueil
      </a>
    </div>
  </section>

  <script is:inline>
    (async function () {
      const token = new URLSearchParams(location.search).get("token");
      if (!token) {
        document.getElementById("loading").classList.add("hidden");
        document.getElementById("error").classList.remove("hidden");
        return;
      }

      try {
        const resp = await fetch("https://nkjbmbdrvejemzrggxvr.supabase.co/rest/v1/rpc/newsletter_unsubscribe", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            apikey: "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5ramJtYmRydmVqZW16cmdneHZyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU3NzE1MjUsImV4cCI6MjA5MTM0NzUyNX0.KYc8rXIC0RPMskW6eJIE_EranUcLK6nckCAWEph-340",
            Authorization: "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5ramJtYmRydmVqZW16cmdneHZyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU3NzE1MjUsImV4cCI6MjA5MTM0NzUyNX0.KYc8rXIC0RPMskW6eJIE_EranUcLK6nckCAWEph-340",
          },
          body: JSON.stringify({ p_token: token }),
        });
        const data = await resp.json();
        document.getElementById("loading").classList.add("hidden");
        if (data?.success) {
          document.getElementById("success").classList.remove("hidden");
          if (window.km && window.km.trackEvent) window.km.trackEvent("newsletter_unsubscribed");
        } else {
          document.getElementById("error").classList.remove("hidden");
        }
      } catch (e) {
        document.getElementById("loading").classList.add("hidden");
        document.getElementById("error").classList.remove("hidden");
      }
    })();
  </script>
</BaseLayout>
