---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Étoile - l'abonnement Karmastro : Oracle illimité + ta guidance mensuelle";
const description =
  "Passe en Étoile : l'Oracle en illimité jour et nuit, des lectures complètes et approfondies, et ta guidance personnalisée chaque mois. 5,99€/mois, sans engagement, résiliable en un clic.";

// Le checkout authentifié (compte + entitlement Oracle illimité) vit dans l'app.
const APP_PRICING = "https://app.karmastro.com/pricing";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Product",
    name: "Abonnement Étoile - Karmastro",
    description,
    offers: { "@type": "Offer", price: "5.99", priceCurrency: "EUR", availability: "https://schema.org/InStock", url: APP_PRICING },
  },
];

const eveil = [
  "3 messages avec l'Oracle par jour",
  "Tous les calculs et outils gratuits",
  "Ton horoscope quotidien",
];
const etoile = [
  "L'Oracle en illimité, jour et nuit",
  "Des lectures complètes et approfondies",
  "Ta guidance personnalisée chaque mois par email",
  "Ton historique de conversations conservé",
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <article class="max-w-3xl mx-auto px-4 py-16">
    <header class="text-center mb-10">
      <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-3">Abonnement Étoile</p>
      <h1 class="text-4xl md:text-5xl font-serif mb-4">Passe en Étoile</h1>
      <p class="text-lg text-white/70 max-w-xl mx-auto leading-relaxed">
        L'Oracle sans limite, des lectures qui vont au fond des choses, et chaque mois une guidance qui n'appartient qu'à toi. Tout ce que les astres ont à te dire, quand tu en as besoin.
      </p>
    </header>

    <!-- Comparatif Éveil (gratuit) vs Étoile -->
    <div class="grid md:grid-cols-2 gap-4 mb-10">
      <div class="p-6 rounded-2xl border border-white/10 bg-white/[0.02]">
        <p class="text-sm uppercase tracking-widest text-white/50 mb-1">Éveil</p>
        <p class="font-serif text-2xl text-white mb-4">Gratuit</p>
        <ul class="space-y-2 text-sm text-white/70">
          {eveil.map((f) => (
            <li class="flex items-start gap-2"><span class="text-white/40 mt-0.5">○</span><span>{f}</span></li>
          ))}
        </ul>
      </div>
      <div class="p-6 rounded-2xl border border-amber-300/40 bg-gradient-to-br from-amber-300/[0.08] to-purple-400/[0.05] relative">
        <p class="absolute -top-3 left-6 px-3 py-0.5 rounded-full bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] text-xs font-semibold">Recommandé</p>
        <p class="text-sm uppercase tracking-widest text-amber-300/80 mb-1">Étoile</p>
        <p class="font-serif text-2xl text-white mb-4">5,99 € <span class="text-base text-white/50">/ mois</span></p>
        <ul class="space-y-2 text-sm text-white/85">
          {etoile.map((f) => (
            <li class="flex items-start gap-2"><span class="text-amber-300 mt-0.5">✦</span><span>{f}</span></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Carte d'abonnement : le checkout se fait dans l'app (compte requis pour débloquer l'Oracle) -->
    <div id="subscribe" class="p-6 md:p-8 rounded-3xl border border-amber-300/30 bg-gradient-to-br from-amber-300/[0.06] to-purple-400/[0.04] text-center">
      <p class="font-serif text-2xl text-white mb-1">Rejoins Étoile</p>
      <p class="text-sm text-white/60 mb-1">5,99 € / mois, ou 49,99 € / an (2 mois offerts).</p>
      <p class="text-sm text-white/60 mb-5">Sans engagement, résiliable en un clic.</p>
      <a id="sub-go" href={APP_PRICING} class="inline-block w-full max-w-sm px-6 py-3.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold hover:opacity-90 transition-opacity">
        Passer en Étoile
      </a>
      <p class="text-[11px] text-white/40 mt-3">Tu crées ou retrouves ton compte, puis tu débloques l'Oracle illimité. Paiement sécurisé Stripe.</p>
    </div>
  </article>
</BaseLayout>

<script>
  document.getElementById("sub-go")?.addEventListener("click", () => {
    try { (window as any).km?.trackEvent("subscribe_click", { tier: "etoile", price: "5.99", dest: "app" }); } catch {}
  });
</script>
