---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  image?: string;
  imageAlt?: string;
  category?: string;
}

const { title, description, date, slug, image, imageAlt, category } = Astro.props;
---

<article class="group rounded-xl overflow-hidden border-glow transition-all hover:glow-violet" style="background: var(--bg-card);">
  <a href={`/blog/${slug}`} class="block">
    {image ? (
      <img
        src={image}
        alt={imageAlt || title}
        class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
        width="400"
        height="200"
      />
    ) : (
      <div class="w-full h-48 flex items-center justify-center" style="background: hsl(260 20% 14%);">
        <svg class="w-12 h-12" style="color: hsl(271 91% 65% / 0.3);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
        </svg>
      </div>
    )}
    <div class="p-6">
      {category && (
        <span class="text-xs font-medium uppercase tracking-wide text-gradient-gold">
          {category}
        </span>
      )}
      <h3 class="text-lg font-bold mt-1 mb-2 text-white group-hover:text-gradient-violet transition-colors line-clamp-2">
        {title}
      </h3>
      <p class="text-sm line-clamp-3 mb-3" style="color: hsl(220 9% 64%);">{description}</p>
      <time class="text-xs" style="color: hsl(220 9% 44%);" datetime={date.toISOString().split("T")[0]}>
        {date.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
      </time>
    </div>
  </a>
</article>
