const c = COPY[locale] || COPY.fr;
const privacyUrl = locale === "fr" ? "/politique-confidentialite" : `/${locale}/politique-confidentialite`;
const dir = locale === "ar" ? "rtl" : "ltr";
---

<!-- Cookie Banner RGPD - Karmastro cosmic theme -->
<div
  id="cookie-banner"
  class="fixed bottom-4 left-4 right-4 z-[60] hidden md:max-w-lg"
  dir={dir}
  style="
    background: rgba(10, 10, 15, 0.92);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(139, 92, 246, 0.15);
    border-radius: 20px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
    padding: 20px;
  "
>
  <div class="flex items-start gap-3 mb-4">
    <span class="text-2xl">🔮</span>
    <div>
      <p class="text-white text-sm font-semibold mb-1" style="font-family: Outfit, sans-serif;">
        {c.title}
      </p>
      <p class="text-xs" style="color: hsl(220 9% 64%);">
        {c.body}
        <a href={privacyUrl} class="underline hover:text-white transition-colors" style="color: hsl(271 91% 65%);">{c.learnMore}</a>
      </p>
    </div>
  </div>

  <div class="flex flex-wrap gap-2">
    <button
      id="cookie-accept"
      class="flex-1 min-w-[100px] text-sm font-semibold text-white py-2.5 px-4 rounded-xl transition-all hover:opacity-90"
      style="background: hsl(271 91% 65%); box-shadow: 0 4px 15px rgba(139, 92, 246, 0.25);"
    >
      {c.acceptAll}
    </button>
    <button
      id="cookie-essential"
      class="flex-1 min-w-[100px] text-sm font-medium py-2.5 px-4 rounded-xl transition-all"
      style="color: hsl(220 9% 64%); border: 1px solid rgba(139, 92, 246, 0.2);"
    >
      {c.essential}
    </button>
    <button
      id="cookie-reject"
      class="text-xs py-2 px-3 rounded-lg transition-colors"
      style="color: hsl(220 9% 44%);"
    >
      {c.reject}
    </button>
  </div>
</div>

<script>
  const banner = document.getElementById("cookie-banner");
  const acceptBtn = document.getElementById("cookie-accept");
  const essentialBtn = document.getElementById("cookie-essential");
  const rejectBtn = document.getElementById("cookie-reject");

  // Read cookie (shared across subdomains via .karmastro.com)
  function getCookie(name: string): string | null {
    const match = document.cookie.match(new RegExp("(^| )" + name + "=([^;]+)"));
    return match ? match[2] : null;
  }

  // Show banner if no consent saved
  if (!getCookie("cookie-consent")) {
    setTimeout(() => {
      banner?.classList.remove("hidden");
      banner?.classList.add("animate-slide-up");
    }, 1500);
  }

  function saveConsent(level: string) {
    // Set cookie on .karmastro.com (shared between site + app)
    const expires = new Date(Date.now() + 365 * 86400000).toUTCString();
    document.cookie = `cookie-consent=${level};expires=${expires};path=/;domain=.karmastro.com;SameSite=Lax`;
    banner?.classList.add("hidden");
  }

  acceptBtn?.addEventListener("click", () => saveConsent("all"));
  essentialBtn?.addEventListener("click", () => saveConsent("essential"));
  rejectBtn?.addEventListener("click", () => saveConsent("none"));
</script>

<style>
  @keyframes slide-up {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  .animate-slide-up {
    animation: slide-up 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }
</style>
