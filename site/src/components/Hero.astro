---
import { siteConfig } from "../../site.config";
---

<section class="relative overflow-hidden py-20 md:py-32 px-4 bg-starfield">
  <!-- Constellation patterns background -->
  <div class="absolute inset-0 z-0" style="background-image: url('/constellations.svg'); background-size: cover; background-position: center;"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <p class="text-sm font-medium uppercase tracking-widest mb-4 text-gradient-gold">Astrologie + Numérologie + Karma</p>
    <h1 class="mb-6 text-gradient-violet" data-speakable>
      {siteConfig.tagline}
    </h1>
    <p class="text-lg md:text-xl max-w-2xl mx-auto mb-10" style="color: var(--text-muted);" data-speakable>
      {siteConfig.description}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      {siteConfig.appUrl && (
        <a
          href={siteConfig.appUrl}
          class="inline-flex items-center justify-center gap-2 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-all hover:scale-105 glow-violet"
          style="background: hsl(271 91% 65%);"
        >
          Découvrir mon profil cosmique
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      )}
      <a
        href="/blog"
        class="inline-flex items-center justify-center gap-2 font-semibold px-8 py-4 rounded-xl text-lg border-glow transition-all hover:border-[hsl(271_91%_65%_/_0.4)]"
        style="color: var(--text-muted);"
      >
        Explorer Le Cosmos
      </a>
    </div>
    <p class="mt-6 text-xs" style="color: rgba(196, 184, 219, 0.5);">Offert par les astres - Thème natal + 3 messages Oracle/jour</p>
    <a href="/precision" class="inline-flex items-center gap-1.5 mt-3 text-[11px] transition-colors" style="color: hsl(220 9% 40%); border: 1px solid hsl(0 0% 100% / 0.05); border-radius: 9999px; padding: 4px 12px;">
      <span style="width: 6px; height: 6px; border-radius: 50%; background: hsl(142 71% 45%); display: inline-block;"></span>
      Calculs astronomiques précision NASA
    </a>
  </div>
</section>
