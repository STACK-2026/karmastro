---
import { siteConfig } from "../../site.config";
---

<section class="relative overflow-hidden py-12 md:py-32 px-3 md:px-4 bg-starfield">
  <!-- Constellation patterns background -->
  <div class="absolute inset-0 z-0" style="background-image: url('/constellations.svg'); background-size: cover; background-position: center;"></div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <p class="text-xs md:text-sm font-medium uppercase tracking-widest mb-3 md:mb-4 text-gradient-gold">Astrologie + Numérologie + Karma</p>

    <h1 class="mb-4 md:mb-6 text-gradient-violet text-3xl md:text-5xl lg:text-6xl" data-speakable style="font-family: Outfit, sans-serif; font-weight: 700; line-height: 1.1;">
      {siteConfig.tagline}
    </h1>

    <!-- Rotating text -->
    <p class="text-base md:text-lg mb-6 md:mb-8" style="color: var(--text-muted);">
      On s'occupe de :
      <span id="rotating-text" class="text-gradient-violet font-semibold"></span>
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      {siteConfig.appUrl && (
        <a
          href={siteConfig.appUrl}
          class="inline-flex items-center justify-center gap-2 text-white font-semibold px-6 md:px-8 py-3.5 md:py-4 rounded-xl text-base md:text-lg transition-all hover:scale-105 glow-violet"
          style="background: hsl(271 91% 65%);"
        >
          Découvrir mon profil cosmique
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      )}
      <a
        href="/blog"
        class="inline-flex items-center justify-center gap-2 font-semibold px-6 md:px-8 py-3.5 md:py-4 rounded-xl text-base md:text-lg border-glow transition-all hover:border-[hsl(271_91%_65%_/_0.4)]"
        style="color: var(--text-muted); background: rgba(255,255,255,0.03);"
      >
        Explorer Le Cosmos
      </a>
    </div>
    <p class="mt-4 text-[11px]" style="color: rgba(196, 184, 219, 0.5);">Offert par les astres - Thème natal + 3 messages Oracle/jour</p>
    <a href="/precision" id="nasa-badge" class="inline-flex items-center gap-1.5 mt-2 text-[10px] md:text-[11px] transition-colors" style="color: rgba(196, 184, 219, 0.4); border: 1px solid rgba(255,255,255,0.05); border-radius: 9999px; padding: 3px 10px;">
      <span style="width: 5px; height: 5px; border-radius: 50%; background: hsl(142 71% 45%); display: inline-block;" class="animate-pulse"></span>
      <span id="nasa-text">Calculs astronomiques précision NASA</span>
    </a>
  </div>
</section>

<script>
  // Rotating text animation
  const words = ["ton thème natal", "ta numérologie", "ton karma", "tes transits", "ta compatibilité", "ton chemin de vie"];
  const el = document.getElementById("rotating-text");
  let idx = 0;

  function rotateText() {
    if (!el) return;
    el.style.opacity = "0";
    el.style.transform = "translateY(8px)";
    setTimeout(() => {
      el.textContent = words[idx];
      el.style.opacity = "1";
      el.style.transform = "translateY(0)";
      idx = (idx + 1) % words.length;
    }, 300);
  }

  if (el) {
    el.style.transition = "opacity 0.3s, transform 0.3s";
    el.style.display = "inline-block";
    el.textContent = words[0];
    setInterval(rotateText, 2500);
  }

  // Dynamic NASA badge — show time + location
  const nasaText = document.getElementById("nasa-text");
  if (nasaText) {
    const now = new Date();
    const time = now.toLocaleTimeString("fr-FR", { hour: "2-digit", minute: "2-digit" });

    // Get city from timezone (zero API call, instant)
    const tz = Intl.DateTimeFormat().resolvedOptions().timeZone; // ex: "Europe/Paris"
    const cityMap: Record<string, string> = {
      "Europe/Paris": "Paris", "Europe/London": "Londres", "Europe/Berlin": "Berlin",
      "Europe/Madrid": "Madrid", "Europe/Rome": "Rome", "Europe/Brussels": "Bruxelles",
      "Europe/Zurich": "Zurich", "Europe/Amsterdam": "Amsterdam", "Europe/Vienna": "Vienne",
      "Europe/Lisbon": "Lisbonne", "Europe/Warsaw": "Varsovie", "Europe/Prague": "Prague",
      "Europe/Stockholm": "Stockholm", "Europe/Helsinki": "Helsinki", "Europe/Athens": "Athènes",
      "Europe/Bucharest": "Bucarest", "Europe/Dublin": "Dublin", "Europe/Oslo": "Oslo",
      "America/New_York": "New York", "America/Los_Angeles": "Los Angeles",
      "America/Chicago": "Chicago", "America/Toronto": "Toronto",
      "America/Montreal": "Montréal", "Asia/Tokyo": "Tokyo",
      "Africa/Casablanca": "Casablanca", "Africa/Tunis": "Tunis", "Africa/Algiers": "Alger",
    };
    const city = cityMap[tz] || tz.split("/").pop()?.replace(/_/g, " ") || "";

    nasaText.textContent = `Précision NASA · ${time} · ${city}`;
  }
</script>
