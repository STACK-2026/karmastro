---
import { siteConfig } from "../../site.config";
import { extractLocale } from "../i18n/config";
import { getContent } from "../i18n/content";

const locale = extractLocale(Astro.url.pathname);
const content = getContent(locale);

const iconMap: Record<string, string> = {
  zap: "M13 10V3L4 14h7v7l9-11h-7z",
  shield: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  chart: "M18 20V10M12 20V4M6 20v-6",
  search: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z",
  users: "M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zm14 10v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75",
  star: "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z",
};
---

<section class="py-20 px-4 relative" style="background: linear-gradient(to bottom, transparent, hsl(260 25% 5% / 0.6) 15%, hsl(260 25% 5% / 0.6) 85%, transparent);">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-center mb-4" set:html={content.featuresTitle.replace(siteConfig.name, `<span class="text-gradient-violet">${siteConfig.name}</span>`)}></h2>
    <p class="text-center mb-12" style="color: rgba(255, 255, 255, 0.65);">{content.featuresSubtitle}</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {content.features.map((feature) => (
        <div class="rounded-xl p-8 border-glow transition-all hover:glow-violet" style="background: var(--bg-card);">
          <div
            class="w-12 h-12 rounded-xl flex items-center justify-center mb-5"
            style="background: hsl(271 91% 65% / 0.1);"
          >
            <svg
              class="w-6 h-6"
              fill="none"
              stroke="hsl(271 91% 65%)"
              viewBox="0 0 24 24"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d={iconMap[feature.icon] || iconMap.zap} />
            </svg>
          </div>
          <h3 class="text-lg font-bold mb-2 text-white">{feature.title}</h3>
          <p style="color: rgba(255, 255, 255, 0.7);">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
