---
import { siteConfig } from "../../site.config";
---

<!-- Floating glass header (inspired by ScoreImmo, dark theme) -->
<header
  id="site-header"
  class="fixed z-50 flex items-center justify-between transition-transform duration-500 ease-in-out"
  style="
    top: 8px; left: 8px; right: 8px;
    height: 56px;
    padding: 0 16px;
    background: rgba(15, 10, 30, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(139, 92, 246, 0.12);
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  "
>
  <!-- Logo -->
  <a href="/" class="flex items-center gap-2.5 no-underline">
    <div class="w-8 h-8 rounded-xl flex items-center justify-center" style="background: hsl(271 91% 65%);">
      <span class="text-white text-xs font-bold" style="font-family: Outfit, sans-serif;">K</span>
    </div>
    <span class="text-white font-bold text-xl tracking-tight" style="font-family: Outfit, sans-serif;">{siteConfig.name}</span>
  </a>

  <!-- Desktop nav -->
  <nav class="hidden md:flex items-center gap-6">
    {siteConfig.navLinks.map((link) => (
      <a
        href={link.href}
        class="nav-link text-sm font-medium no-underline relative"
        style="color: var(--text-muted);"
        {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
      >
        {link.label}
      </a>
    ))}
  </nav>

  <!-- CTA desktop -->
  {siteConfig.appUrl && (
    <a
      href={siteConfig.appUrl}
      class="hidden md:inline-flex items-center gap-2 text-sm font-semibold text-white no-underline transition-all"
      style="
        background: hsl(271 91% 65%);
        padding: 10px 24px;
        height: 40px;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(139, 92, 246, 0.25);
      "
    >
      Mon profil cosmique
      <svg class="w-4 h-4 arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </a>
  )}

  <!-- Mobile hamburger -->
  <button
    id="mobile-menu-btn"
    class="md:hidden flex items-center justify-center w-10 h-10 rounded-xl"
    style="color: white;"
    aria-label="Menu"
    aria-expanded="false"
  >
    <svg id="menu-open-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
    <svg id="menu-close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</header>

<!-- Mobile overlay -->
<div id="mobile-overlay" class="fixed inset-0 z-40 hidden" style="background: rgba(0,0,0,0.5); transition: opacity 0.3s;"></div>

<!-- Mobile drawer -->
<div
  id="mobile-drawer"
  class="fixed z-50 flex flex-col"
  style="
    top: 8px; right: 8px; bottom: 8px;
    width: 280px;
    background: rgba(15, 10, 30, 0.92);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid rgba(139, 92, 246, 0.15);
    border-radius: 20px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
    transform: translateX(calc(100% + 8px));
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    overflow: hidden;
  "
>
  <div class="flex items-center justify-between p-4" style="border-bottom: 1px solid rgba(139, 92, 246, 0.1);">
    <span class="text-white font-bold" style="font-family: Outfit, sans-serif;">{siteConfig.name}</span>
    <button id="drawer-close" class="w-8 h-8 flex items-center justify-center rounded-lg" style="color: var(--text-muted);">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
  <nav class="flex-1 p-3 space-y-1">
    {siteConfig.navLinks.map((link) => (
      <a
        href={link.href}
        class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium no-underline transition-colors"
        style="color: white;"
        {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
      >
        {link.label}
      </a>
    ))}
  </nav>
  {siteConfig.appUrl && (
    <div class="p-4">
      <a
        href={siteConfig.appUrl}
        class="flex items-center justify-center gap-2 text-white font-semibold py-3 rounded-xl no-underline"
        style="background: hsl(271 91% 65%);"
      >
        Mon profil cosmique
      </a>
    </div>
  )}
</div>

<!-- Spacer for fixed header -->
<div class="h-[72px]"></div>

<style>
  /* Animated underline on nav links */
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: hsl(271 91% 65%);
    border-radius: 1px;
    transition: width 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .nav-link:hover::after { width: 100%; }
  .nav-link:hover { color: white !important; }

  /* CTA hover */
  a:has(.arrow-icon):hover { opacity: 0.9; transform: translateY(-1px); }
  a:has(.arrow-icon):hover .arrow-icon { transform: translateX(3px); }
  .arrow-icon { transition: transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94); }

  /* Mobile drawer open state */
  #mobile-drawer.open { transform: translateX(0) !important; }
  #mobile-overlay.open { display: block !important; opacity: 1; }
  #mobile-drawer nav a:hover { background: rgba(139, 92, 246, 0.08); }
</style>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const drawer = document.getElementById("mobile-drawer");
  const overlay = document.getElementById("mobile-overlay");
  const closeBtn = document.getElementById("drawer-close");
  const openIcon = document.getElementById("menu-open-icon");
  const closeIcon = document.getElementById("menu-close-icon");

  function toggleMenu(open) {
    drawer?.classList.toggle("open", open);
    overlay?.classList.toggle("open", open);
    openIcon?.classList.toggle("hidden", open);
    closeIcon?.classList.toggle("hidden", !open);
    btn?.setAttribute("aria-expanded", String(open));
  }

  btn?.addEventListener("click", () => toggleMenu(!drawer?.classList.contains("open")));
  closeBtn?.addEventListener("click", () => toggleMenu(false));
  overlay?.addEventListener("click", () => toggleMenu(false));

  // Header hide/show on scroll (500ms ease-in-out)
  let lastY = 0;
  const header = document.getElementById("site-header");
  window.addEventListener("scroll", () => {
    const y = window.scrollY;
    if (y > 450 && y > lastY) {
      header?.classList.add("-translate-y-[120%]");
    } else {
      header?.classList.remove("-translate-y-[120%]");
    }
    lastY = y;
  }, { passive: true });
</script>
