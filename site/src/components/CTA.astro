---
import { siteConfig } from "../../site.config";
---

<section class="py-20 px-4">
  <div
    class="max-w-4xl mx-auto text-center rounded-2xl p-12 md:p-16 border-glow glow-violet"
    style="background: hsl(260 25% 8%);"
  >
    <p class="text-sm font-medium uppercase tracking-widest mb-4 text-gradient-gold">Offert par les astres</p>
    <h2 class="text-white mb-4">Commence ton éveil cosmique</h2>
    <p class="text-lg mb-8 max-w-xl mx-auto" style="color: hsl(220 9% 64%);">
      Thème natal, chemin de vie, guidance karmique. Les astres t'attendent.
    </p>
    {siteConfig.appUrl && (
      <a
        href={siteConfig.appUrl}
        class="inline-flex items-center gap-2 font-bold px-8 py-4 rounded-xl text-lg transition-all hover:scale-105 text-white glow-violet"
        style="background: hsl(271 91% 65%);"
      >
        Commencer mon éveil
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    )}
    <p class="mt-4 text-xs" style="color: hsl(220 9% 44%);">Aucune carte bancaire requise</p>
  </div>
</section>
