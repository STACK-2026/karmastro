---
import { siteConfig } from "../../site.config";
import { extractLocale } from "../i18n/config";
import { getContent } from "../i18n/content";
import { t } from "../i18n/translations";

const locale = extractLocale(Astro.url.pathname);
const content = getContent(locale);
---

<section class="py-20 px-4">
  <div
    class="max-w-4xl mx-auto text-center rounded-2xl p-12 md:p-16 border-glow glow-violet"
    style="background: var(--bg-card);"
  >
    <p class="text-sm font-medium uppercase tracking-widest mb-4 text-gradient-gold">{t("hero.free_badge", locale)}</p>
    <h2 class="text-white mb-4">{content.ctaTitle}</h2>
    <p class="text-lg mb-8 max-w-xl mx-auto" style="color: rgba(255, 255, 255, 0.75);">
      {content.ctaSubtitle}
    </p>
    {siteConfig.appUrl && (
      <a
        href={siteConfig.appUrl}
        class="inline-flex items-center gap-2 font-bold px-8 py-4 rounded-xl text-lg transition-all hover:scale-105 text-white glow-violet"
        style="background: hsl(271 91% 65%);"
      >
        {content.ctaButton}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    )}
    <p class="mt-4 text-xs" style="color: rgba(196, 184, 219, 0.5);">{content.ctaNoCard}</p>
  </div>
</section>
