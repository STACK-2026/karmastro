---
// Reusable share button component
// - Uses Web Share API on mobile (native share sheet)
// - Falls back to dropdown with copy link + Twitter/Facebook/WhatsApp/email on desktop
// - All JS is vanilla, no dependencies

interface Props {
  title: string;
  text: string;
  url?: string;
  variant?: "primary" | "secondary" | "minimal";
  label?: string;
  className?: string;
}

const {
  title,
  text,
  url,
  variant = "primary",
  label = "Partager",
  className = "",
} = Astro.props;

const baseUrl = url || Astro.url.href;

const variantClasses = {
  primary: "bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] hover:opacity-90",
  secondary: "border border-amber-300/40 text-amber-300 hover:bg-amber-300/10",
  minimal: "text-amber-300 hover:text-amber-200 underline-offset-4 hover:underline",
};
---

<div class={`share-widget relative inline-block ${className}`} data-share-url={baseUrl} data-share-title={title} data-share-text={text}>
  <button
    type="button"
    class={`share-trigger inline-flex items-center gap-2 px-4 py-2 rounded-xl font-medium text-sm transition-all ${variantClasses[variant]}`}
    aria-label={label}
    aria-expanded="false"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="18" cy="5" r="3"></circle>
      <circle cx="6" cy="12" r="3"></circle>
      <circle cx="18" cy="19" r="3"></circle>
      <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
      <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
    </svg>
    {label}
  </button>

  <div class="share-menu hidden absolute right-0 top-full mt-2 z-50 min-w-[240px] p-2 rounded-2xl border border-white/15 bg-[#0f0a1e]/95 backdrop-blur-xl shadow-2xl">
    <button type="button" data-action="copy" class="share-action w-full text-left px-3 py-2 rounded-lg text-sm text-white/80 hover:bg-white/5 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
      <span class="copy-label">Copier le lien</span>
    </button>
    <a data-action="twitter" href="#" target="_blank" rel="noopener noreferrer" class="share-action w-full text-left px-3 py-2 rounded-lg text-sm text-white/80 hover:bg-white/5 flex items-center gap-2 no-underline">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      Twitter / X
    </a>
    <a data-action="facebook" href="#" target="_blank" rel="noopener noreferrer" class="share-action w-full text-left px-3 py-2 rounded-lg text-sm text-white/80 hover:bg-white/5 flex items-center gap-2 no-underline">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      Facebook
    </a>
    <a data-action="whatsapp" href="#" target="_blank" rel="noopener noreferrer" class="share-action w-full text-left px-3 py-2 rounded-lg text-sm text-white/80 hover:bg-white/5 flex items-center gap-2 no-underline">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      WhatsApp
    </a>
    <a data-action="email" href="#" class="share-action w-full text-left px-3 py-2 rounded-lg text-sm text-white/80 hover:bg-white/5 flex items-center gap-2 no-underline">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
      Email
    </a>
  </div>
</div>

<script>
  function setupShareWidgets() {
    document.querySelectorAll<HTMLElement>(".share-widget").forEach((widget) => {
      if (widget.dataset.initialized === "true") return;
      widget.dataset.initialized = "true";

      const trigger = widget.querySelector<HTMLButtonElement>(".share-trigger");
      const menu = widget.querySelector<HTMLElement>(".share-menu");
      if (!trigger || !menu) return;

      const url = widget.dataset.shareUrl || location.href;
      const title = widget.dataset.shareTitle || document.title;
      const text = widget.dataset.shareText || "";

      // Update all link hrefs with proper share URLs
      const encodedUrl = encodeURIComponent(url);
      const encodedText = encodeURIComponent(text);
      const encodedTitle = encodeURIComponent(title);

      const actions: Record<string, string> = {
        twitter: `https://twitter.com/intent/tweet?text=${encodedText}&url=${encodedUrl}`,
        facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
        whatsapp: `https://wa.me/?text=${encodedText}%20${encodedUrl}`,
        email: `mailto:?subject=${encodedTitle}&body=${encodedText}%0A%0A${encodedUrl}`,
      };

      for (const [action, href] of Object.entries(actions)) {
        const link = widget.querySelector<HTMLAnchorElement>(`[data-action="${action}"]`);
        if (link) link.href = href;
      }

      // Trigger: Web Share API if available, else toggle menu
      trigger.addEventListener("click", async (e) => {
        e.stopPropagation();

        // Try native share first (mobile)
        if (typeof navigator.share === "function") {
          try {
            await navigator.share({ title, text, url });
            return;
          } catch (err) {
            // User cancelled or share failed, fall through to menu
            if ((err as Error).name === "AbortError") return;
          }
        }

        // Desktop: toggle menu
        const isOpen = !menu.classList.contains("hidden");
        // Close all other menus first
        document.querySelectorAll(".share-menu").forEach((m) => m.classList.add("hidden"));
        if (!isOpen) menu.classList.remove("hidden");
        trigger.setAttribute("aria-expanded", String(!isOpen));
      });

      // Copy action
      const copyBtn = widget.querySelector<HTMLButtonElement>('[data-action="copy"]');
      const copyLabel = widget.querySelector<HTMLElement>(".copy-label");
      copyBtn?.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(url);
          if (copyLabel) copyLabel.textContent = "Lien copié ✦";
          setTimeout(() => {
            if (copyLabel) copyLabel.textContent = "Copier le lien";
          }, 2000);
        } catch (err) {
          console.error("Clipboard failed:", err);
        }
      });

      // Click outside → close
      document.addEventListener("click", (e) => {
        if (!widget.contains(e.target as Node)) {
          menu.classList.add("hidden");
          trigger.setAttribute("aria-expanded", "false");
        }
      });
    });
  }

  setupShareWidgets();
  document.addEventListener("astro:page-load", setupShareWidgets);
</script>
