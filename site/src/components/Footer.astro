---
import { siteConfig } from "../../site.config";
import { extractLocale, DEFAULT_LOCALE } from "../i18n/config";
import { t } from "../i18n/translations";
import { getContent } from "../i18n/content";

const locale = extractLocale(Astro.url.pathname);
const content = getContent(locale);
const currentYear = new Date().getFullYear();

// Build localized paths
const localizedPath = (path: string) => {
  const p = path.endsWith("/") ? path : `${path}/`;
  return locale === DEFAULT_LOCALE ? p : `/${locale}${p}`;
};

// Pages legales/about non encore localisees : pointer vers la version FR avec lang="fr"
// pour eviter les 404. A retirer quand les versions localisees sont creees.
const FR_ONLY_PAGES = new Set([
  "/mentions-legales",
  "/cgv",
  "/politique-confidentialite",
  "/glossaire",
  "/notre-histoire",
  "/precision",
]);
const safePath = (path: string) => FR_ONLY_PAGES.has(path) ? path : localizedPath(path);
const isFrFallback = (path: string) => locale !== DEFAULT_LOCALE && FR_ONLY_PAGES.has(path);
---

<div style="height: 60px; background: linear-gradient(to bottom, transparent, var(--bg-card)); pointer-events: none;" class="relative z-10"></div>
<footer style="background: var(--bg-card);" class="relative z-10">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <p class="text-white font-bold text-lg mb-2" style="font-family: Outfit, sans-serif;">{siteConfig.name}</p>
        <p class="text-sm" style="color: rgba(255, 255, 255, 0.7);">{t("footer.tagline", locale)}</p>
        <p class="text-xs italic mt-4" style="color: rgba(255, 255, 255, 0.4);">
          « {t("footer.quote", locale)} »<br/>
          <span class="text-[10px]">- {t("footer.quote_author", locale)}</span>
        </p>
      </div>

      <!-- Legal links -->
      <div>
        <p class="text-white font-semibold text-sm mb-3">{content.footerLegalTitle}</p>
        <ul class="space-y-2 text-sm" style="color: rgba(255, 255, 255, 0.7);">
          <li><a href={safePath("/mentions-legales")} hreflang={isFrFallback("/mentions-legales") ? "fr" : undefined} class="hover:text-white transition-colors">{t("footer.legal", locale)}</a></li>
          <li><a href={safePath("/cgv")} hreflang={isFrFallback("/cgv") ? "fr" : undefined} class="hover:text-white transition-colors">{t("footer.cgv", locale)}</a></li>
          <li><a href={safePath("/politique-confidentialite")} hreflang={isFrFallback("/politique-confidentialite") ? "fr" : undefined} class="hover:text-white transition-colors">{t("footer.privacy", locale)}</a></li>
        </ul>
      </div>

      <!-- Explore links -->
      <div>
        <p class="text-white font-semibold text-sm mb-3">{content.footerExploreTitle}</p>
        <ul class="space-y-2 text-sm" style="color: rgba(255, 255, 255, 0.7);">
          <li><a href={localizedPath("/blog")} class="hover:text-white transition-colors">{t("nav.blog", locale)}</a></li>
          <li><a href={`${siteConfig.appUrl}/oracle`} class="hover:text-white transition-colors">{t("nav.oracle", locale)}</a></li>
          <li><a href={safePath("/glossaire")} hreflang={isFrFallback("/glossaire") ? "fr" : undefined} class="hover:text-white transition-colors">{t("nav.glossary", locale)}</a></li>
          <li><a href={safePath("/notre-histoire")} hreflang={isFrFallback("/notre-histoire") ? "fr" : undefined} class="hover:text-white transition-colors">{t("nav.about", locale)}</a></li>
          <li><a href={safePath("/precision")} hreflang={isFrFallback("/precision") ? "fr" : undefined} class="hover:text-white transition-colors">{t("nav.precision", locale)}</a></li>
          <li><a href={`mailto:${siteConfig.legal.email}`} class="hover:text-white transition-colors">{siteConfig.legal.email}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 text-center text-xs" style="border-top: 1px solid hsl(260 20% 12%); color: rgba(196, 184, 219, 0.5);">
      <p>&copy; {currentYear} {siteConfig.name}. {content.footerCopyright}.</p>
    </div>
  </div>
</footer>
