---
import { siteConfig } from "../../site.config";

const currentYear = new Date().getFullYear();
---

<div style="height: 60px; background: linear-gradient(to bottom, transparent, var(--bg-card)); pointer-events: none;" class="relative z-10"></div>
<footer style="background: var(--bg-card);" class="relative z-10">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <p class="text-white font-bold text-lg mb-2" style="font-family: Outfit, sans-serif;">{siteConfig.name}</p>
        <p class="text-sm" style="color: var(--text-muted);">{siteConfig.tagline}</p>
      </div>

      <!-- Legal links -->
      <div>
        <p class="text-white font-semibold text-sm mb-3">Informations légales</p>
        <ul class="space-y-2 text-sm" style="color: var(--text-muted);">
          <li><a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a></li>
          <li><a href="/cgv" class="hover:text-white transition-colors">Conditions générales</a></li>
          <li><a href="/politique-confidentialite" class="hover:text-white transition-colors">Confidentialité</a></li>
        </ul>
      </div>

      <!-- Contact + Links -->
      <div>
        <p class="text-white font-semibold text-sm mb-3">Explorer</p>
        <ul class="space-y-2 text-sm" style="color: var(--text-muted);">
          <li><a href="/blog" class="hover:text-white transition-colors">Le Cosmos (blog)</a></li>
          <li><a href={`${siteConfig.appUrl}/oracle`} class="hover:text-white transition-colors">L'Oracle</a></li>
          <li><a href={`mailto:${siteConfig.legal.email}`} class="hover:text-white transition-colors">{siteConfig.legal.email}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 text-center text-xs" style="border-top: 1px solid hsl(260 20% 12%); color: rgba(196, 184, 219, 0.5);">
      <p>&copy; {currentYear} {siteConfig.name}. Tous droits réservés.</p>
    </div>
  </div>
</footer>
