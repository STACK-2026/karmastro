const cfg = CONFIG[lang];
function pickTool(s: string, c: Cfg): Tool {
  const low = s.toLowerCase();
  for (const [re, t] of c.rules) if (re.test(low)) return c.tools[t];
  return c.fallback; // jamais null pour une langue supportée
}
const data = cfg ? pickTool(slug, cfg) : null;
---
{cfg && data && (
  <aside class="not-prose my-12">
    <a
      href={data.url}
      class="group relative flex items-center gap-5 p-6 rounded-2xl bg-gradient-to-br from-purple-400/[0.12] to-amber-300/[0.10] border border-amber-300/30 hover:border-amber-300/60 hover:from-purple-400/[0.18] hover:to-amber-300/[0.16] transition-all no-underline"
    >
      <div class="hidden sm:flex shrink-0 h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-purple-400/30 to-amber-300/30 text-2xl">✦</div>
      <div class="flex-1 min-w-0">
        <p class="text-[11px] uppercase tracking-widest text-amber-300/80 mb-1">{cfg.eyebrow}</p>
        <p class="font-serif text-lg text-white leading-snug mb-1">{cfg.verb} {data.name} <span class="text-amber-300/90">{cfg.free}</span></p>
        <p class="text-sm text-white/65 leading-relaxed">{data.hook}</p>
      </div>
      <span class="shrink-0 inline-flex items-center gap-1.5 px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold text-sm group-hover:gap-2.5 transition-all">
        {cfg.cta}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </span>
    </a>
  </aside>
)}
