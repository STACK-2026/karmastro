---
// CTA contextuel "passe à la pratique" injecté en fin d'article de blog.
// Choisit l'outil le plus pertinent selon le slug et renvoie au calculateur gratuit
// (qui porte l'upsell lecture + le pont vers l'Oracle/app). Si aucun outil précis
// ne matche, un fallback renvoie vers le hub d'outils de la langue : ainsi chaque
// article d'une langue supportée a TOUJOURS une insertion vers la pratique. [2026-06-30]
interface Props {
  slug: string;
  lang?: string;
}
const { slug, lang = "fr" } = Astro.props;

type Tool = { url: string; name: string; hook: string };
type Cfg = {
  eyebrow: string; verb: string; free: string; cta: string;
  tools: Record<string, Tool>;
  rules: [RegExp, string][];
  fallback: Tool;
};

const CONFIG: Record<string, Cfg> = {
