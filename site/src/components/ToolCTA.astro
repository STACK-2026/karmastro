---
// CTA contextuel "passe à la pratique" injecté en fin d'article de blog.
// Choisit l'outil le plus pertinent selon le slug et renvoie au calculateur gratuit
// (qui porte l'upsell lecture 4,90€). Ne s'affiche QUE vers des outils monétisés
// dans la langue courante (FR : 9 outils ; EN : 3 outils numérologie pour l'instant). [2026-06-01]
interface Props {
  slug: string;
  lang?: string;
}
const { slug, lang = "fr" } = Astro.props;

type Tool = { url: string; name: string; hook: string };
type Cfg = { eyebrow: string; verb: string; cta: string; tools: Record<string, Tool>; rules: [RegExp, string][] };

const CONFIG: Record<string, Cfg> = {
  fr: {
    eyebrow: "Passe à la pratique",
    verb: "Calcule",
    cta: "Calculer ✦",
    tools: {
      "chemin-de-vie": { url: "/outils/chemin-de-vie/", name: "ton chemin de vie", hook: "Le nombre qui guide toute ta vie, calculé en 30 secondes." },
      "nombre-expression": { url: "/outils/nombre-expression/", name: "ton nombre d'expression", hook: "Ce que la vibration de ton nom révèle de tes talents." },
      "annee-personnelle": { url: "/outils/annee-personnelle/", name: "ton année personnelle", hook: "L'énergie de ton cycle de l'année, à l'instant." },
      "dette-karmique": { url: "/outils/dette-karmique/", name: "ta dette karmique", hook: "Découvre si ton âme porte une mémoire karmique à libérer." },
      "compatibilite": { url: "/outils/compatibilite/", name: "votre compatibilité", hook: "L'harmonie entre vos deux profils, en 30 secondes." },
      "synastrie": { url: "/outils/synastrie/", name: "votre synastrie", hook: "Vos deux thèmes croisés, aspect par aspect (Swiss Ephemeris)." },
      "ascendant": { url: "/outils/ascendant/", name: "ton ascendant", hook: "Le signe qui se levait à ta naissance, précis à la minute." },
      "theme-natal": { url: "/outils/theme-natal/", name: "ton thème natal", hook: "La carte complète du ciel à ta naissance (Swiss Ephemeris)." },
      "transits": { url: "/outils/transits/", name: "tes transits du jour", hook: "Ce que le ciel active dans ta vie en ce moment." },
    },
    rules: [
      [/synastr/, "synastrie"],
      [/ascendant/, "ascendant"],
      [/(theme-natal|maisons?|carte-ciel|carte-du-ciel|chakras)/, "theme-natal"],
      [/(retrograd|transit|mercure|saturne|pluton|jupiter|neptune|uranus|\bmars\b|venus|lune|pleine-lune|eclipse|cycles-planetaires)/, "transits"],
      [/(compatibilit|amoureuse|\bcouple|attir|sattir|signes-zodiaque|incompat)/, "compatibilite"],
      [/(annee-personnelle|cycle-9|fin-cycle)/, "annee-personnelle"],
      [/(dette|karmiqu|\bkarma|noeud|nud|vies-anterieures)/, "dette-karmique"],
      [/(expression|prenom|nom-identite|nombre-personnel)/, "nombre-expression"],
      [/(chemin-de-vie|chemin-vie|life-path)/, "chemin-de-vie"],
      [/(numerolog|maitres?-nombres?|maitre-nombre)/, "chemin-de-vie"],
      [/(signe-ascendant|horoscope|signe-)/, "theme-natal"],
    ],
  },
  // EN : seuls les 3 outils numérologie portent l'upsell pour l'instant.
  en: {
    eyebrow: "Try it yourself",
    verb: "Calculate",
    cta: "Calculate ✦",
    tools: {
      "chemin-de-vie": { url: "/en/tools/life-path-number/", name: "your life path number", hook: "The number that guides your whole life, in 30 seconds." },
      "nombre-expression": { url: "/en/tools/expression-number/", name: "your expression number", hook: "What the vibration of your name reveals about your talents." },
      "annee-personnelle": { url: "/en/tools/personal-year/", name: "your personal year", hook: "The energy of your yearly cycle, right now." },
    },
    rules: [
      [/(personal-year)/, "annee-personnelle"],
      [/(expression-number|expression)/, "nombre-expression"],
      [/(life-path|numerology|number-)/, "chemin-de-vie"],
    ],
  },
};

const cfg = CONFIG[lang];
function pickTool(s: string, c: Cfg): string | null {
  const low = s.toLowerCase();
  for (const [re, t] of c.rules) if (re.test(low)) return t;
  return null;
}
const tool = cfg ? pickTool(slug, cfg) : null;
const data = tool ? cfg.tools[tool] : null;
---
{data && (
  <aside class="not-prose my-10 p-6 rounded-2xl bg-gradient-to-r from-purple-400/10 to-amber-300/10 border border-amber-300/30">
    <div class="flex flex-col sm:flex-row items-center gap-4 text-center sm:text-left">
      <div class="flex-1">
        <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-1">{cfg.eyebrow}</p>
        <p class="font-serif text-lg text-white mb-1">{cfg.verb} {data.name} {lang === "fr" ? "gratuitement" : "free"}</p>
        <p class="text-sm text-white/65 leading-relaxed">{data.hook}</p>
      </div>
      <a
        href={data.url}
        class="shrink-0 inline-block px-6 py-3 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold text-sm hover:opacity-90 transition-opacity"
      >
        {cfg.cta}
      </a>
    </div>
  </aside>
)}
