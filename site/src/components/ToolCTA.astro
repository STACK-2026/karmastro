      "expresion": { url: "/es/herramientas/numero-expresion/", name: "tu número de expresión", hook: "Lo que la vibración de tu nombre revela de tus talentos." },
      "ano-personal": { url: "/es/herramientas/ano-personal/", name: "tu año personal", hook: "La energía de tu ciclo anual, ahora mismo." },
      "ascendente": { url: "/es/herramientas/ascendente/", name: "tu ascendente", hook: "El signo que ascendía en tu nacimiento, preciso al minuto." },
      "carta-natal": { url: "/es/herramientas/carta-natal/", name: "tu carta natal", hook: "El mapa completo del cielo en tu nacimiento (Swiss Ephemeris)." },
      "compatibilidad": { url: "/es/herramientas/compatibilidad/", name: "vuestra compatibilidad", hook: "La armonía entre vuestros dos perfiles, en 30 segundos." },
