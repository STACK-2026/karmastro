      [/ascendant/, "ascendant"],
      [/(theme-natal|maisons?|carte-ciel|carte-du-ciel|chakras|lune|monde-emotionnel|signe-lunaire)/, "theme-natal"],
      [/(retrograd|transit|mercure|saturne|pluton|jupiter|neptune|uranus|\bmars\b|venus|pleine-lune|eclipse|cycles-planetaires|retour-de-saturne)/, "transits"],
      [/(compatibilit|amoureuse|\bcouple|attir|sattir|signes-zodiaque|incompat|belier|taureau|gemeaux|cancer|lion|vierge|balance|scorpion|sagittaire|capricorne|verseau|poissons)/, "compatibilite"],
      [/(annee-personnelle|cycle-9|fin-cycle)/, "annee-personnelle"],
