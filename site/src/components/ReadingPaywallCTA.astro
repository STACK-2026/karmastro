---
// Bloc upsell "lecture complète 4,90€" réutilisable, posé en fin de résultat d'outil.
// Gère le checkout invité (Stripe) côté client via data-attributs : pour l'ascendant,
// géocode le lieu (Nominatim) au clic. Copy i18n pour les langues sans CTA inline
// (es/it/de/pt/tr/ru/pl/ar). FR/EN gardent leur CTA inline. [2026-06-01]
interface Props {
  tool: "chemin-de-vie" | "ascendant";
  locale: string;
}
const { tool, locale } = Astro.props;

// title par {locale}{tool}, le reste générique par locale.
const COPY: Record<string, { eyebrow: string; desc: string; button: string; titles: Record<string, string> }> = {
  es: { eyebrow: "Pasa a la práctica", desc: "Una lectura personalizada de Orion (1100-1400 palabras), entregada al instante en pantalla y por email.", button: "Desbloquear mi lectura completa - 4,90 €", titles: { "chemin-de-vie": "Tu lectura completa del camino de vida", "ascendant": "Tu lectura completa del ascendente" } },
  it: { eyebrow: "Passa alla pratica", desc: "Una lettura personalizzata di Orion (1100-1400 parole), consegnata subito a schermo e via email.", button: "Sblocca la mia lettura completa - 4,90 €", titles: { "chemin-de-vie": "La tua lettura completa del percorso di vita", "ascendant": "La tua lettura completa dell'ascendente" } },
  de: { eyebrow: "In die Praxis", desc: "Eine persönliche Lesung von Orion (1100-1400 Wörter), sofort auf dem Bildschirm und per E-Mail geliefert.", button: "Meine vollständige Lesung freischalten - 4,90 €", titles: { "chemin-de-vie": "Deine vollständige Lebensweg-Lesung", "ascendant": "Deine vollständige Aszendenten-Lesung" } },
  pt: { eyebrow: "Passa à prática", desc: "Uma leitura personalizada de Orion (1100-1400 palavras), entregue na hora no ecrã e por email.", button: "Desbloquear a minha leitura completa - 4,90 €", titles: { "chemin-de-vie": "A tua leitura completa do caminho de vida", "ascendant": "A tua leitura completa do ascendente" } },
  tr: { eyebrow: "Uygulamaya geç", desc: "Orion'dan kişisel bir okuma (1100-1400 kelime), anında ekranda ve e-posta ile.", button: "Tam okumamı aç - 4,90 €", titles: { "chemin-de-vie": "Tam yaşam yolu okuman", "ascendant": "Tam yükselen burç okuman" } },
  ru: { eyebrow: "К практике", desc: "Персональное чтение от Ориона (1100-1400 слов), сразу на экране и по электронной почте.", button: "Открыть мое полное чтение - 4,90 €", titles: { "chemin-de-vie": "Твое полное чтение жизненного пути", "ascendant": "Твое полное чтение асцендента" } },
  pl: { eyebrow: "Przejdź do praktyki", desc: "Spersonalizowane odczytanie od Oriona (1100-1400 słów), od razu na ekranie i e-mailem.", button: "Odblokuj moje pełne odczytanie - 4,90 €", titles: { "chemin-de-vie": "Twoje pełne odczytanie drogi życia", "ascendant": "Twoje pełne odczytanie ascendentu" } },
  ar: { eyebrow: "إلى التطبيق", desc: "قراءة شخصية من أوريون (1100-1400 كلمة)، تصلك فورًا على الشاشة وبالبريد الإلكتروني.", button: "افتح قراءتي الكاملة - 4,90 €", titles: { "chemin-de-vie": "قراءتك الكاملة لمسار الحياة", "ascendant": "قراءتك الكاملة للطالع" } },
};

const c = COPY[locale];
const dir = locale === "ar" ? "rtl" : undefined;
---
{c && (
  <div id="reading-cta" data-tool={tool} data-locale={locale} dir={dir} class="mt-6 pt-5 border-t border-white/10">
    <div class="relative p-5 rounded-xl bg-gradient-to-r from-purple-400/10 to-amber-300/10 border border-amber-300/30 text-center overflow-hidden">
      <p class="text-2xl mb-1">✦</p>
      <p class="text-xs uppercase tracking-widest text-amber-300/80 mb-1">{c.eyebrow}</p>
      <p class="font-serif text-base text-white mb-1">{c.titles[tool]}</p>
      <p class="text-xs text-white/60 mb-4 max-w-sm mx-auto leading-relaxed">{c.desc}</p>
      <button type="button" id="km-buy" class="inline-block px-5 py-2.5 rounded-xl bg-gradient-to-r from-purple-400 to-amber-300 text-[#0f0a1e] font-semibold text-sm hover:opacity-90 transition-opacity">{c.button}</button>
    </div>
  </div>
)}

<script>
  const CHECKOUT_URL = "https://nkjbmbdrvejemzrggxvr.supabase.co/functions/v1/reading-checkout";
  const cta = document.getElementById("reading-cta");
  async function geocode(place: string): Promise<{ lat: number; lon: number } | null> {
    try {
      const r = await fetch(`https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(place)}`, { headers: { "Accept-Language": cta?.getAttribute("data-locale") || "en" } });
      const d = await r.json();
      if (Array.isArray(d) && d[0]) return { lat: parseFloat(d[0].lat), lon: parseFloat(d[0].lon) };
    } catch { /* noop */ }
    return null;
  }
  cta?.addEventListener("click", async (ev) => {
    const btn = (ev.target as HTMLElement).closest("#km-buy") as HTMLButtonElement | null;
    if (!btn) return;
    const tool = cta.getAttribute("data-tool")!;
    const locale = cta.getAttribute("data-locale")!;
    const dateEl = document.getElementById("birth-date") as HTMLInputElement | null;
    const birthDate = dateEl?.value || "";
    if (!birthDate) { btn.classList.add("animate-pulse"); setTimeout(() => btn.classList.remove("animate-pulse"), 1000); return; }
    const original = btn.textContent;
    btn.disabled = true; btn.textContent = "…";
    try {
      const body: Record<string, unknown> = { tool, locale, birthDate };
      if (tool === "ascendant") {
        const time = (document.getElementById("birth-time") as HTMLInputElement | null)?.value || "12:00";
        const place = (document.getElementById("birth-place") as HTMLInputElement | null)?.value || "";
        const geo = place ? await geocode(place) : null;
        if (!geo) { btn.disabled = false; btn.textContent = original; alert("Please calculate first ✦"); return; }
        body.birthTime = time; body.latitude = geo.lat; body.longitude = geo.lon;
      }
      const r = await fetch(CHECKOUT_URL, { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body) });
      const data = await r.json();
      if (data?.url) { window.location.href = data.url; } else { throw new Error(data?.error || "no url"); }
    } catch {
      btn.disabled = false; btn.textContent = original;
      alert("Something went wrong, please try again.");
    }
  });
</script>
