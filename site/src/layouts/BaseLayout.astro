---
import { siteConfig } from "../../site.config";
import { fontsUrl } from "../utils/config";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import { LOCALES, DEFAULT_LOCALE, extractLocale, stripLocalePrefix, isRTL } from "../i18n/config";
import { getLocalizedSlug, getCanonicalSlugFromLocalized } from "../data/zodiac";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  jsonLd?: object | object[];
  noIndex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = siteConfig.ogImage,
  ogType = "website",
  publishedTime,
  jsonLd,
  noIndex = false,
} = Astro.props;

const imageUrl = ogImage?.startsWith("http") ? ogImage : `${siteConfig.url}${ogImage}`;
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// i18n
const currentLocale = extractLocale(Astro.url.pathname);
const isRightToLeft = isRTL(currentLocale);
const pathWithoutLocale = stripLocalePrefix(Astro.url.pathname);

// Build hreflang URLs for all 11 locales.
// For horoscope pages the sign slug is translated per locale (e.g. FR "cancer" vs AR "burj-al-saratan"),
// so we must re-translate the slug when constructing each locale variant - otherwise alternates 404.
const horoscopeMatch = pathWithoutLocale.match(/^\/horoscope\/([^/]+)(\/.*)?$/);
const canonicalSignSlug = horoscopeMatch
  ? (currentLocale === DEFAULT_LOCALE
      ? horoscopeMatch[1]
      : getCanonicalSlugFromLocalized(horoscopeMatch[1], currentLocale))
  : undefined;

const hreflangUrls = LOCALES.map((locale) => {
  const prefix = locale === DEFAULT_LOCALE ? "" : `/${locale}`;
  let path = pathWithoutLocale;
  if (horoscopeMatch && canonicalSignSlug) {
    const translatedSlug = getLocalizedSlug(canonicalSignSlug, locale);
    const tail = horoscopeMatch[2] ?? "";
    path = `/horoscope/${translatedSlug}${tail}`;
  }
  return {
    locale,
    url: `${siteConfig.url}${prefix}${path}`,
  };
});

// x-default points to the default locale variant
const xDefaultUrl = hreflangUrls.find((h) => h.locale === DEFAULT_LOCALE)?.url;
---

<!doctype html>
<html lang={currentLocale} dir={isRightToLeft ? "rtl" : "ltr"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Self-hosted fonts -->
    <link rel="stylesheet" href="/fonts/fonts.css" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="author" content={siteConfig.author} />
    <meta name="keywords" content={siteConfig.keywords.join(", ")} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Hreflang tags for all 11 locales -->
    {hreflangUrls.map(({ locale, url }) => (
      <link rel="alternate" hreflang={locale} href={url} />
    ))}
    {xDefaultUrl && <link rel="alternate" hreflang="x-default" href={xDefaultUrl} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={siteConfig.locale} />
    <meta property="og:site_name" content={siteConfig.name} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {siteConfig.twitterHandle && <meta name="twitter:site" content={siteConfig.twitterHandle} />}

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Karmastro · Le Cosmos & Horoscope" href="/rss.xml" />

    <!-- Analytics tracker -->
    <script src="/tracker.js" defer is:inline></script>

    <!-- JSON-LD -->
    {jsonLdArray.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col relative">
    <!-- Starfield - 3 couches identiques a l'app -->
    <div id="starfield" class="fixed inset-0 pointer-events-none overflow-hidden z-0">
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, hsl(258 46% 12%) 0%, hsl(258 46% 8%) 40%, hsl(258 46% 6%) 100%); opacity: 0.5;"></div>
    </div>

    <Header />
    <main class="flex-1 relative z-10 lg:px-6 xl:px-12 2xl:px-20">
      <slot />
    </main>
    <Footer />
    <CookieBanner />

    <script>
      // Seeded RNG (same positions every load, matching app)
      let _s = 42;
      function rand() { _s = (_s * 16807) % 2147483647; return _s / 2147483647; }

      const driftAnims = ["drift-1", "drift-2", "drift-3"];
      const field = document.getElementById("starfield");
      if (!field) throw new Error("starfield not found");

      // Background layer (60 small stars)
      for (let i = 0; i < 60; i++) {
        const size = rand() * 1.2 + 0.3;
        const d = rand() * 8, dur = rand() * 4 + 3, dd = rand() * 10;
        const drift = driftAnims[Math.floor(rand() * 3)];
        const star = document.createElement("div");
        star.style.cssText = `position:absolute;border-radius:50%;left:${rand()*100}%;top:${rand()*100}%;width:${size}px;height:${size}px;background:white;opacity:${rand()*0.3+0.05};animation:twinkle ${dur}s ease-in-out ${d}s infinite,${drift} ${12+dd}s ease-in-out ${dd}s infinite;will-change:opacity,transform;`;
        field.appendChild(star);
      }

      // Mid layer (25 colored stars)
      for (let i = 0; i < 25; i++) {
        const size = rand() * 1.8 + 0.8;
        const d = rand() * 6, dur = rand() * 3 + 2, dd = rand() * 8;
        const drift = driftAnims[Math.floor(rand() * 3)];
        const r = rand();
        const color = r > 0.7 ? "hsl(43 76% 80%)" : r > 0.4 ? "hsl(220 60% 90%)" : "white";
        const star = document.createElement("div");
        star.style.cssText = `position:absolute;border-radius:50%;left:${rand()*100}%;top:${rand()*100}%;width:${size}px;height:${size}px;background:${color};opacity:${rand()*0.4+0.15};animation:twinkle ${dur}s ease-in-out ${d}s infinite,${drift} ${12+dd}s ease-in-out ${dd}s infinite;will-change:opacity,transform;`;
        field.appendChild(star);
      }

      // Bright layer (8 glowing stars)
      for (let i = 0; i < 8; i++) {
        const size = rand() * 1.5 + 2;
        const d = rand() * 5, dur = rand() * 2.5 + 1.5, dd = rand() * 6;
        const drift = driftAnims[Math.floor(rand() * 3)];
        const color = rand() > 0.5 ? "hsl(271 60% 85%)" : "hsl(43 50% 90%)";
        const star = document.createElement("div");
        star.style.cssText = `position:absolute;border-radius:50%;left:${rand()*100}%;top:${rand()*100}%;width:${size}px;height:${size}px;background:${color};opacity:${rand()*0.3+0.5};box-shadow:0 0 ${size*2}px ${color};animation:twinkle ${dur}s ease-in-out ${d}s infinite,${drift} ${12+dd}s ease-in-out ${dd}s infinite;will-change:opacity,transform;`;
        field.appendChild(star);
      }
    </script>
    <style>
      @keyframes twinkle {
        0%, 100% { opacity: 0.2; }
        50% { opacity: 0.8; }
      }
      @keyframes drift-1 {
        0% { transform: translate(0, 0); }
        25% { transform: translate(2px, -3px); }
        50% { transform: translate(-1px, 2px); }
        75% { transform: translate(3px, 1px); }
        100% { transform: translate(0, 0); }
      }
      @keyframes drift-2 {
        0% { transform: translate(0, 0); }
        25% { transform: translate(-3px, 1px); }
        50% { transform: translate(1px, -2px); }
        75% { transform: translate(-2px, 3px); }
        100% { transform: translate(0, 0); }
      }
      @keyframes drift-3 {
        0% { transform: translate(0, 0); }
        33% { transform: translate(1px, -4px); }
        66% { transform: translate(-2px, 1px); }
        100% { transform: translate(0, 0); }
      }
      /* Fade-in on scroll - JS-only, SSR-safe (visible by default for crawlers/no-JS) */
      .js-fade-in {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s ease-out, transform 0.8s ease-out;
      }
      .js-fade-in.visible {
        opacity: 1;
        transform: translateY(0);
      }
      @media (prefers-reduced-motion: reduce) {
        .js-fade-in { opacity: 1 !important; transform: none !important; transition: none !important; }
      }
    </style>
    <script>
      // JS-only fade-in: apply opacity:0 class ONLY if JS runs.
      // This way AI crawlers, SEO bots, and no-JS users see everything immediately.
      const sections = Array.from(document.querySelectorAll("main section"));
      // Skip the first section (hero) - never fade
      sections.slice(1).forEach(el => el.classList.add("js-fade-in"));

      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add("visible");
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.05, rootMargin: "0px 0px -50px 0px" });

      sections.slice(1).forEach(el => obs.observe(el));

      // Safety net: reveal everything after 2s no matter what (e.g. if observer fails)
      setTimeout(() => {
        document.querySelectorAll(".js-fade-in").forEach(el => el.classList.add("visible"));
      }, 2000);
    </script>

    <!-- Sparkle cursor trail with depth. Disabled for reduced-motion users. -->
    <script is:inline>
      (function () {
        if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        const isMobile = matchMedia("(pointer: coarse)").matches;
        const throttle = isMobile ? 90 : 30;
        const colors = ["#fbbf24", "#c9a8e8", "#ffffff", "#f3d68c"];
        let lastSpawn = 0;
        let active = 0;
        const MAX_ACTIVE = 60;

        function makeStar(x, y, layer) {
          // layer 0 = background (small soft), layer 1 = foreground (big bright)
          const isBg = layer === 0;
          const size = isBg ? 1.5 + Math.random() * 1.5 : 4 + Math.random() * 3.5;
          const color = colors[(Math.random() * colors.length) | 0];
          const spread = isBg ? 30 : 45;
          const dx = (Math.random() - 0.5) * spread;
          const dy = (Math.random() - 0.5) * spread * 0.6 + (isBg ? 12 : 18);
          const dur = isBg ? 900 + Math.random() * 500 : 1100 + Math.random() * 600;
          const initialOpacity = isBg ? 0.6 : 1;
          const glowMultiplier = isBg ? 3 : 5.5;
          const scale = isBg ? 0.5 : 0.2;

          const star = document.createElement("div");
          star.style.cssText =
            "position:fixed;left:" + x + "px;top:" + y + "px;width:" + size + "px;height:" + size +
            "px;background:" + color + ";border-radius:50%;box-shadow:0 0 " + (size * glowMultiplier) + "px " + color +
            ",0 0 " + (size * 2) + "px " + color +
            ";pointer-events:none;z-index:9999;opacity:" + initialOpacity +
            ";transform:translate(-50%,-50%) scale(1);transition:opacity " +
            dur + "ms ease-out,transform " + dur + "ms cubic-bezier(.3,.1,.3,1);will-change:opacity,transform;";
          document.body.appendChild(star);
          active++;

          requestAnimationFrame(function () {
            star.style.opacity = "0";
            star.style.transform = "translate(calc(-50% + " + dx + "px),calc(-50% + " + dy + "px)) scale(" + scale + ")";
          });

          setTimeout(function () {
            star.remove();
            active--;
          }, dur + 80);
        }

        function spawn(x, y) {
          const now = performance.now();
          if (now - lastSpawn < throttle) return;
          if (active >= MAX_ACTIVE) return;
          lastSpawn = now;
          // Foreground bright star
          makeStar(x + (Math.random() - 0.5) * 6, y + (Math.random() - 0.5) * 6, 1);
          // Background soft star (depth layer)
          if (active < MAX_ACTIVE) {
            makeStar(x + (Math.random() - 0.5) * 16, y + (Math.random() - 0.5) * 16, 0);
          }
          // Occasionally a third tiny one for extra twinkle
          if (Math.random() > 0.6 && active < MAX_ACTIVE) {
            makeStar(x + (Math.random() - 0.5) * 24, y + (Math.random() - 0.5) * 24, 0);
          }
        }

        window.addEventListener("mousemove", function (e) { spawn(e.clientX, e.clientY); }, { passive: true });
        window.addEventListener("touchmove", function (e) {
          if (e.touches && e.touches[0]) spawn(e.touches[0].clientX, e.touches[0].clientY);
        }, { passive: true });
      })();
    </script>
  </body>
</html>
