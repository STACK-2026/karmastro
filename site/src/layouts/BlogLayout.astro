---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ShareButton from "../components/ShareButton.astro";
import NewsletterCapture from "../components/NewsletterCapture.astro";
import { siteConfig } from "../../site.config";
import { fullUrl } from "../utils/config";
import { jsonLdArticle, jsonLdBreadcrumbs } from "../utils/seo";

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  category?: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  slug: string;
  keywords?: string;
  lang?: string;
}

const {
  title,
  description,
  date,
  author = siteConfig.blog.defaultAuthor,
  category,
  tags = [],
  image,
  imageAlt,
  slug,
  keywords,
  lang = "fr",
} = Astro.props;

const isDefault = lang === "fr";
const blogPath = isDefault ? `/blog/${slug}` : `/${lang}/blog/${slug}`;
const blogIndexPath = isDefault ? `/blog` : `/${lang}/blog`;
const homePath = isDefault ? "/" : `/${lang}/`;

const articleUrl = fullUrl(blogPath);
const dateStr = date.toISOString().split("T")[0];

const LABELS: Record<string, { home: string; blog: string; share: string; shareBtn: string; locale: string }> = {
  fr: { home: "Accueil", blog: "Blog", share: "Cet article t'a plu ? Partage-le", shareBtn: "Partager l'article", locale: "fr-FR" },
  en: { home: "Home", blog: "Blog", share: "Enjoyed this article? Share it", shareBtn: "Share article", locale: "en-US" },
  es: { home: "Inicio", blog: "Blog", share: "¿Te gusto este articulo? Compartelo", shareBtn: "Compartir articulo", locale: "es-ES" },
  pt: { home: "Inicio", blog: "Blog", share: "Gostou deste artigo? Compartilhe", shareBtn: "Compartilhar artigo", locale: "pt-PT" },
  de: { home: "Startseite", blog: "Blog", share: "Hat dir der Artikel gefallen? Teile ihn", shareBtn: "Artikel teilen", locale: "de-DE" },
  it: { home: "Home", blog: "Blog", share: "Ti e piaciuto l'articolo? Condividilo", shareBtn: "Condividi articolo", locale: "it-IT" },
  tr: { home: "Ana sayfa", blog: "Blog", share: "Makaleyi begendin mi? Paylas", shareBtn: "Makaleyi paylas", locale: "tr-TR" },
  pl: { home: "Strona glowna", blog: "Blog", share: "Spodobal ci sie artykul? Podziel sie nim", shareBtn: "Udostepnij artykul", locale: "pl-PL" },
  ru: { home: "Главная", blog: "Блог", share: "Понравилась статья? Поделись", shareBtn: "Поделиться", locale: "ru-RU" },
  ja: { home: "ホーム", blog: "ブログ", share: "記事が気に入った? シェアしよう", shareBtn: "記事をシェア", locale: "ja-JP" },
  ar: { home: "الرئيسية", blog: "المدونة", share: "هل أعجبك المقال؟ شاركه", shareBtn: "شارك المقال", locale: "ar-SA" },
};
const labels = LABELS[lang] ?? LABELS.fr;

const breadcrumbs = [
  { name: labels.home, url: fullUrl(homePath) },
  { name: labels.blog, url: fullUrl(blogIndexPath) },
  { name: title, url: articleUrl },
];

const jsonLd = [
  jsonLdArticle({
    title,
    description,
    url: articleUrl,
    datePublished: dateStr,
    image,
    author,
    keywords: keywords?.split(",").map((k) => k.trim()),
  }),
  jsonLdBreadcrumbs(breadcrumbs),
];
---

<BaseLayout
  title={`${title} | ${siteConfig.name}`}
  description={description}
  canonicalUrl={articleUrl}
  ogImage={image}
  ogType="article"
  publishedTime={dateStr}
  jsonLd={jsonLd}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      {category && (
        <span class="inline-block bg-primary/10 text-primary text-sm font-medium px-3 py-1 rounded-full mb-4">
          {category}
        </span>
      )}
      <h1 class="mb-4">{title}</h1>
      <div class="flex items-center gap-4 text-gray-500 text-sm">
        <span>{author}</span>
        <span>|</span>
        <time datetime={dateStr}>
          {date.toLocaleDateString(labels.locale, {
            day: "numeric",
            month: "long",
            year: "numeric",
          })}
        </time>
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {image && (
      <figure class="mb-10">
        <img
          src={image}
          alt={imageAlt || title}
          class="w-full rounded-xl"
          loading="eager"
          width="800"
          height="450"
        />
      </figure>
    )}

    <div class="prose max-w-none">
      <slot />
    </div>

    <NewsletterCapture variant="card" source={`blog-${slug}`} />

    <div class="mt-12 pt-8 border-t border-white/10">
      <div class="flex flex-col items-center gap-4">
        <p class="text-sm text-white/60">{labels.share}</p>
        <ShareButton
          title={title}
          text={description}
          url={articleUrl}
          variant="secondary"
          label={labels.shareBtn}
        />
      </div>
    </div>
  </article>
</BaseLayout>
