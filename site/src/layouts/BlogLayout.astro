---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ShareButton from "../components/ShareButton.astro";
import NewsletterCapture from "../components/NewsletterCapture.astro";
import { siteConfig } from "../../site.config";
import { fullUrl } from "../utils/config";
import { jsonLdArticle, jsonLdBreadcrumbs } from "../utils/seo";

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  category?: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  slug: string;
  keywords?: string;
  lang?: string;
  lastReviewed?: Date;
  reviewedBy?: string;
  /** Raw markdown body, used to derive wordCount + citation[] in the
   *  Article JSON-LD. Optional to stay backwards-compatible. */
  body?: string;
}

const {
  title,
  description,
  date,
  author = siteConfig.blog.defaultAuthor,
  category,
  tags = [],
  image,
  imageAlt,
  slug,
  keywords,
  lang = "fr",
  lastReviewed,
  reviewedBy,
  body,
} = Astro.props;

const isDefault = lang === "fr";
const blogPath = isDefault ? `/blog/${slug}` : `/${lang}/blog/${slug}`;
const blogIndexPath = isDefault ? `/blog` : `/${lang}/blog`;
const homePath = isDefault ? "/" : `/${lang}/`;

const articleUrl = fullUrl(blogPath);
const dateStr = date.toISOString().split("T")[0];

const LABELS: Record<string, { home: string; blog: string; share: string; shareBtn: string; locale: string; reviewed: string; reviewedBy: string }> = {
  fr: { home: "Accueil", blog: "Blog", share: "Cet article t'a plu ? Partage-le", shareBtn: "Partager l'article", locale: "fr-FR", reviewed: "Relu le", reviewedBy: "Relu par" },
  en: { home: "Home", blog: "Blog", share: "Enjoyed this article? Share it", shareBtn: "Share article", locale: "en-US", reviewed: "Reviewed on", reviewedBy: "Reviewed by" },
  es: { home: "Inicio", blog: "Blog", share: "Te gusto este articulo? Compartelo", shareBtn: "Compartir articulo", locale: "es-ES", reviewed: "Revisado el", reviewedBy: "Revisado por" },
  pt: { home: "Inicio", blog: "Blog", share: "Gostou deste artigo? Compartilhe", shareBtn: "Compartilhar artigo", locale: "pt-PT", reviewed: "Revisto em", reviewedBy: "Revisto por" },
  de: { home: "Startseite", blog: "Blog", share: "Hat dir der Artikel gefallen? Teile ihn", shareBtn: "Artikel teilen", locale: "de-DE", reviewed: "Geprueft am", reviewedBy: "Geprueft von" },
  it: { home: "Home", blog: "Blog", share: "Ti e piaciuto l'articolo? Condividilo", shareBtn: "Condividi articolo", locale: "it-IT", reviewed: "Revisionato il", reviewedBy: "Revisionato da" },
  tr: { home: "Ana sayfa", blog: "Blog", share: "Makaleyi begendin mi? Paylas", shareBtn: "Makaleyi paylas", locale: "tr-TR", reviewed: "Gozden gecirildi", reviewedBy: "Inceleyen" },
  pl: { home: "Strona glowna", blog: "Blog", share: "Spodobal ci sie artykul? Podziel sie nim", shareBtn: "Udostepnij artykul", locale: "pl-PL", reviewed: "Zweryfikowano", reviewedBy: "Zweryfikowane przez" },
  ru: { home: "Главная", blog: "Блог", share: "Понравилась статья? Поделись", shareBtn: "Поделиться", locale: "ru-RU", reviewed: "Проверено", reviewedBy: "Проверил" },
  ja: { home: "ホーム", blog: "ブログ", share: "記事が気に入った? シェアしよう", shareBtn: "記事をシェア", locale: "ja-JP", reviewed: "確認日", reviewedBy: "確認者" },
  ar: { home: "الرئيسية", blog: "المدونة", share: "هل أعجبك المقال؟ شاركه", shareBtn: "شارك المقال", locale: "ar-SA", reviewed: "تمت المراجعة في", reviewedBy: "راجعه" },
};
const labels = LABELS[lang] ?? LABELS.fr;
const reviewedDateStr = lastReviewed ? lastReviewed.toISOString().split("T")[0] : undefined;
const reviewedDateDisplay = lastReviewed
  ? lastReviewed.toLocaleDateString(labels.locale, { day: "numeric", month: "long", year: "numeric" })
  : undefined;

const breadcrumbs = [
  { name: labels.home, url: fullUrl(homePath) },
  { name: labels.blog, url: fullUrl(blogIndexPath) },
  { name: title, url: articleUrl },
];

function extractFaq(md: string | undefined): { q: string; a: string }[] {
  if (!md) return [];
  // Match FAQ section in multiple languages
  const m = md.match(/^##\s+(FAQ|Foire aux questions|Questions fr[ée]quentes|Frequently asked questions|Preguntas frecuentes|Domande frequenti|H[äa]ufige Fragen)[^\n]*$/im);
  if (!m || m.index === undefined) return [];
  let section = md.slice(m.index + m[0].length);
  const nextH2 = section.match(/^##\s+/m);
  if (nextH2 && nextH2.index !== undefined) section = section.slice(0, nextH2.index);
  const pairs: { q: string; a: string }[] = [];
  const cleanAnswer = (s: string) => s.replace(/\*\*/g, '').replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').replace(/\s+/g, ' ').trim();
  // Pattern A: ### Question \n answer
  const reH3 = /^###\s+([^\n]+)\n+([\s\S]*?)(?=^###\s+|$)/gm;
  let m2: RegExpExecArray | null;
  while ((m2 = reH3.exec(section)) !== null) {
    const q = m2[1].replace(/\s*\{#[^}]+\}\s*$/, '').replace(/\*\*/g, '').trim();
    const a = cleanAnswer(m2[2]);
    if (q && a) pairs.push({ q, a });
  }
  if (pairs.length > 0) return pairs;
  // Pattern B: **Question?** Answer (inline bold lead, common in karmastro)
  const reBold = /\*\*([^*\n]+\?)\*\*\s*([^\n]+(?:\n(?!\s*\n|\*\*|##)[^\n]+)*)/g;
  let m3: RegExpExecArray | null;
  while ((m3 = reBold.exec(section)) !== null) {
    const q = m3[1].trim();
    const a = cleanAnswer(m3[2]);
    if (q && a) pairs.push({ q, a });
  }
  return pairs;
}
const faqPairs = extractFaq(body);

const jsonLd: any[] = [
  jsonLdArticle({
    title,
    description,
    url: articleUrl,
    datePublished: dateStr,
    dateModified: reviewedDateStr,
    image,
    author,
    keywords: keywords?.split(",").map((k) => k.trim()),
    reviewedBy,
    inLanguage: labels.locale,
    body,
  }),
  jsonLdBreadcrumbs(breadcrumbs),
];

if (faqPairs.length > 0) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqPairs.map(({ q, a }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: { '@type': 'Answer', text: a },
    })),
  });
}
---

<BaseLayout
  title={`${title} | ${siteConfig.name}`}
  description={description}
  canonicalUrl={articleUrl}
  ogImage={image}
  ogType="article"
  publishedTime={dateStr}
  jsonLd={jsonLd}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      {category && (
        <span class="inline-block bg-primary/10 text-primary text-sm font-medium px-3 py-1 rounded-full mb-4">
          {category}
        </span>
      )}
      <h1 class="mb-4">{title}</h1>
      <div class="flex items-center gap-4 text-gray-500 text-sm flex-wrap">
        <span>{author}</span>
        <span>|</span>
        <time datetime={dateStr}>
          {date.toLocaleDateString(labels.locale, {
            day: "numeric",
            month: "long",
            year: "numeric",
          })}
        </time>
        {reviewedDateDisplay && (
          <>
            <span>|</span>
            <span>
              {labels.reviewed} <time datetime={reviewedDateStr}>{reviewedDateDisplay}</time>
            </span>
          </>
        )}
        {reviewedBy && (
          <>
            <span>|</span>
            <span>{labels.reviewedBy} {reviewedBy}</span>
          </>
        )}
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {image && (
      <figure class="mb-10">
        <img
          src={image}
          alt={imageAlt || title}
          class="w-full rounded-xl"
          loading="eager"
          width="800"
          height="450"
        />
      </figure>
    )}

    <div class="prose max-w-none">
      <slot />
    </div>

    <NewsletterCapture variant="card" source={`blog-${slug}`} />

    <div class="mt-12 pt-8 border-t border-white/10">
      <div class="flex flex-col items-center gap-4">
        <p class="text-sm text-white/60">{labels.share}</p>
        <ShareButton
          title={title}
          text={description}
          url={articleUrl}
          variant="secondary"
          label={labels.shareBtn}
        />
      </div>
    </div>
  </article>
</BaseLayout>
